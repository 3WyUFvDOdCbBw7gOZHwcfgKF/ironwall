  ))

  (export (function <generic set_toggle_entries_from_arrays T> ([target <Set T>] [slots <array <union unit <Box T>>>] [states <array i5>] [capacity i5]) to unit in
    {
      (var [index i5] $0^i5)
      (while (lt index capacity) in
        {
          (if (eq (array_get states index) $1^i5)
            then
              {
                (var [value T] (<set_slot_unwrap T> (array_get slots index)))
                (if (<set_contains T> target value)
                  then
                    {
                      ((cm_get target remove) value)
                      unit
                    }
                  else
                    {
                      ((cm_get target add) value)
                      unit
                    }
                )
                unit
              }
            else unit
          )
          (var_set index (add index $1^i5))
        }
      )
      unit
    }
  ))

  (export (function <generic set_isdisjoint_arrays T> ([slots <array <union unit <Box T>>>] [states <array i5>] [capacity i5] [other <Set T>]) to bool in
    {
      (var [index i5] $0^i5)
      (var [result bool] true)
      (while (lt index capacity) in
        {
          (if result
            then
              (if (eq (array_get states index) $1^i5)
                then
                  {
                    (if (<set_contains T> other (<set_slot_unwrap T> (array_get slots index)))
                      then
                        {
                          (var_set result false)
                          unit
                        }
                      else unit
                    )
                    unit
                  }
                else unit
              )
            else unit
          )
          (var_set index (add index $1^i5))
        }
      )
      result
    }
  ))

  (export (function <generic set_issubset_arrays T> ([slots <array <union unit <Box T>>>] [states <array i5>] [capacity i5] [other <Set T>]) to bool in
    {
      (var [index i5] $0^i5)
      (var [result bool] true)
      (while (lt index capacity) in
        {
          (if result
            then
              (if (eq (array_get states index) $1^i5)
                then
                  {
                    (if (<set_contains T> other (<set_slot_unwrap T> (array_get slots index)))
                      then unit
                      else
                        {
                          (var_set result false)
                          unit
                        }
                    )
                    unit
                  }
                else unit
              )
            else unit
          )
          (var_set index (add index $1^i5))
        }
      )
