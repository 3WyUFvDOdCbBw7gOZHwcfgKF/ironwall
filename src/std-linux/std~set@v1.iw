    }
  ))

  (export (function <generic set_new T> ([hash_rule <Hash T>] [eq_rule <Eq T>]) to <Set T> in
    (class_new <Set T> hash_rule eq_rule $8^i5)
  ))

  (export (function <generic set_len T> ([set <Set T>]) to i5 in
    (cm_get set size)
  ))

  (export (function <generic set_contains T> ([set <Set T>] [value T]) to bool in
    {
      (var [hash_value i5] (<hash_apply T> (cm_get set hash_rule) value))
      (cm_get
        (<set_find_slot T>
          (cm_get set slots)
          (cm_get set hashes)
          (cm_get set states)
          (cm_get set capacity)
          (cm_get set eq_rule)
          value
          hash_value
        )
        found
      )
    }
  ))

  (export (function <generic set_fold T Acc> ([source <Set T>] [init Acc] [step <to Acc from Acc T>]) to Acc in
    (<set_fold_slots_forward T Acc>
      (cm_get source slots)
      (cm_get source states)
      (cm_get source capacity)
      init
      step
    )
  ))

  (export (function <generic set_map T U> ([source <Set T>] [hash_rule <Hash U>] [eq_rule <Eq U>] [mapper <to U from T>]) to <Set U> in
    {
      (var [result <Set U>] (class_new <Set U> hash_rule eq_rule (cm_get source capacity)))
      (<set_add_mapped_entries_from_arrays T U>
        result
        (cm_get source slots)
        (cm_get source states)
        (cm_get source capacity)
        mapper
      )
      result
    }
  ))

  (export (function <generic set_filter T> ([source <Set T>] [predicate <to bool from T>]) to <Set T> in
    {
      (var [result <Set T>] (class_new <Set T> (cm_get source hash_rule) (cm_get source eq_rule) (cm_get source capacity)))
      (<set_add_filtered_entries_from_arrays T>
        result
        (cm_get source slots)
        (cm_get source states)
        (cm_get source capacity)
        predicate
      )
      result
    }
  ))

  (export (function <generic set_union T> ([left <Set T>] [right <Set T>]) to <Set T> in
    ((cm_get left union) right)
  ))

  (export (function <generic set_intersection T> ([left <Set T>] [right <Set T>]) to <Set T> in
    ((cm_get left intersection) right)
  ))

  (export (function <generic set_difference T> ([left <Set T>] [right <Set T>]) to <Set T> in
