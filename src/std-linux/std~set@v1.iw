    }
  ))

  (export (function <generic set_intersection_update_from_arrays T> ([target <Set T>] [other <Set T>]) to unit in
    {
      (var [index i5] $0^i5)
      (var [slots_now <array <union unit <Box T>>>] (cm_get target slots))
      (var [states_now <array i5>] (cm_get target states))
      (var [capacity_now i5] (cm_get target capacity))
      (while (lt index capacity_now) in
        {
          (if (eq (array_get states_now index) $1^i5)
            then
              {
                (var [value T] (<set_slot_unwrap T> (array_get slots_now index)))
                (if (<set_contains T> other value)
                  then unit
                  else (<set_remove_at_index T> target index)
                )
                unit
              }
            else unit
          )
          (var_set index (add index $1^i5))
        }
      )
      unit
    }
  ))

  (export (function <generic set_difference_update_from_arrays T> ([target <Set T>] [other <Set T>]) to unit in
    {
      (var [index i5] $0^i5)
      (var [slots_now <array <union unit <Box T>>>] (cm_get target slots))
      (var [states_now <array i5>] (cm_get target states))
      (var [capacity_now i5] (cm_get target capacity))
      (while (lt index capacity_now) in
        {
          (if (eq (array_get states_now index) $1^i5)
            then
              {
                (var [value T] (<set_slot_unwrap T> (array_get slots_now index)))
                (if (<set_contains T> other value)
                  then (<set_remove_at_index T> target index)
