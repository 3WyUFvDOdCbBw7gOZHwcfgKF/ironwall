  ))

  (export (function <generic Array_concat_into T> ([target <ArrayBuilder T>] [source <Array T>]) to unit in
    {
      (var [length_now i5] (cm_get target length))
      (var [source_raw <array T>] (cm_get source raw))
      (var [source_length i5] (array_length source_raw))
      (var [result_length i5] (checked_add_nonnegative_i5 length_now source_length))
      (<array_builder_ensure_capacity T> target result_length)
      (<array_copy_items T> source_raw $0^i5 (cm_get target raw) length_now source_length)
      (cm_set target length result_length)
      unit
    }
  ))

  (export (function <generic Array_concat T> ([left <Array T>] [right <Array T>]) to <Array T> in
    {
      (var [left_raw <array T>] (cm_get left raw))
      (var [right_raw <array T>] (cm_get right raw))
      (var [left_length i5] (array_length left_raw))
      (var [right_length i5] (array_length right_raw))
      (if (eq left_length $0^i5)
        then ((cm_get right copy))
        else
          (if (eq right_length $0^i5)
            then ((cm_get left copy))
            else
              {
                (var [seed_value T] (cm_get left seed))
                (var [result_raw <array T>] (array_new <array T> (checked_add_nonnegative_i5 left_length right_length) seed_value))
                (<array_copy_items T> left_raw $0^i5 result_raw $0^i5 left_length)
                (<array_copy_items T> right_raw $0^i5 result_raw left_length right_length)
                (class_new <Array T> result_raw seed_value)
              }
          )
      )
    }
  ))

  (export (function <generic Array_sorted T> ([source <Array T>] [rule <Ord T>]) to <Array T> in
    {
      (var [result <Array T>] ((cm_get source copy)))
      ((cm_get result sort) rule)
      result
    }
  ))

  (export (function <generic Array_reversed T> ([source <Array T>]) to <Array T> in
    {
      (var [source_raw <array T>] (cm_get source raw))
      (var [length i5] (array_length source_raw))
      (var [seed_value T] (cm_get source seed))
      (var [result_raw <array T>] (array_new <array T> length seed_value))
      (var [index i5] $0^i5)
      (while (lt index length) in
        {
          (array_set result_raw index (array_get source_raw (sub (sub length $1^i5) index)))
          (var_set index (add index $1^i5))
        }
      )
      (class_new <Array T> result_raw seed_value)
    }
  ))

  (export (function <generic Array_max T> ([array <Array T>] [rule <Ord T>]) to T in
    {
      (var [target_raw <array T>] (cm_get array raw))
      (var [length i5] (array_length target_raw))
      (if (eq length $0^i5)
        then (iw_match_unreachable)
        else
          {
            (var [best_index i5] $0^i5)
            (var [index i5] $1^i5)
            (while (lt index length) in
              {
                (if (gt (<ord_compare T> rule (array_get target_raw index) (array_get target_raw best_index)) $0^i5)
                  then
                    {
                      (var_set best_index index)
                      unit
                    }
                  else unit
                )
                (var_set index (add index $1^i5))
              }
            )
            (array_get target_raw best_index)
          }
      )
    }
  ))

  (export (function <generic Array_min T> ([array <Array T>] [rule <Ord T>]) to T in
    {
      (var [target_raw <array T>] (cm_get array raw))
      (var [length i5] (array_length target_raw))
      (if (eq length $0^i5)
        then (iw_match_unreachable)
        else
          {
            (var [best_index i5] $0^i5)
            (var [index i5] $1^i5)
            (while (lt index length) in
              {
