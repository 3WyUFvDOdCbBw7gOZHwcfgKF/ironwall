        (cm_get self capacity)
      )
    )
    (method items () to <List <Pair K V>> in
      (<dict_build_items_from_arrays K V>
        (class_new <Pair K V> (cm_get self key_seed) (cm_get self value_seed))
        (cm_get self key_slots)
        (cm_get self value_slots)
        (cm_get self states)
