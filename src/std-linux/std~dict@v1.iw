  (export (function <generic dict_find_slot K> ([key_slots <array <union unit <Box K>>>] [hashes <array i5>] [states <array i5>] [capacity i5] [eq_rule <Eq K>] [key K] [key_hash i5]) to DictLookupResult in
    {
      (var [slot i5] (mod key_hash capacity))
      (if (lt slot $0^i5)
        then
          {
            (var_set slot (add slot capacity))
            unit
          }
        else unit
      )
      (var [first_tombstone i5] capacity)
      (var [steps i5] $0^i5)
      (var [result DictLookupResult] (class_new DictLookupResult capacity false))
      (while (lt steps capacity) in
        {
          (var [state i5] (array_get states slot))
          (if (eq state $0^i5)
            then
              {
                (cm_set result index (if (lt first_tombstone capacity) then first_tombstone else slot))
                (cm_set result found false)
                (var_set steps capacity)
                unit
              }
            else
              (if (eq state $2^i5)
                then
                  {
                    (if (lt first_tombstone capacity)
                      then unit
                      else
                        {
                          (var_set first_tombstone slot)
                          unit
                        }
                    )
                    unit
                  }
                else
                  (if (eq (array_get hashes slot) key_hash)
                    then
                      (if (<eq_apply K> eq_rule (<dict_key_unwrap K> (array_get key_slots slot)) key)
                        then
                          {
                            (cm_set result index slot)
                            (cm_set result found true)
                            (var_set steps capacity)
                            unit
                          }
                        else unit
                      )
                    else unit
                  )
              )
          )
          (if (lt steps capacity)
            then
              {
                (var_set slot (mod (add slot $1^i5) capacity))
                (var_set steps (add steps $1^i5))
                unit
              }
            else unit
          )
        }
      )
      (if (lt (cm_get result index) capacity)
        then result
        else
          (if (lt first_tombstone capacity)
            then (class_new DictLookupResult first_tombstone false)
            else (iw_match_unreachable)
          )
      )
    }
  ))

  (export (function <generic dict_reset_storage K V> ([dict <Dict K V>] [capacity i5]) to unit in
    {
      (cm_set dict key_slots (<dict_new_key_slots K> capacity))
      (cm_set dict value_slots (<dict_new_value_slots V> capacity))
      (cm_set dict hashes (array_new <array i5> capacity $0^i5))
      (cm_set dict states (array_new <array i5> capacity $0^i5))
      (cm_set dict size $0^i5)
      (cm_set dict used $0^i5)
      (cm_set dict capacity capacity)
      (cm_set dict order (<list_new K> (cm_get dict key_seed)))
      unit
    }
  ))

  (export (function <generic dict_store_hashed K V> ([dict <Dict K V>] [key K] [value V] [key_hash i5] [record_order bool]) to unit in
    {
      (var [lookup DictLookupResult]
        (<dict_find_slot K>
          (cm_get dict key_slots)
          (cm_get dict hashes)
          (cm_get dict states)
          (cm_get dict capacity)
          (cm_get dict eq_rule)
          key
          key_hash
        )
      )
      (if (cm_get lookup found)
        then
          {
            (array_set (cm_get dict value_slots) (cm_get lookup index) (class_new <Box V> value))
            unit
          }
        else
          {
            (var [index i5] (cm_get lookup index))
            (var [prior_state i5] (array_get (cm_get dict states) index))
            (array_set (cm_get dict key_slots) index (class_new <Box K> key))
            (array_set (cm_get dict value_slots) index (class_new <Box V> value))
            (array_set (cm_get dict hashes) index key_hash)
            (array_set (cm_get dict states) index $1^i5)
            (cm_set dict size (add (cm_get dict size) $1^i5))
            (if (eq prior_state $0^i5)
              then
                {
                  (cm_set dict used (add (cm_get dict used) $1^i5))
                  unit
                }
              else unit
            )
            (if record_order
              then
                {
                  (var [order_now <List K>] (cm_get dict order))
                  (var [new_order_node <ListNode K>] (class_new <ListNode K> key (cm_get order_now items)))
                  (cm_set order_now items new_order_node)
                  (if (eq (cm_get order_now length) $0^i5)
                    then (cm_set order_now tail new_order_node)
                    else unit
                  )
                  (cm_set order_now length (add (cm_get order_now length) $1^i5))
                  unit
                }
              else unit
            )
            unit
          }
      )
    }
  ))

  (export (function <generic dict_resize K V> ([dict <Dict K V>] [new_capacity i5]) to unit in
    {
      (var [old_order <List K>] (cm_get dict order))
      (var [old_key_slots <array <union unit <Box K>>>] (cm_get dict key_slots))
      (var [old_value_slots <array <union unit <Box V>>>] (cm_get dict value_slots))
      (var [old_hashes <array i5>] (cm_get dict hashes))
      (var [old_states <array i5>] (cm_get dict states))
      (var [old_capacity i5] (cm_get dict capacity))
      (cm_set dict key_slots (<dict_new_key_slots K> new_capacity))
      (cm_set dict value_slots (<dict_new_value_slots V> new_capacity))
      (cm_set dict hashes (array_new <array i5> new_capacity $0^i5))
      (cm_set dict states (array_new <array i5> new_capacity $0^i5))
      (cm_set dict size $0^i5)
      (cm_set dict used $0^i5)
      (cm_set dict capacity new_capacity)
      (cm_set dict order old_order)
      (var [index i5] $0^i5)
      (while (lt index old_capacity) in
        {
          (if (eq (array_get old_states index) $1^i5)
            then
              {
                (<dict_store_hashed K V>
                  dict
                  (<dict_key_unwrap K> (array_get old_key_slots index))
                  (<dict_value_unwrap V> (array_get old_value_slots index))
                  (array_get old_hashes index)
                  false
                )
                unit
              }
            else unit
          )
          (var_set index (add index $1^i5))
        }
      )
      unit
    }
  ))

  (export (function <generic dict_store K V> ([dict <Dict K V>] [key K] [value V]) to unit in
    {
      (var [capacity_now i5] (cm_get dict capacity))
      (if (ge (mul (cm_get dict used) $4^i5) (mul capacity_now $3^i5))
        then
          {
            (<dict_resize K V> dict (mul capacity_now $2^i5))
            unit
          }
        else unit
      )
      (var [key_hash i5] (<hash_apply K> (cm_get dict hash_rule) key))
      (<dict_store_hashed K V> dict key value key_hash true)
      unit
    }
  ))

  (export (function <generic dict_get_existing_value K V> ([dict <Dict K V>] [key K]) to V in
    {
      (var [key_hash i5] (<hash_apply K> (cm_get dict hash_rule) key))
      (var [lookup DictLookupResult]
        (<dict_find_slot K>
