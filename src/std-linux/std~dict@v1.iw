  (export (class DictLookupResult
    (property [index i5])
    (property [found bool])
    (constructor ([index0 i5] [found0 bool]) in
      {
        (cm_set self index index0)
        (cm_set self found found0)
      }
    )
  ))

  (export (function <generic dict_key_unwrap K> ([slot <union unit <Box K>>]) to K in
    (match
      slot
      ([empty unit] (iw_match_unreachable))
      ([value <Box K>] (<box_unwrap K> value))
    )
  ))

  (export (function <generic dict_value_unwrap V> ([slot <union unit <Box V>>]) to V in
    (match
      slot
      ([empty unit] (iw_match_unreachable))
