  (export (function <generic dict_remove_at_index K V> ([dict <Dict K V>] [index i5]) to V in
    {
      (var [removed_key K] (<dict_key_unwrap K> (array_get (cm_get dict key_slots) index)))
      (var [result V] (<dict_value_unwrap V> (array_get (cm_get dict value_slots) index)))
      (var [order_now <List K>] (cm_get dict order))
      (if (gt (cm_get order_now length) $0^i5)
        then
          {
            (match (cm_get order_now items)
              ([empty unit] unit)
              ([head_node <ListNode K>]
                (if (<eq_apply K> (cm_get dict eq_rule) (cm_get head_node value) removed_key)
                  then
                    {
                      (cm_set order_now items (cm_get head_node next))
                      (cm_set order_now length (sub (cm_get order_now length) $1^i5))
                      (if (eq (cm_get order_now length) $0^i5)
                        then (cm_set order_now tail unit)
                        else unit
                      )
                      unit
                    }
                  else
                    {
                      (var [prev_cursor <union unit <ListNode K>>] (cm_get order_now items))
                      (var [removed bool] false)
                      (while (and (not removed) (gt (cm_get order_now length) $0^i5)) in
                        {
                          (match prev_cursor
                            ([empty unit] (var_set removed true))
                            ([prev_node <ListNode K>]
                              (match (cm_get prev_node next)
                                ([empty unit] (var_set removed true))
                                ([target_node <ListNode K>]
                                  (if (<eq_apply K> (cm_get dict eq_rule) (cm_get target_node value) removed_key)
                                    then
                                      {
                                        (cm_set prev_node next (cm_get target_node next))
                                        (match (cm_get target_node next)
                                          ([empty unit] (cm_set order_now tail prev_node))
                                          ([next_node <ListNode K>] unit)
                                        )
                                        (cm_set order_now length (sub (cm_get order_now length) $1^i5))
                                        (var_set removed true)
                                        unit
                                      }
                                    else
                                      {
                                        (var_set prev_cursor (cm_get prev_node next))
                                        unit
                                      }
                                  )
                                )
                              )
                            )
                          )
                        }
                      )
                      unit
                    }
                )
              )
            )
          }
        else unit
      )
      (array_set (cm_get dict key_slots) index unit)
      (array_set (cm_get dict value_slots) index unit)
      (array_set (cm_get dict hashes) index $0^i5)
      (array_set (cm_get dict states) index $2^i5)
      (cm_set dict size (sub (cm_get dict size) $1^i5))
      result
    }
  ))

  (export (function <generic dict_store_entries_from_arrays K V> ([target <Dict K V>] [key_slots <array <union unit <Box K>>>] [value_slots <array <union unit <Box V>>>] [states <array i5>] [capacity i5]) to unit in
    {
      (var [index i5] $0^i5)
      (while (lt index capacity) in
        {
          (if (eq (array_get states index) $1^i5)
            then
              {
