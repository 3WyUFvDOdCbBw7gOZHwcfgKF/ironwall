  (export (class <generic Dict K V>
    (property [hash_rule <Hash K>])
    (property [eq_rule <Eq K>])
    (property [key_seed K])
    (property [value_seed V])
    (property [key_slots <array <union unit <Box K>>>])
    (property [value_slots <array <union unit <Box V>>>])
    (property [hashes <array i5>])
    (property [states <array i5>])
    (property [size i5])
    (property [used i5])
    (property [capacity i5])
    (property [order <List K>])
    (constructor ([hash_rule0 <Hash K>] [eq_rule0 <Eq K>] [key_seed0 K] [value_seed0 V] [capacity0 i5]) in
      {
        (cm_set self hash_rule hash_rule0)
        (cm_set self eq_rule eq_rule0)
        (cm_set self key_seed key_seed0)
        (cm_set self value_seed value_seed0)
        (cm_set self key_slots (<dict_new_key_slots K> capacity0))
        (cm_set self value_slots (<dict_new_value_slots V> capacity0))
        (cm_set self hashes (array_new <array i5> capacity0 $0^i5))
        (cm_set self states (array_new <array i5> capacity0 $0^i5))
        (cm_set self size $0^i5)
        (cm_set self used $0^i5)
        (cm_set self capacity capacity0)
        (cm_set self order (<list_new K> key_seed0))
      }
    )
    (method get ([key K] [fallback V]) to V in
      {
        (var [key_hash i5] (<hash_apply K> (cm_get self hash_rule) key))
        (var [lookup DictLookupResult]
          (<dict_find_slot K>
            (cm_get self key_slots)
            (cm_get self hashes)
            (cm_get self states)
            (cm_get self capacity)
            (cm_get self eq_rule)
            key
            key_hash
          )
        )
        (if (cm_get lookup found)
          then (<dict_value_unwrap V> (array_get (cm_get self value_slots) (cm_get lookup index)))
          else fallback
        )
      }
    )
    (method pop ([key K]) to V in
      {
        (var [key_hash i5] (<hash_apply K> (cm_get self hash_rule) key))
        (var [lookup DictLookupResult]
          (<dict_find_slot K>
            (cm_get self key_slots)
            (cm_get self hashes)
            (cm_get self states)
            (cm_get self capacity)
            (cm_get self eq_rule)
            key
            key_hash
          )
        )
        (if (cm_get lookup found)
          then (<dict_remove_at_index K V> self (cm_get lookup index))
          else (iw_match_unreachable)
        )
      }
    )
    (method popitem () to <Pair K V> in
      {
        (var [order_now <List K>] (cm_get self order))
        (var [found i5] $0^i5)
        (var [result_key K] (cm_get self key_seed))
        (var [result_value V] (cm_get self value_seed))
        (while (and (gt (cm_get order_now length) $0^i5) (eq found $0^i5)) in
          {
            (match (cm_get order_now items)
              ([empty unit] (iw_match_unreachable))
              ([node <ListNode K>]
                {
                  (var [candidate K] (cm_get node value))
                  (if (<dict_contains K V> self candidate)
                    then
                      {
                        (var_set result_key candidate)
                        (var_set result_value (<dict_get_existing_value K V> self candidate))
                        ((cm_get self pop) candidate)
                        (var_set found $1^i5)
                        unit
                      }
                    else
                      {
                        (cm_set order_now items (cm_get node next))
                        (cm_set order_now length (sub (cm_get order_now length) $1^i5))
                        (if (eq (cm_get order_now length) $0^i5)
                          then (cm_set order_now tail unit)
                          else unit
                        )
                        unit
                      }
                  )
                }
              )
            )
          }
        )
        (if (eq found $1^i5)
          then (class_new <Pair K V> result_key result_value)
          else (iw_match_unreachable)
        )
      }
    )
    (method update ([other <Dict K V>]) to unit in
      {
        (<dict_store_entries_from_arrays K V>
          self
          (cm_get other key_slots)
          (cm_get other value_slots)
          (cm_get other states)
          (cm_get other capacity)
        )
        unit
      }
    )
    (method setdefault ([key K] [fallback V]) to V in
      {
        (var [key_hash i5] (<hash_apply K> (cm_get self hash_rule) key))
        (var [lookup DictLookupResult]
          (<dict_find_slot K>
            (cm_get self key_slots)
            (cm_get self hashes)
            (cm_get self states)
            (cm_get self capacity)
            (cm_get self eq_rule)
            key
            key_hash
          )
        )
        (if (cm_get lookup found)
          then (<dict_value_unwrap V> (array_get (cm_get self value_slots) (cm_get lookup index)))
          else
            {
