    (cm_get dict size)
  ))

  (export (function <generic dict_contains K V> ([dict <Dict K V>] [key K]) to bool in
    {
      (var [key_hash i5] (<hash_apply K> (cm_get dict hash_rule) key))
      (cm_get
        (<dict_find_slot K>
          (cm_get dict key_slots)
          (cm_get dict hashes)
          (cm_get dict states)
          (cm_get dict capacity)
          (cm_get dict eq_rule)
          key
          key_hash
        )
        found
      )
    }
  ))

  (export (function <generic dict_fold K V Acc> ([source <Dict K V>] [init Acc] [step <to Acc from Acc V>]) to Acc in
    (<dict_fold_values_from_arrays_reverse K V Acc>
      (cm_get source value_slots)
      (cm_get source states)
      (cm_get source capacity)
      init
      step
    )
  ))

  (export (function <generic dict_map_values K V U> ([source <Dict K V>] [value_seed U] [mapper <to U from K V>]) to <Dict K U> in
    {
      (var [result <Dict K U>]
        (class_new <Dict K U>
          (cm_get source hash_rule)
          (cm_get source eq_rule)
          (cm_get source key_seed)
          value_seed
          (cm_get source capacity)
        )
      )
      (<dict_store_mapped_entries_from_arrays K V U>
        result
        (cm_get source key_slots)
        (cm_get source value_slots)
        (cm_get source states)
        (cm_get source capacity)
        mapper
      )
      result
    }
  ))

  (export (function <generic dict_map K V U> ([source <Dict K V>] [value_seed U] [mapper <to U from K V>]) to <Dict K U> in
    (<dict_map_values K V U> source value_seed mapper)
  ))

  (export (function <generic dict_filter K V> ([source <Dict K V>] [predicate <to bool from K V>]) to <Dict K V> in
    {
      (var [result <Dict K V>]
        (class_new <Dict K V>
          (cm_get source hash_rule)
          (cm_get source eq_rule)
          (cm_get source key_seed)
          (cm_get source value_seed)
          (cm_get source capacity)
        )
      )
      (<dict_store_filtered_entries_from_arrays K V>
        result
        (cm_get source key_slots)
        (cm_get source value_slots)
        (cm_get source states)
        (cm_get source capacity)
        predicate
      )
      result
    }
  ))

  (export (function <generic dict_merge K V> ([left <Dict K V>] [right <Dict K V>]) to <Dict K V> in
    {
      (var [result <Dict K V>] ((cm_get left copy)))
      ((cm_get result update) right)
      result
    }
  ))

  (export (function <generic dict_equals K V> ([left <Dict K V>] [right <Dict K V>] [value_rule <Eq V>]) to bool in
    (if (eq (<dict_len K V> left) (<dict_len K V> right))
      then
        {
          (var [left_key_slots <array <union unit <Box K>>>] (cm_get left key_slots))
          (var [left_value_slots <array <union unit <Box V>>>] (cm_get left value_slots))
          (var [left_states <array i5>] (cm_get left states))
          (var [index i5] $0^i5)
          (var [total i5] (cm_get left capacity))
          (var [result bool] true)
          (while (lt index total) in
            {
              (if result
                then
                  {
                    (if (eq (array_get left_states index) $1^i5)
                      then
                        {
                          (var [candidate K] (<dict_key_unwrap K> (array_get left_key_slots index)))
                          (if (<dict_contains K V> right candidate)
                          then
                            (if (<eq_apply V> value_rule (<dict_value_unwrap V> (array_get left_value_slots index)) (<dict_get_existing_value K V> right candidate))
                              then unit
                              else
                                {
                                  (var_set result false)
                                  unit
                                }
                            )
                          else
                            {
                              (var_set result false)
                              unit
                            }
                        )
                        }
                      else unit
                    )
                    unit
                  }
                else unit
              )
              (var_set index (add index $1^i5))
            }
          )
          result
        }
      else false
    )
  ))
}
