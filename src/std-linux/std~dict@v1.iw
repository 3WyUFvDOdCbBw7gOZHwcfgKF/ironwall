              fallback
            }
        )
      }
    )
    (method clear () to unit in
      {
        (<dict_reset_storage K V> self (cm_get self capacity))
        unit
      }
    )
    (method copy () to <Dict K V> in
      {
        (var [result <Dict K V>]
          (class_new <Dict K V>
            (cm_get self hash_rule)
            (cm_get self eq_rule)
            (cm_get self key_seed)
            (cm_get self value_seed)
            (cm_get self capacity)
