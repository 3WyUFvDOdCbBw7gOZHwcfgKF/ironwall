{program std~ord@v1
  (export (class <generic Ord T>
    (property [comparator <to i5 from T T>])
    (constructor ([comparator0 <to i5 from T T>]) in
      (cm_set self comparator comparator0)
    )
    (method compare ([left T] [right T]) to i5 in
      ((cm_get self comparator) left right)
    )
  ))

  (export (function <generic ord_compare T> ([rule <Ord T>] [left T] [right T]) to i5 in
    ((cm_get rule compare) left right)
  ))
}