{program std~pair@v1
  (class <generic Pair K V>
    (property [first K])
    (property [second V])
    (constructor ([first0 K] [second0 V]) in
      {
        (cm_set self first first0)
        (cm_set self second second0)
      }
    )
  )

  (function <generic pair_first K V> ([pair <Pair K V>]) to K in
    (cm_get pair first)
  )

  (function <generic pair_second K V> ([pair <Pair K V>]) to V in
    (cm_get pair second)
  )
}