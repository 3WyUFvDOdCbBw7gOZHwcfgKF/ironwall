{program test~std~support_layer@main
  (import std~box)
  (import std~pair)
  (import std~eq)
  (import std~ord)
  (import std~hash)
  (function same_i5 ([left i5] [right i5]) to bool in (eq left right))
  (function compare_i5 ([left i5] [right i5]) to i5 in
    (if (lt left right) then $0neg1^i5 else (if (gt left right) then $1^i5 else $0^i5))
  )
  (function hash_i5 ([value i5]) to i5 in (add (mul value $17^i5) $3^i5))
  (function main ([args <array s3>]) to i5 in
    {
      (var [boxed <Box i5>] (class_new <Box i5> $30^i5))
      (var [pair <Pair i5 i5>] (class_new <Pair i5 i5> $4^i5 $9^i5))
      (var [eqv <Eq i5>] (class_new <Eq i5> same_i5))
      (var [ordv <Ord i5>] (class_new <Ord i5> compare_i5))
      (var [hashv <Hash i5>] (class_new <Hash i5> hash_i5))
      (add
        (<box_unwrap i5> boxed)
        (add
          (<pair_first i5 i5> pair)
          (add
            (<pair_second i5 i5> pair)
            (add
              (if (<eq_apply i5> eqv $4^i5 $4^i5) then $100^i5 else $0^i5)
              (add
                (mul (ordv.compare $9^i5 $4^i5) $10^i5)
                (<hash_apply i5> hashv $7^i5)
              )
            )
          )
        )
      )
    }
  )
}
