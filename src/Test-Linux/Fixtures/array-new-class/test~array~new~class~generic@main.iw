{program test~array~new~class~generic@main
  (class <generic TaggedBox T>
    (property [flag i5])
    (property [extra i5])
    (constructor () in {(cm_set self flag $23^i5) (cm_set self extra $5^i5)})
  )
  (function main ([args <array s3>]) to i5 in
    {
      (var [seed <TaggedBox i5>] <class_new TaggedBox i5>)
      (cm_set seed flag $77^i5)
      (cm_set seed extra $9^i5)
      (var [raw <array <TaggedBox i5>>] (array_new <array <TaggedBox i5>> $4^i5 seed))
      (var [left_flag i5] (cm_get (array_get raw $0^i5) flag))
      (cm_set (array_get raw $2^i5) flag $61^i5)
      (var [other_flag i5] (cm_get (array_get raw $1^i5) flag))
      (var [seed_flag i5] seed.flag)
      (add left_flag (add (mul other_flag $100^i5) (mul seed_flag $10000^i5)))
    }
  )
}
