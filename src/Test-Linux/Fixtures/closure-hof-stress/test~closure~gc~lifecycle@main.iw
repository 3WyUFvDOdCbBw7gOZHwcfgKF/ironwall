{program test~closure~gc~lifecycle@main
  (import std~gc)

  (class Marker
    (property [label s3])
    (property [rank i5])
    (constructor ([label0 s3] [rank0 i5]) in
      {
        (cm_set self label label0)
        (cm_set self rank rank0)
      }
    )
  )

  (class Payload
    (property [marker Marker])
    (property [name s3])
    (property [size i5])
    (constructor ([marker0 Marker] [name0 s3] [size0 i5]) in
      {
        (cm_set self marker marker0)
        (cm_set self name name0)
        (cm_set self size size0)
      }
    )
  )

  (function make_reader ([seed_text s3] [rank0 i5] [size0 i5]) to <to i5 from i5> in
    {
      (var [dynamic_text s3] (s3_new $5^i5 (s3_get seed_text $0^i5)))
      (var [marker Marker] (class_new Marker dynamic_text rank0))
      (var [payload Payload] (class_new Payload marker dynamic_text size0))
      (fn ([delta i5]) to i5 in
        (add marker.rank (add payload.size (add (s3_length payload.name) delta)))
      )
    }
  )

  (function dead_wave ([seed_text s3] [start i5]) to i5 in
    {
      (var [first <to i5 from i5>] (make_reader seed_text start $1^i5))
      (var [second <to i5 from i5>] (make_reader seed_text (add start $1^i5) $2^i5))
      (var [third <to i5 from i5>] (make_reader seed_text (add start $2^i5) $3^i5))
      (add (first $1^i5) (add (second $1^i5) (third $1^i5)))
    }
  )

  (function main ([args <array s3>]) to i5 in
    {
      (var [noise_before i5] (dead_wave $dead_s3^s3 $4^i5))
      (var [live_reader <to i5 from i5>] (make_reader $hello_s3^s3 $7^i5 $2^i5))
      (var [live_before_gc i5] (live_reader $3^i5))
      (var [noise_after i5] (dead_wave $junk_s3^s3 $10^i5))
      (var [first_reclaimed i5] (gc_collect))
      (var [live_after_gc i5] (live_reader $4^i5))
      (var [second_reclaimed i5] (gc_collect))
      (add
        noise_before
        (add
          live_before_gc
          (add
            noise_after
            (add first_reclaimed (add live_after_gc second_reclaimed))
          )
        )
      )
    }
  )
}
