{program test~std~string~ops@s4_main
  (import std~array)
  (import std~string)

  (function score_s4 ([value bool]) to i5 in (if value then $1^i5 else $0^i5))

  (function same_s4 ([left s4] [right s4]) to bool in
    {
      (var [left_len i5] (s4_length left))
      (var [right_len i5] (s4_length right))
      (if (neq left_len right_len)
        then false
        else
          {
            (var [same bool] true)
            (var [index i5] $0^i5)
            (while (and same (lt index left_len)) in
              {
                (var_set same (eq (s4_get left index) (s4_get right index)))
                (var_set index (add index $1^i5))
              }
            )
            same
          }
      )
    }
  )

  (function main ([args <array s3>]) to i5 in
    {
      (var [hello StringS4] (class_new StringS4 $hello_s4^s4))
      (var [ell StringS4] (class_new StringS4 $ell_s4^s4))
      (var [lo StringS4] (class_new StringS4 $lo_s4^s4))
      (var [world StringS4] (class_new StringS4 $world_s4^s4))
      (var [empty StringS4] (class_new StringS4 $empty_s4^s4))
      (var [comma StringS4] (class_new StringS4 $comma_s4^s4))
      (var [csv StringS4] (class_new StringS4 $csv_s4^s4))
      (var [aa StringS4] (class_new StringS4 $aa_s4^s4))
      (var [bb StringS4] (class_new StringS4 $bb_s4^s4))
      (var [dd StringS4] (class_new StringS4 $dd_s4^s4))
      (var [padded StringS4] (class_new StringS4 $padded_s4^s4))
      (var [padded_inner StringS4] (class_new StringS4 $padded_inner_s4^s4))
      (var [inner StringS4] (class_new StringS4 $inner_s4^s4))
      (var [slice_mid StringS4] (string_slice hello $1^i5 $4^i5))
      (var [slice_tail StringS4] (string_slice hello (sub $0^i5 $2^i5) (string_len hello)))
      (var [slice_clamped StringS4] (string_slice hello (sub $0^i5 $99^i5) $99^i5))
      (var [trimmed StringS4] (string_trim padded))
      (var [trimmed_inner StringS4] (string_trim padded_inner))
      (var [csv_parts <Array StringS4>] (string_split csv comma))
      (var [no_match_parts <Array StringS4>] (string_split hello world))
      (var [empty_parts <Array StringS4>] (<array_new_fill StringS4> $0^i5 empty))
      (var [rejoined_csv StringS4] (string_join comma csv_parts))
      (var [rejoined_empty StringS4] (string_join comma empty_parts))
      (add
        (score_s4 (same_s4 slice_mid.raw ell.raw))
        (add
          (score_s4 (same_s4 slice_tail.raw lo.raw))
          (add
            (score_s4 (same_s4 slice_clamped.raw hello.raw))
            (add
              (score_s4 (same_s4 trimmed.raw hello.raw))
              (add
                (score_s4 (same_s4 trimmed_inner.raw inner.raw))
                (add
                  (score_s4 (eq (<Array_len StringS4> csv_parts) $4^i5))
                  (add
                    (score_s4 (same_s4 (cm_get (csv_parts.get $0^i5) raw) aa.raw))
                    (add
                      (score_s4 (same_s4 (cm_get (csv_parts.get $1^i5) raw) bb.raw))
                      (add
                        (score_s4 (same_s4 (cm_get (csv_parts.get $2^i5) raw) empty.raw))
                        (add
                          (score_s4 (same_s4 (cm_get (csv_parts.get $3^i5) raw) dd.raw))
                          (add
                            (score_s4 (same_s4 rejoined_csv.raw csv.raw))
                            (add
                              (score_s4 (eq (<Array_len StringS4> no_match_parts) $1^i5))
                              (add
                                (score_s4 (same_s4 (cm_get (no_match_parts.get $0^i5) raw) hello.raw))
                                (score_s4 (same_s4 rejoined_empty.raw empty.raw))
                              )
                            )
                          )
                        )
                      )
                    )
                  )
                )
              )
            )
          )
        )
      )
    }
  )
}