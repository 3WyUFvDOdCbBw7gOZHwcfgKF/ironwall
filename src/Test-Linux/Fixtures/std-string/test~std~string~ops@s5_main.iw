{program test~std~string~ops@s5_main
  (import std~array)
  (import std~string)

  (function score_s5 ([value bool]) to i5 in (if value then $1^i5 else $0^i5))

  (function same_s5 ([left s5] [right s5]) to bool in
    {
      (var [left_len i5] (s5_length left))
      (var [right_len i5] (s5_length right))
      (if (neq left_len right_len)
        then false
        else
          {
            (var [same bool] true)
            (var [index i5] $0^i5)
            (while (and same (lt index left_len)) in
              {
                (var_set same (eq (s5_get left index) (s5_get right index)))
                (var_set index (add index $1^i5))
              }
            )
            same
          }
      )
    }
  )

  (function main ([args <array s3>]) to i5 in
    {
      (var [hello StringS5] (class_new StringS5 $hello_s5^s5))
      (var [ell StringS5] (class_new StringS5 $ell_s5^s5))
      (var [lo StringS5] (class_new StringS5 $lo_s5^s5))
      (var [world StringS5] (class_new StringS5 $world_s5^s5))
      (var [empty StringS5] (class_new StringS5 $empty_s5^s5))
      (var [comma StringS5] (class_new StringS5 $comma_s5^s5))
      (var [csv StringS5] (class_new StringS5 $csv_s5^s5))
      (var [aa StringS5] (class_new StringS5 $aa_s5^s5))
      (var [bb StringS5] (class_new StringS5 $bb_s5^s5))
      (var [dd StringS5] (class_new StringS5 $dd_s5^s5))
      (var [padded StringS5] (class_new StringS5 $padded_s5^s5))
      (var [padded_inner StringS5] (class_new StringS5 $padded_inner_s5^s5))
      (var [inner StringS5] (class_new StringS5 $inner_s5^s5))
      (var [slice_mid StringS5] (string_slice hello $1^i5 $4^i5))
      (var [slice_tail StringS5] (string_slice hello (sub $0^i5 $2^i5) (string_len hello)))
      (var [slice_clamped StringS5] (string_slice hello (sub $0^i5 $99^i5) $99^i5))
      (var [trimmed StringS5] (string_trim padded))
      (var [trimmed_inner StringS5] (string_trim padded_inner))
      (var [csv_parts <Array StringS5>] (string_split csv comma))
      (var [no_match_parts <Array StringS5>] (string_split hello world))
      (var [empty_parts <Array StringS5>] (<array_new_fill StringS5> $0^i5 empty))
      (var [rejoined_csv StringS5] (string_join comma csv_parts))
      (var [rejoined_empty StringS5] (string_join comma empty_parts))
      (add
        (score_s5 (same_s5 slice_mid.raw ell.raw))
        (add
          (score_s5 (same_s5 slice_tail.raw lo.raw))
          (add
            (score_s5 (same_s5 slice_clamped.raw hello.raw))
            (add
              (score_s5 (same_s5 trimmed.raw hello.raw))
              (add
                (score_s5 (same_s5 trimmed_inner.raw inner.raw))
                (add
                  (score_s5 (eq (<Array_len StringS5> csv_parts) $4^i5))
                  (add
                    (score_s5 (same_s5 (cm_get (csv_parts.get $0^i5) raw) aa.raw))
                    (add
                      (score_s5 (same_s5 (cm_get (csv_parts.get $1^i5) raw) bb.raw))
                      (add
                        (score_s5 (same_s5 (cm_get (csv_parts.get $2^i5) raw) empty.raw))
                        (add
                          (score_s5 (same_s5 (cm_get (csv_parts.get $3^i5) raw) dd.raw))
                          (add
                            (score_s5 (same_s5 rejoined_csv.raw csv.raw))
                            (add
                              (score_s5 (eq (<Array_len StringS5> no_match_parts) $1^i5))
                              (add
                                (score_s5 (same_s5 (cm_get (no_match_parts.get $0^i5) raw) hello.raw))
                                (score_s5 (same_s5 rejoined_empty.raw empty.raw))
                              )
                            )
                          )
                        )
                      )
                    )
                  )
                )
              )
            )
          )
        )
      )
    }
  )
}