{program test~gc~explicit~only@main
  (import std~gc)
  (class Marker
    (property [label s3])
    (property [rank i5])
    (constructor ([label0 s3] [rank0 i5]) in
      {
        (cm_set self label label0)
        (cm_set self rank rank0)
      }
    )
  )
  (class Payload
    (property [marker Marker])
    (property [name s3])
    (property [size i5])
    (constructor ([marker0 Marker] [name0 s3] [size0 i5]) in
      {
        (cm_set self marker marker0)
        (cm_set self name name0)
        (cm_set self size size0)
      }
    )
  )
  (function dead_leaf ([source_text s3] [rank0 i5]) to i5 in
    {
      (var [dead_text s3] (s3_new $4^i5 (s3_get source_text $0^i5)))
      (var [dead_marker Marker] (class_new Marker dead_text rank0))
      (var [dead_items <array s3>] (array_new <array s3> $1^i5 dead_text))
      (add (s3_length dead_text) (add dead_marker.rank (array_length dead_items)))
    }
  )
  (function dead_wrapper ([source_text s3] [seed i5]) to i5 in
    {
      (var [left i5] (dead_leaf source_text seed))
      (var [right i5] (dead_leaf source_text (add seed $1^i5)))
      (add left right)
    }
  )
  (function touch_live ([marker Marker] [payload Payload] [items <array s3>]) to i5 in
    (add
      marker.rank
      (add payload.size (add (s3_length payload.name) (array_length items)))
    )
  )
  (function main ([args <array s3>]) to i5 in
    {
      (var [pre_noise i5] (dead_wrapper $dead_s3^s3 $9^i5))
      (var [dynamic_text s3] (s3_new $5^i5 (s3_get $hello_s3^s3 $0^i5)))
      (var [marker Marker] (class_new Marker dynamic_text $7^i5))
      (var [payload Payload] (class_new Payload marker dynamic_text $2^i5))
      (var [items <array s3>] (array_new <array s3> $2^i5 dynamic_text))
      (var [live_score i5] (touch_live marker payload items))
      (var [post_noise i5] (dead_wrapper $junk_s3^s3 $3^i5))
      (var [first_reclaimed i5] (gc_collect))
      (var [second_reclaimed i5] (gc_collect))
      (add
        pre_noise
        (add live_score (add post_noise (add first_reclaimed second_reclaimed)))
      )
    }
  )
}
