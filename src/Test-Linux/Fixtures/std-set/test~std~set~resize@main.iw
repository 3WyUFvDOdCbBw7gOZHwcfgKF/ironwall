{program test~std~set~resize@main
  (import std~set)
  (import std~eq)
  (import std~hash)
  (function same_i5 ([left i5] [right i5]) to bool in (eq left right))
  (function id_hash ([value i5]) to i5 in value)
  (function main ([args <array s3>]) to i5 in
    {
      (var [eq_rule <Eq i5>] (class_new <Eq i5> same_i5))
      (var [hash_rule <Hash i5>] (class_new <Hash i5> id_hash))
      (var [source <Set i5>] (<set_new i5> hash_rule eq_rule))
      (source.add $0^i5)
      (source.add $1^i5)
      (source.add $2^i5)
      (source.add $3^i5)
      (source.add $4^i5)
      (source.add $5^i5)
      (source.add $6^i5)
      (source.add $7^i5)
      (source.add $8^i5)
      (source.add $9^i5)
      (source.add $10^i5)
      (source.add $11^i5)
      (source.add $12^i5)
      (source.add $13^i5)
      (source.add $14^i5)
      (source.add $15^i5)
      (source.add $16^i5)
      (source.add $17^i5)
      (source.add $18^i5)
      (source.add $19^i5)
      (source.add $5^i5)
      (source.remove $3^i5)
      (source.remove $7^i5)
      (source.remove $11^i5)
      (source.add $27^i5)
      (source.add $31^i5)
      (source.add $35^i5)
      (var [other <Set i5>] (<set_new i5> hash_rule eq_rule))
      (other.add $10^i5)
      (other.add $12^i5)
      (other.add $27^i5)
      (other.add $40^i5)
      (var [unioned <Set i5>] (source.union other))
      (var [intersected <Set i5>] (source.intersection other))
      (var [diffed <Set i5>] (source.difference other))
      (var [symdiffed <Set i5>] (source.symmetric_difference other))
      (var [copy <Set i5>] (source.copy))
      (copy.clear)
      (copy.add $50^i5)
      (copy.add $51^i5)
      (var [popped i5] (copy.pop))
      (var [popped_valid i5] (if (eq popped $50^i5) then $5^i5 else (if (eq popped $51^i5) then $5^i5 else $0^i5)))
      (copy.discard $999^i5)
      (var [update_target <Set i5>] (<set_new i5> hash_rule eq_rule))
      (update_target.add $100^i5)
      (update_target.update source)
      (var [intersection_target <Set i5>] (source.copy))
      (intersection_target.intersection_update other)
      (var [difference_target <Set i5>] (source.copy))
      (difference_target.difference_update other)
      (var [symdiff_target <Set i5>] (source.copy))
      (symdiff_target.symmetric_difference_update other)
      (add
        (add
          (<set_len i5> source)
          (add
            (<set_len i5> unioned)
            (add
              (<set_len i5> intersected)
              (add
                (<set_len i5> diffed)
                (add
                  (<set_len i5> symdiffed)
                  (add
                    popped_valid
                    (add
                      (<set_len i5> copy)
                      (add
                        (<set_len i5> update_target)
                        (add
                          (<set_len i5> intersection_target)
                          (add
                            (<set_len i5> difference_target)
                            (<set_len i5> symdiff_target)
                          )
                        )
                      )
                    )
                  )
                )
              )
            )
          )
        )
        (add
          (if (<set_contains i5> source $27^i5) then $100^i5 else $0^i5)
          (add
            (if (<set_contains i5> source $3^i5) then $0^i5 else $10^i5)
            (add
              (if (<set_contains i5> unioned $40^i5) then $20^i5 else $0^i5)
              (add
                (if (<set_contains i5> intersected $12^i5) then $30^i5 else $0^i5)
                (add
                  (if (<set_contains i5> diffed $10^i5) then $0^i5 else $40^i5)
                  (add
                    (if (<set_contains i5> symdiffed $40^i5) then $50^i5 else $0^i5)
                    (add
                      (if (intersected.issubset unioned) then $60^i5 else $0^i5)
                      (add
                        (if (unioned.issuperset intersected) then $70^i5 else $0^i5)
                        (add
                          (if (diffed.isdisjoint other) then $80^i5 else $0^i5)
                          (add
                            (if
                              (<set_contains i5> update_target $100^i5)
                              then
                              $90^i5
                              else
                              $0^i5
                            )
                            (add
                              (if
                                (<set_contains i5> copy popped)
                                then
                                $0^i5
                                else
                                $10^i5
                              )
                              (if
                                (<set_contains i5> copy $50^i5)
                                then
                                $100^i5
                                else
                                $0^i5
                              )
                            )
                          )
                        )
                      )
                    )
                  )
                )
              )
            )
          )
        )
      )
    }
  )
}
