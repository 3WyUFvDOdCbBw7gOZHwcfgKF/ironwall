{program test~std~memory~string~ops~baseline@main
  (import std~array)
  (import std~string)

  (function score ([value bool]) to i5 in (if value then $1^i5 else $0^i5))

  (function clamp_string_index ([length i5] [index i5]) to i5 in
    (if (lt index $0^i5)
      then
        (if (lt index (sub $0^i5 length))
          then $0^i5
          else (add length index)
        )
      else
        (if (gt index length)
          then length
          else index
        )
    )
  )

  (function is_ascii_trim_space_code ([code i5]) to bool in
    (or (eq code $32^i5) (and (ge code $9^i5) (le code $13^i5)))
  )

  (function is_trim_space ([value c3]) to bool in
    (is_ascii_trim_space_code (val_to_i5 value))
  )

  (function slow_s3_slice_span ([source s3] [start i5] [end_exclusive i5]) to s3 in
    {
      (var [slice_len i5] (sub end_exclusive start))
      (if (le slice_len $0^i5)
        then $empty_s3^s3
        else
          {
            (var [result s3] (s3_new slice_len (s3_get source start)))
            (var [index i5] $0^i5)
            (while (lt index slice_len) in
              {
                (s3_set result index (s3_get source (add start index)))
                (var_set index (add index $1^i5))
              }
            )
            result
          }
      )
    }
  )

  (function slow_string_slice ([value StringS3] [start i5] [end_exclusive i5]) to StringS3 in
    {
      (var [source s3] (cm_get value raw))
      (var [length i5] (s3_length source))
      (var [slice_start i5] (clamp_string_index length start))
      (var [slice_end i5] (clamp_string_index length end_exclusive))
      (class_new StringS3 (slow_s3_slice_span source slice_start slice_end))
    }
  )

  (function slow_string_trim ([value StringS3]) to StringS3 in
    {
      (var [source s3] (cm_get value raw))
      (var [length i5] (s3_length source))
      (var [left i5] $0^i5)
      (var [right i5] length)
      (while (and (lt left right) (is_trim_space (s3_get source left))) in
        {
          (var_set left (add left $1^i5))
        }
      )
      (while (and (lt left right) (is_trim_space (s3_get source (sub right $1^i5)))) in
        {
          (var_set right (sub right $1^i5))
        }
      )
      (class_new StringS3 (slow_s3_slice_span source left right))
    }
  )

  (function slow_s3_matches_at ([haystack s3] [needle s3] [start i5]) to bool in
    {
      (var [haystack_len i5] (s3_length haystack))
      (var [needle_len i5] (s3_length needle))
      (if (gt (add start needle_len) haystack_len)
        then false
        else
          {
            (var [same bool] true)
            (var [offset i5] $0^i5)
            (while (and same (lt offset needle_len)) in
              {
                (var_set same (eq (s3_get haystack (add start offset)) (s3_get needle offset)))
                (var_set offset (add offset $1^i5))
              }
            )
            same
          }
      )
    }
  )

  (function slow_string_split ([value StringS3] [delimiter StringS3] [empty StringS3]) to <Array StringS3> in
    {
      (var [source s3] (cm_get value raw))
      (var [needle s3] (cm_get delimiter raw))
      (var [source_len i5] (s3_length source))
      (var [needle_len i5] (s3_length needle))
      (var [builder <ArrayBuilder StringS3>] (<array_builder_new StringS3> empty))
      (if (eq needle_len $0^i5)
        then
          {
            (var [char_index i5] $0^i5)
            (while (lt char_index source_len) in
              {
                (builder.append (class_new StringS3 (slow_s3_slice_span source char_index (add char_index $1^i5))))
                (var_set char_index (add char_index $1^i5))
              }
            )
            (builder.build)
          }
        else
          {
            (var [segment_start i5] $0^i5)
            (var [scan_index i5] $0^i5)
            (while (le (add scan_index needle_len) source_len) in
              {
                (if (slow_s3_matches_at source needle scan_index)
                  then
                    {
                      (builder.append (class_new StringS3 (slow_s3_slice_span source segment_start scan_index)))
                      (var_set segment_start (add scan_index needle_len))
                      (var_set scan_index (add scan_index needle_len))
                    }
                  else (var_set scan_index (add scan_index $1^i5))
                )
              }
            )
            (builder.append (class_new StringS3 (slow_s3_slice_span source segment_start source_len)))
            (builder.build)
          }
      )
    }
  )

  (function slow_string_join ([separator StringS3] [items <Array StringS3>] [empty StringS3]) to StringS3 in
    {
      (var [result StringS3] empty)
      (var [index i5] $0^i5)
      (var [item_count i5] (<Array_len StringS3> items))
      (while (lt index item_count) in
        {
          (if (gt index $0^i5)
            then (var_set result (string_concat result separator))
            else unit
          )
          (var_set result (string_concat result (items.get index)))
          (var_set index (add index $1^i5))
        }
      )
      result
    }
  )

  (function build_parts ([alpha StringS3] [beta StringS3] [gamma StringS3] [empty StringS3]) to <Array StringS3> in
    {
      (var [builder <ArrayBuilder StringS3>] (<array_builder_new StringS3> empty))
      (var [index i5] $0^i5)
      (while (lt index $256^i5) in
        {
          (if (eq (mod index $3^i5) $0^i5)
            then (builder.append alpha)
            else
              (if (eq (mod index $3^i5) $1^i5)
                then (builder.append beta)
                else (builder.append gamma)
              )
          )
          (var_set index (add index $1^i5))
        }
      )
      (builder.build)
    }
  )

  (function normalized_join_round ([parts <Array StringS3>] [comma StringS3] [pipe StringS3] [empty StringS3]) to StringS3 in
    {
      (var [joined StringS3] (slow_string_join comma parts empty))
      (var [segments <Array StringS3>] (slow_string_split joined comma empty))
      (var [builder <ArrayBuilder StringS3>] (<array_builder_new StringS3> empty))
      (var [index i5] $0^i5)
      (var [segment_count i5] (<Array_len StringS3> segments))
      (while (lt index segment_count) in
        {
          (var [trimmed StringS3] (slow_string_trim (segments.get index)))
          (builder.append (slow_string_slice trimmed $1^i5 (sub $0^i5 $1^i5)))
          (var_set index (add index $1^i5))
        }
      )
      (slow_string_join pipe (builder.build) empty)
    }
  )

  (function main ([args <array s3>]) to i5 in
    {
      (var [empty StringS3] (class_new StringS3 $empty_s3^s3))
      (var [comma StringS3] (class_new StringS3 $comma_s3^s3))
      (var [pipe StringS3] (class_new StringS3 $pipe_s3^s3))
      (var [alpha_padded StringS3] (class_new StringS3 $padded_alpha_s3^s3))
      (var [beta_padded StringS3] (class_new StringS3 $padded_beta_s3^s3))
      (var [gamma_padded StringS3] (class_new StringS3 $padded_gamma_s3^s3))
      (var [alpha StringS3] (class_new StringS3 $alpha_s3^s3))
      (var [parts <Array StringS3>] (build_parts alpha_padded beta_padded gamma_padded empty))
      (var [last StringS3] empty)
      (var [length_sum i5] $0^i5)
      (var [round i5] $0^i5)
      (while (lt round $32^i5) in
        {
          (var [round_result StringS3] (normalized_join_round parts comma pipe empty))
          (var_set last round_result)
          (var_set length_sum (add length_sum (string_len round_result)))
          (var_set round (add round $1^i5))
        }
      )
      (add
        (score (eq length_sum $46400^i5))
        (add
          (score (eq (string_len last) $1450^i5))
          (add
            (score (eq (last.count pipe) $255^i5))
            (add
              (score (last.startswith alpha))
              (score (last.endswith alpha))
            )
          )
        )
      )
    }
  )
}