{program test~std~sys~socketpair_stream@main
  (import std~linux~sys)
  (import test~std~sys~lib)
  (function main ([args <array s3>]) to i5 in
    {
      (var [pair_fds <array i5>] (sys_net_socketpair_stream))
      (var [left_fd i5] (pipe_read_fd pair_fds))
      (var [right_fd i5] (pipe_write_fd pair_fds))
      (var [left_sent i5] (sys_net_send_s3 left_fd $socketpair_left_s3^s3))
      (var [right_received s3] (sys_net_recv_s3 right_fd $64^i5))
      (var [right_sent i5] (sys_net_send_s3 right_fd $socketpair_right_s3^s3))
      (var [left_received s3] (sys_net_recv_s3 left_fd $64^i5))
      (sys_fd_close right_fd)
      (sys_fd_close left_fd)
      (add
        $420^i5
        (add
          (score (eq left_sent (s3_length $socketpair_left_s3^s3)))
          (add
            (score (s3_equals right_received $socketpair_left_s3^s3))
            (add
              (score (eq right_sent (s3_length $socketpair_right_s3^s3)))
              (score (s3_equals left_received $socketpair_right_s3^s3))
            )
          )
        )
      )
    }
  )
}
