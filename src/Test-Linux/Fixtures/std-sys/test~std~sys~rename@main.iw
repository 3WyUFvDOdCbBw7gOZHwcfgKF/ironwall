{program test~std~sys~rename@main
  (import std~linux~sys)
  (import test~std~sys~lib)
  (function main ([args <array s3>]) to i5 in
    {
      (sys_path_rename_s3 $sys_rename_source_path_s3^s3 $sys_rename_target_path_s3^s3)
      (var [fd i5] (sys_fd_open_read_s3 $sys_rename_target_path_s3^s3))
      (var [received s3] (sys_fd_read_s3 fd $32^i5))
      (sys_fd_close fd)
      (add $350^i5 (score (s3_equals received $sys_rename_payload_s3^s3)))
    }
  )
}
