{program test~std~sys~poll_socketpair@main
  (import std~linux~sys)
  (import test~std~sys~lib)
  (function main ([args <array s3>]) to i5 in
    {
      (var [pair_fds <array i5>] (sys_net_socketpair_stream))
      (var [left_fd i5] (pipe_read_fd pair_fds))
      (var [right_fd i5] (pipe_write_fd pair_fds))
      (var [sent i5] (sys_net_send_s3 right_fd $poll_socketpair_payload_s3^s3))
      (var [fds <array i5>] (array_new <array i5> $1^i5 left_fd))
      (var [requested_events <array i5>] (array_new <array i5> $1^i5 (sys_poll_in_flag)))
      (var [events <array SysPollEvent>] (sys_poll fds requested_events $5000^i5))
      (var [ready bool] false)
      (var [fd_ok bool] false)
      (var [events_ok bool] false)
      (var [revents_ok bool] false)
      (if
        (gt (array_length events) $0^i5)
        then
        {
          (var [event SysPollEvent] (array_get events $0^i5))
          (var_set ready (sys_poll_event_has_in event))
          (var_set fd_ok (eq (sys_poll_event_fd event) left_fd))
          (var_set events_ok (eq (sys_poll_event_events event) (sys_poll_in_flag)))
          (var_set revents_ok (eq (bwand (sys_poll_event_revents event) (sys_poll_in_flag)) (sys_poll_in_flag)))
          unit
        }
        else
        unit
      )
      (var [received s3] (sys_net_recv_s3 left_fd $64^i5))
      (sys_fd_close right_fd)
      (sys_fd_close left_fd)
      (add
        $610^i5
        (add
          (score (eq sent (s3_length $poll_socketpair_payload_s3^s3)))
          (add
            (score ready)
            (add
              (score fd_ok)
              (add
                (score events_ok)
                (add
                  (score revents_ok)
                  (score (s3_equals received $poll_socketpair_payload_s3^s3))
                )
              )
            )
          )
        )
      )
    }
  )
}
