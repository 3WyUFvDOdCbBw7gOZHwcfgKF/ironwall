{program test~std~sys~mkdir@main
  (import std~linux~sys)
  (import test~std~sys~lib)
  (function main ([args <array s3>]) to i5 in
    {
      (sys_path_mkdir_s3 $sys_mkdir_path_s3^s3)
      (var [dir_fd i5] (sys_fd_open_read_s3 $sys_mkdir_path_s3^s3))
      (var [dir_stat SysFileStat] (sys_fd_fstat dir_fd))
      (sys_fd_close dir_fd)
      (add $320^i5 (score (sys_stat_is_dir dir_stat)))
    }
  )
}
