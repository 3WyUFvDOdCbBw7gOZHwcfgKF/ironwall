{program test~std~sys~readv_writev_socketpair@main
  (import std~linux~sys)
  (import test~std~sys~lib)
  (function main ([args <array s3>]) to i5 in
    {
      (var [pair_fds <array i5>] (sys_net_socketpair_stream))
      (var [left_fd i5] (pipe_read_fd pair_fds))
      (var [right_fd i5] (pipe_write_fd pair_fds))
      (var [chunks <array s3>] (s3_array3 $readv_chunk0_s3^s3 $readv_chunk1_s3^s3 $readv_chunk2_s3^s3))
      (var [sent i5] (sys_fd_writev_s3 left_fd chunks))
      (var [sizes <array i5>] (array_new <array i5> $3^i5 $0^i5))
      (array_set sizes $0^i5 $5^i5)
      (array_set sizes $1^i5 $1^i5)
      (array_set sizes $2^i5 $4^i5)
      (var [received <array s3>] (sys_fd_readv_s3 right_fd sizes))
      (sys_fd_close right_fd)
      (sys_fd_close left_fd)
      (add
        $570^i5
        (add
          (score (eq sent $10^i5))
          (add
            (score (eq (array_length received) $3^i5))
            (add
              (score (s3_equals (array_get received $0^i5) $readv_chunk0_s3^s3))
              (add
                (score (s3_equals (array_get received $1^i5) $readv_chunk1_s3^s3))
                (score (s3_equals (array_get received $2^i5) $readv_chunk2_s3^s3))
              )
            )
          )
        )
      )
    }
  )
}
