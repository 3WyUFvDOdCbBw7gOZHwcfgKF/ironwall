{program test~std~array@main
  (import std~array)
  (import std~eq)
  (function same_i5 ([left i5] [right i5]) to bool in (eq left right))
  (function main ([args <array s3>]) to i5 in
    {
      (var [rule <Eq i5>] (class_new <Eq i5> same_i5))
      (var [source <Array i5>] (<array_new_fill i5> $4^i5 $0^i5))
      (source.set $0^i5 $5^i5)
      (source.set $1^i5 $7^i5)
      (source.set $2^i5 $7^i5)
      (source.set $3^i5 $9^i5)
      (var [count_seven i5] (source.count rule $7^i5))
      (var [index_nine i5] (source.index rule $9^i5))
      (var [copy <Array i5>] (source.copy))
      (copy.reverse)
      (source.fill $4^i5)
      (var [joined <Array i5>] (<Array_concat i5> source copy))
      (add
        (source.get $0^i5)
        (add
          (copy.get $0^i5)
          (add
            (copy.get $3^i5)
            (add
              (<Array_len i5> joined)
              (add
                count_seven
                (add
                  index_nine
                  (add
                    (if (<Array_contains i5> joined rule $5^i5) then $100^i5 else $0^i5)
                    (joined.get $5^i5)
                  )
                )
              )
            )
          )
        )
      )
    }
  )
}
