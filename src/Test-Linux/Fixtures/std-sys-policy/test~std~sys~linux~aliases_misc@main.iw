{program test~std~sys~linux~aliases_misc@main
  (import std~linux~sys)

  (function score ([value bool]) to i5 in (if value then $1^i5 else $0^i5))
  (function s3_equals ([left s3] [right s3]) to bool in
    {
      (var [left_length i5] (s3_length left))
      (if
        (neq left_length (s3_length right))
        then
        false
        else
        {
          (var [index i5] $0^i5)
          (var [same bool] true)
          (while
            (lt index left_length)
            in
            {
              (if
                same
                then
                (if
                  (neq (s3_get left index) (s3_get right index))
                  then
                  {
                    (var_set same false)
                    unit
                  }
                  else
                  unit
                )
                else
                unit
              )
              (var_set index (add index $1^i5))
            }
          )
          same
        }
      )
    }
  )
  (function non_negative ([value i5]) to bool in
    (not (lt value $0^i5))
  )

  (function main ([args <array s3>]) to i5 in
    {
      (if (sys_path_exists_s3 $std_sys_linux_aliases_file_s3^s3) then (sys_path_unlink_s3 $std_sys_linux_aliases_file_s3^s3) else unit)
      (if (sys_path_exists_s3 $std_sys_linux_aliases_patch_file_s3^s3) then (sys_path_unlink_s3 $std_sys_linux_aliases_patch_file_s3^s3) else unit)
      (if (sys_path_exists_s3 $std_sys_linux_aliases_dir_s3^s3) then (sys_path_rmdir_s3 $std_sys_linux_aliases_dir_s3^s3) else unit)
      (sys_path_mkdir_s3 $std_sys_linux_aliases_dir_s3^s3)

      (var [file_fd i5] (sys_file_create_s3 $std_sys_linux_aliases_file_s3^s3))
      (sys_file_write_s3 file_fd $std_sys_linux_aliases_part_a_s3^s3)
      (sys_file_close file_fd)

      (var [append_fd i5] (sys_file_open_append_s3 $std_sys_linux_aliases_file_s3^s3))
      (sys_file_write_s3 append_fd $std_sys_linux_aliases_part_b_s3^s3)
      (sys_file_flush append_fd)
      (sys_file_close append_fd)

      (var [read_fd i5] (sys_file_open_read_s3 $std_sys_linux_aliases_file_s3^s3))
      (var [contents s3] (sys_file_read_s3 read_fd $16^i5))
      (var [prefix s3] (sys_file_pread_s3 read_fd $2^i5 $0^i5))
      (var [seek_set_offset i5] (sys_file_seek_set read_fd $1^i5))
      (var [tail s3] (sys_file_read_s3 read_fd $16^i5))
      (var [seek_cur_offset i5] (sys_file_seek_cur read_fd $0^i5))
      (sys_file_close read_fd)

      (var [rewrite_fd i5] (sys_file_open_write_s3 $std_sys_linux_aliases_file_s3^s3))
      (sys_file_write_s3 rewrite_fd $std_sys_linux_aliases_rewrite_s3^s3)
      (sys_file_close rewrite_fd)

      (var [verify_fd i5] (sys_file_open_read_s3 $std_sys_linux_aliases_file_s3^s3))
      (var [rewritten s3] (sys_file_read_s3 verify_fd $16^i5))
      (var [seek_end_offset i5] (sys_file_seek_end verify_fd $0^i5))
      (var [file_stat SysFileStat] (sys_file_stat verify_fd))
      (sys_file_close verify_fd)

      (var [patch_fd i5] (sys_file_create_s3 $std_sys_linux_aliases_patch_file_s3^s3))
      (sys_file_write_s3 patch_fd $std_sys_linux_aliases_patch_seed_s3^s3)
      (sys_file_pwrite_s3 patch_fd $std_sys_linux_aliases_patch_value_s3^s3 $1^i5)
      (sys_file_close patch_fd)

      (var [patch_read_fd i5] (sys_file_open_read_s3 $std_sys_linux_aliases_patch_file_s3^s3))
      (var [patched s3] (sys_file_read_s3 patch_read_fd $16^i5))
      (sys_file_close patch_read_fd)

      (var [path_stat SysFileStat] (sys_path_stat_s3 $std_sys_linux_aliases_file_s3^s3))
      (var [dir_stat SysFileStat] (sys_path_stat_s3 $std_sys_linux_aliases_dir_s3^s3))
      (var [pid_before i5] (sys_process_getpid))
      (var [tid_before i5] (sys_thread_gettid))
      (sys_thread_yield)
      (var [pid_after i5] (sys_process_getpid))
      (var [tid_after i5] (sys_thread_gettid))

      (var [socket_fd i5] (sys_net_socket_tcp4))
      (sys_net_setsockopt_reuseaddr socket_fd)
      (sys_net_setsockopt_reuseport socket_fd)
      (sys_net_bind_ipv4_any socket_fd $0^i5)
      (var [port i5] (sys_net_getsockname_ipv4_port socket_fd))
      (sys_fd_close socket_fd)

      (var [total i5]
        (add
          (score (s3_equals contents $std_sys_linux_aliases_contents_s3^s3))
          (add
            (score (s3_equals prefix $std_sys_linux_aliases_prefix_s3^s3))
            (add
              (score (eq seek_set_offset $1^i5))
              (add
                (score (s3_equals tail $std_sys_linux_aliases_tail_s3^s3))
                (add
                  (score (eq seek_cur_offset $4^i5))
                  (add
                    (score (s3_equals rewritten $std_sys_linux_aliases_rewrite_s3^s3))
                    (add
                      (score (eq seek_end_offset $2^i5))
                      (add
                        (score (s3_equals patched $std_sys_linux_aliases_patch_expected_s3^s3))
                        (add
                          (score (eq (sys_stat_size path_stat) $2^i5))
                          (add
                            (score (eq (sys_stat_size file_stat) $2^i5))
                            (add
                              (score (sys_stat_is_regular path_stat))
                              (add
                                (score (sys_stat_is_dir dir_stat))
                                (add
                                  (score (gt (sys_stat_device file_stat) $0^i5))
                                  (add
                                    (score (gt (sys_stat_inode file_stat) $0^i5))
                                    (add
                                      (score (gt (sys_stat_mode file_stat) $0^i5))
                                      (add
                                        (score (gt (sys_stat_link_count file_stat) $0^i5))
                                        (add
                                          (score (non_negative (sys_stat_uid file_stat)))
                                          (add
                                            (score (non_negative (sys_stat_gid file_stat)))
                                            (add
                                              (score (eq (sys_stat_rdevice file_stat) $0^i5))
                                              (add
                                                (score (gt (sys_stat_block_size file_stat) $0^i5))
                                                (add
                                                  (score (non_negative (sys_stat_block_count file_stat)))
                                                  (add
                                                    (score (gt (sys_stat_atime_sec file_stat) $0^i5))
                                                    (add
                                                      (score (gt (sys_stat_mtime_sec file_stat) $0^i5))
                                                      (add
                                                        (score (gt (sys_stat_ctime_sec file_stat) $0^i5))
                                                        (add
                                                          (score (gt pid_before $0^i5))
                                                          (add
                                                            (score (gt tid_before $0^i5))
                                                            (add
                                                              (score (eq pid_before pid_after))
                                                              (add
                                                                (score (eq tid_before tid_after))
                                                                (add
                                                                  (score (eq pid_before tid_before))
                                                                  (add
                                                                    (score (eq (sys_stdin_handle) $0^i5))
                                                                    (add
                                                                      (score (eq (sys_stdout_handle) $1^i5))
                                                                      (add
                                                                        (score (eq (sys_stderr_handle) $2^i5))
                                                                        (add
                                                                          (score (gt (sys_net_msg_dontwait_flag) $0^i5))
                                                                          (add
                                                                            (score (gt (sys_net_msg_more_flag) $0^i5))
                                                                            (add
                                                                              (score (gt (sys_signal_sigint) $0^i5))
                                                                              (add
                                                                                (score (gt (sys_signal_sigterm) $0^i5))
                                                                                (add
                                                                                  (score (neq (sys_signal_sigint) (sys_signal_sigterm)))
                                                                                  (score (gt port $0^i5))
                                                                                )
                                                                              )
                                                                            )
                                                                          )
                                                                        )
                                                                      )
                                                                    )
                                                                  )
                                                                )
                                                              )
                                                            )
                                                          )
                                                        )
                                                      )
                                                    )
                                                  )
                                                )
                                              )
                                            )
                                          )
                                        )
                                      )
                                    )
                                  )
                                )
                              )
                            )
                          )
                        )
                      )
                    )
                  )
                )
              )
            )
          )
        )
      )

      (sys_path_unlink_s3 $std_sys_linux_aliases_patch_file_s3^s3)
      (sys_path_unlink_s3 $std_sys_linux_aliases_file_s3^s3)
      (sys_path_rmdir_s3 $std_sys_linux_aliases_dir_s3^s3)
      total
    }
  )
}