{program test~std~sys~linux~epoll_loopback@main
  (import std~linux~sys)
  (import std~thread)
  (import test~std~sys~lib)

  (function client_worker ([port i5]) to i5 in
    {
      (var [client_fd i5] (sys_net_socket_tcp4))
      (sys_net_connect_ipv4_loopback client_fd port)
      (var [sent i5] (sys_net_send_s3 client_fd $epoll_payload_s3^s3))
      (sys_net_shutdown_write client_fd)
      (sys_fd_close client_fd)
      (score (eq sent (s3_length $epoll_payload_s3^s3)))
    }
  )

  (function main ([args <array s3>]) to i5 in
    {
      (var [server_fd i5] (sys_net_socket_tcp4))
      (sys_net_setsockopt_reuseaddr server_fd)
      (sys_net_bind_ipv4_loopback server_fd $0^i5)
      (var [port i5] (sys_net_getsockname_ipv4_port server_fd))
      (sys_net_listen server_fd $16^i5)
      (var [epoll_fd i5] (sys_epoll_create))
      (sys_epoll_ctl_add epoll_fd server_fd (sys_epoll_in_flag) server_fd)
      (var [client Thread] (spawn (fn ([ignored unit]) to i5 in (client_worker port))))
      (var [server_events <array SysEpollEvent>] (sys_epoll_wait epoll_fd $4^i5 $5000^i5))
      (var [server_ready bool] false)
      (var [server_data_ok bool] false)
      (if
        (gt (array_length server_events) $0^i5)
        then
        {
          (var [server_event SysEpollEvent] (array_get server_events $0^i5))
          (var_set server_ready (sys_epoll_event_has_in server_event))
          (var_set server_data_ok (eq (sys_epoll_event_data server_event) server_fd))
          unit
        }
        else
        unit
      )
      (var [accepted_fd i5] (sys_net_accept server_fd))
      (var [before_flags i5] (sys_fd_fcntl_getfl accepted_fd))
      (sys_fd_fcntl_setfl accepted_fd (bwor before_flags (sys_fd_nonblock_flag)))
      (var [after_flags i5] (sys_fd_fcntl_getfl accepted_fd))
      (sys_epoll_ctl_del epoll_fd server_fd)
      (sys_epoll_ctl_add epoll_fd accepted_fd (sys_epoll_in_flag) $601^i5)
      (sys_epoll_ctl_mod epoll_fd accepted_fd (sys_epoll_in_flag) $602^i5)
      (var [client_events <array SysEpollEvent>] (sys_epoll_wait epoll_fd $4^i5 $5000^i5))
      (var [client_ready bool] false)
      (var [client_data_ok bool] false)
      (if
        (gt (array_length client_events) $0^i5)
        then
        {
          (var [client_event SysEpollEvent] (array_get client_events $0^i5))
          (var_set client_ready (sys_epoll_event_has_in client_event))
          (var_set client_data_ok (eq (sys_epoll_event_data client_event) $602^i5))
          unit
        }
        else
        unit
      )
      (var [received s3] (sys_net_recv_s3 accepted_fd $64^i5))
      (var [client_score i5] (join client))
      (sys_epoll_ctl_del epoll_fd accepted_fd)
      (sys_fd_close accepted_fd)
      (sys_fd_close epoll_fd)
      (sys_fd_close server_fd)
      (add
        (score server_ready)
        (add
          (score server_data_ok)
          (add
            (score (neq (bwand after_flags (sys_fd_nonblock_flag)) $0^i5))
            (add
              (score client_ready)
              (add
                (score client_data_ok)
                (add
                  (score (s3_equals received $epoll_payload_s3^s3))
                  (score (eq client_score $1^i5))
                )
              )
            )
          )
        )
      )
    }
  )
}