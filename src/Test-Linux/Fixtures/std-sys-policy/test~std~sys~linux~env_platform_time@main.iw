{program test~std~sys~linux~env_platform_time@main
  (import std~linux~sys)

  (function score ([value bool]) to i5 in (if value then $1^i5 else $0^i5))
  (function s3_equals ([left s3] [right s3]) to bool in
    {
      (var [left_length i5] (s3_length left))
      (if
        (neq left_length (s3_length right))
        then
        false
        else
        {
          (var [index i5] $0^i5)
          (var [same bool] true)
          (while
            (lt index left_length)
            in
            {
              (if
                same
                then
                (if
                  (neq (s3_get left index) (s3_get right index))
                  then
                  {
                    (var_set same false)
                    unit
                  }
                  else
                  unit
                )
                else
                unit
              )
              (var_set index (add index $1^i5))
            }
          )
          same
        }
      )
    }
  )

  (function main ([args <array s3>]) to i5 in
    {
      (var [t0 i5] (sys_time_monotonic_ms))
      (sys_sleep_ms $5^i5)
      (var [t1 i5] (sys_time_monotonic_ms))
      (sys_env_set_s3 $std_sys_linux_env_set_name_s3^s3 $std_sys_linux_env_set_value_s3^s3)
      (var [total i5]
        (add
          (score (s3_equals (sys_platform_name) $std_sys_linux_platform_name_s3^s3))
          (add
            (score (s3_equals (sys_env_get_s3 $std_sys_linux_env_case_name_s3^s3) $std_sys_linux_env_case_value_s3^s3))
            (add
              (score (s3_equals (sys_env_get_s3 $std_sys_linux_env_set_name_s3^s3) $std_sys_linux_env_set_value_s3^s3))
              (add
                (score (le t0 t1))
                (score (gt (sys_time_unix_ms) $0^i5))
              )
            )
          )
        )
      )
      (sys_env_unset_s3 $std_sys_linux_env_set_name_s3^s3)
      total
    }
  )
}