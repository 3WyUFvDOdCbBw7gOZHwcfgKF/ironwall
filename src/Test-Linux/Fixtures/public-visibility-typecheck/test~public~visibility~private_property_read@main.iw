{program test~public~visibility~private_property_read@main
  (class PrivateCounter
    (property [hidden i5])
    (public (property [shown i5]))
    (constructor ([seed i5]) in
      {
        (cm_set self hidden seed)
        (cm_set self shown seed)
      }
    )
  )
  (function main ([args <array s3>]) to i5 in
    (cm_get (class_new PrivateCounter $7^i5) hidden)
  )
}