{program test~char~support@main
  (function score ([value bool]) to i5 in (if value then $1^i5 else $0^i5))
  (function check_c3 () to i5 in
    (add
      (score (lt $char_a_c3^c3 $char_b_c3^c3))
      (add
        (score (le $char_a_c3^c3 $char_a_c3^c3))
        (add
          (score (ge $char_b_c3^c3 $char_a_c3^c3))
          (add
            (score (gt $char_b_c3^c3 $char_a_c3^c3))
            (add
              (score (eq $char_a_c3^c3 $char_a_c3^c3))
              (add
                (score (neq $char_a_c3^c3 $char_b_c3^c3))
                (add
                  (score (eq (val_to_i5 $char_a_c3^c3) $97^i5))
                  (add
                    (score (eq (val_to_u5 $char_a_c3^c3) $97^u5))
                    (add
                      (score (eq (bin_to_i5 $char_a_c3^c3) $97^i5))
                      (score (eq (bin_to_u5 $char_a_c3^c3) $97^u5))
                    )
                  )
                )
              )
            )
          )
        )
      )
    )
  )
  (function check_c4 () to i5 in
    (add
      (score (lt $char_a_c4^c4 $char_b_c4^c4))
      (add
        (score (le $char_a_c4^c4 $char_a_c4^c4))
        (add
          (score (ge $char_b_c4^c4 $char_a_c4^c4))
          (add
            (score (gt $char_b_c4^c4 $char_a_c4^c4))
            (add
              (score (eq $char_a_c4^c4 $char_a_c4^c4))
              (add
                (score (neq $char_a_c4^c4 $char_b_c4^c4))
                (add
                  (score (eq (val_to_i5 $char_a_c4^c4) $97^i5))
                  (add
                    (score (eq (val_to_u5 $char_a_c4^c4) $97^u5))
                    (add
                      (score (eq (bin_to_i5 $char_a_c4^c4) $97^i5))
                      (score (eq (bin_to_u5 $char_a_c4^c4) $97^u5))
                    )
                  )
                )
              )
            )
          )
        )
      )
    )
  )
  (function check_c5 () to i5 in
    (add
      (score (lt $char_a_c5^c5 $char_b_c5^c5))
      (add
        (score (le $char_a_c5^c5 $char_a_c5^c5))
        (add
          (score (ge $char_b_c5^c5 $char_a_c5^c5))
          (add
            (score (gt $char_b_c5^c5 $char_a_c5^c5))
            (add
              (score (eq $char_a_c5^c5 $char_a_c5^c5))
              (add
                (score (neq $char_a_c5^c5 $char_b_c5^c5))
                (add
                  (score (eq (val_to_i5 $char_a_c5^c5) $97^i5))
                  (add
                    (score (eq (val_to_u5 $char_a_c5^c5) $97^u5))
                    (add
                      (score (eq (bin_to_i5 $char_a_c5^c5) $97^i5))
                      (score (eq (bin_to_u5 $char_a_c5^c5) $97^u5))
                    )
                  )
                )
              )
            )
          )
        )
      )
    )
  )
  (function main ([args <array s3>]) to i5 in
    (add (check_c3) (add (check_c4) (check_c5)))
  )
}
