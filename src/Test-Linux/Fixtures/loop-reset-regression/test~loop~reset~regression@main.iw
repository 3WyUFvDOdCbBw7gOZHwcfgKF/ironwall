{program test~loop~reset~regression@main
  (import std~array)
  (import std~list)

  (function is_even_i5 ([value i5]) to bool in (eq (mod value $2^i5) $0^i5))

  (function main ([args <array s3>]) to i5 in
    {
      (var [base <Array i5>] (<array_new_fill i5> $6^i5 $0^i5))
      (var [index i5] $0^i5)
      (while (lt index (<Array_len i5> base)) in
        {
          (base.set index (add index $1^i5))
          (var_set index (add index $1^i5))
        }
      )
      (var [flags <Array bool>] (<Array_map i5 bool> base false is_even_i5))
      (var [items <List bool>] (<list_new bool> false))
      (var_set index $0^i5)
      (while (lt index (<Array_len bool> flags)) in
        {
          (items.append (flags.get index))
          (var_set index (add index $1^i5))
        }
      )
      (<list_len bool> items)
    }
  )
}