{program test~backend~timing@main
  (function hot_round ([limit i5] [seed i5]) to i5 in
    {
      (var [modulus i5] $1000003^i5)
      (var [acc0 i5] (add seed $11^i5))
      (var [acc1 i5] (add seed $23^i5))
      (var [acc2 i5] (add seed $37^i5))
      (var [acc3 i5] (add seed $47^i5))
      (var [acc4 i5] (add seed $59^i5))
      (var [acc5 i5] (add seed $71^i5))
      (var [acc6 i5] (add seed $89^i5))
      (var [acc7 i5] (add seed $101^i5))
      (var [index i5] $0^i5)
      (while
        (lt index limit)
        in
        {
          (var [step i5] (add index seed))
          (var [mix0 i5] (mod (add (mul (add acc0 acc3) (add step $3^i5)) (add acc6 $101^i5)) modulus))
          (var [mix1 i5] (mod (add (mul (add acc1 acc4) (add step $5^i5)) (add acc7 $211^i5)) modulus))
          (var [mix2 i5] (mod (add (mul (add acc2 acc5) (add step $7^i5)) (add acc0 $307^i5)) modulus))
          (var [mix3 i5] (mod (add (mul (add acc3 acc6) (add step $11^i5)) (add acc1 $401^i5)) modulus))
          (var [mix4 i5] (mod (add (mul (add acc4 acc7) (add step $13^i5)) (add acc2 $503^i5)) modulus))
          (var [mix5 i5] (mod (add (mul (add acc5 acc0) (add step $17^i5)) (add acc3 $601^i5)) modulus))
          (var [mix6 i5] (mod (add (mul (add acc6 acc1) (add step $19^i5)) (add acc4 $701^i5)) modulus))
          (var [mix7 i5] (mod (add (mul (add acc7 acc2) (add step $23^i5)) (add acc5 $809^i5)) modulus))
          (var_set acc0 (mod (add mix0 acc5) modulus))
          (var_set acc1 (mod (add mix1 acc6) modulus))
          (var_set acc2 (mod (add mix2 acc7) modulus))
          (var_set acc3 (mod (add mix3 acc0) modulus))
          (var_set acc4 (mod (add mix4 acc1) modulus))
          (var_set acc5 (mod (add mix5 acc2) modulus))
          (var_set acc6 (mod (add mix6 acc3) modulus))
          (var_set acc7 (mod (add mix7 acc4) modulus))
          (var_set index (add index $1^i5))
        }
      )
      (mod
        (add
          acc0
          (add acc1 (add acc2 (add acc3 (add acc4 (add acc5 (add acc6 acc7))))))
        )
        modulus
      )
    }
  )
  (function main ([args <array s3>]) to i5 in
    (mod
      (add
        (hot_round $180000^i5 $17^i5)
        (add (hot_round $220000^i5 $29^i5) (hot_round $90000^i5 $41^i5))
      )
      $1000003^i5
    )
  )
}
