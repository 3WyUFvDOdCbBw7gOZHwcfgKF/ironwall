{program test~gc~global~print@main
  (import std~gc)
  (var [global_text s3] (s3_new $5^i5 (s3_get $hello_s3^s3 $0^i5)))
  (var [global_rank i5] $11^i5)
  (function main ([args <array s3>]) to i5 in
    {
      (var [local_text s3] global_text)
      (var [reclaimed_count i5] (gc_collect))
      (add reclaimed_count (add (s3_length local_text) global_rank))
    }
  )
}
