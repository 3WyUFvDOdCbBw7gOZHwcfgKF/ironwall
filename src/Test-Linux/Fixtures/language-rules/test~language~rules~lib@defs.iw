{program test~language~rules~lib@defs
  (export (function <generic collapse_union T> ([value <union T bool>]) to <union bool T> in
    value
  ))
  (export (function score_union ([value <union bool i5>]) to i5 in
    (match value ([flag bool] (if flag then $90^i5 else $80^i5)) ([payload i5] payload))
  ))
  (export (function wrap_inner_bool ([flag bool]) to <union bool f5> in flag))
  (export (function wrap_inner_f5 ([value f5]) to <union bool f5> in value))
  (export (function nested_union_score ([value <union i5 <union bool f5>>]) to i5 in
    (match value
      ([payload i5] payload)
      ([inner <union bool f5>]
        (match inner
          ([flag bool] (if flag then $120^i5 else $121^i5))
          ([float_payload f5] $122^i5)
        )
      )
    )
  ))
  (export (function score ([value i5]) to i5 in value))
  (export (function score ([flag bool]) to i5 in (if flag then $40^i5 else $30^i5)))
  (export (class <generic Bucket T>
    (property [value T])
    (constructor ([value0 T]) in (cm_set self value value0))
  ))
  (export (class <generic Bucket Left Right>
    (property [left Left])
    (property [right Right])
    (constructor ([left0 Left] [right0 Right]) in
      {
        (cm_set self left left0)
        (cm_set self right right0)
      }
    )
  ))
  (export (function <generic pack T> ([value T]) to <Bucket T> in (class_new <Bucket T> value)))
  (export (function <generic pack Left Right> ([left Left] [right Right]) to <Bucket Left Right> in
    (class_new <Bucket Left Right> left right)
  ))
  (export (function measure ([box <Bucket i5>]) to i5 in box.value))
  (export (function measure ([box <Bucket i5 bool>]) to i5 in
    (if box.right then (add box.left $50^i5) else (sub box.left $50^i5))
  ))
  (export (class MultiCtor
    (property [value i5])
    (constructor () in (cm_set self value $11^i5))
    (constructor ([initial i5]) in (cm_set self value initial))
    (constructor ([flag bool]) in
      (if flag then (cm_set self value $22^i5) else (cm_set self value $33^i5))
    )
  ))
  (function constructor_seed ([value i5]) to i5 in (add value $1^i5))
  (function constructor_adjust ([value i5]) to i5 in (sub value $1^i5))
  (export (class ConstructorAnalysisOk
    (property [left i5])
    (property [right i5])
    (method read_left () to i5 in (cm_get self left))
    (method read_right () to i5 in (cm_get self right))
    (method read_both () to i5 in (add ((cm_get self read_left)) ((cm_get self read_right))))
    (constructor ([seed i5]) in
      {
        (constructor_adjust seed)
        (cm_set self left (constructor_seed seed))
        ((cm_get self read_left))
        (cm_set self right (constructor_adjust (cm_get self left)))
        ((cm_get self read_both))
      }
    )
  ))
}
