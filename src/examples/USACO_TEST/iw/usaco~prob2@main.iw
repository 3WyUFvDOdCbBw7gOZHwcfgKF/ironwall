        (cm_set self len len0)
        (cm_set self cells cells0)
      }
    )
  )

  (function cell_index ([left_trim i5] [right_trim i5]) to i5 in
    (add (mul left_trim $3^i5) right_trim)
  )

  (function min_i7 ([left i7] [right i7]) to i7 in
    (if (le left right) then left else right)
  )

  (function make_zero_seq () to <array i7> in
    (array_new <array i7> $1^i5 $0^i7)
  )

  (function make_cost_seq ([value i7]) to <array i7> in
    {
      (var [result <array i7>] (array_new <array i7> $2^i5 $0^i7))
      (array_set result $1^i5 value)
      result
    }
  )

  (function make_cells () to <array <array i7>> in
    {
      (var [cells <array <array i7>>] (array_new <array <array i7>> $9^i5 (make_zero_seq)))
      (var [index i5] $0^i5)
      (while (lt index $9^i5) in
        {
          (array_set cells index (make_zero_seq))
          (var_set index (add index $1^i5))
        }
      )
