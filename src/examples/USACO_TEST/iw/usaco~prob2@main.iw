          (array_set change_costs index (val_to_i7 (stdin_read_i5)))
          (var_set index (add index $1^i5))
        }
      )

      (var [moo_count i5] (add (sub n moo_length) $1^i5))
      (var [moo_costs <array i7>] (array_new <array i7> moo_count $0^i7))
      (var_set index $0^i5)
      (while (lt index moo_count) in
        {
          (var [current_cost i7] (cost_if_not_ascii_i7 text change_costs index $77^i5))
          (if (ge moo_length $2^i5)
