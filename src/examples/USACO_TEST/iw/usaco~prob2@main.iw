    }
  )

  (function make_info ([length i5]) to Info in
    (class_new Info length (make_cells))
  )

  (function info_get_seq ([info Info] [left_trim i5] [right_trim i5]) to <array i7> in
    (array_get (cm_get info cells) (cell_index left_trim right_trim))
