              {
                (var_set current_cost (add current_cost (cost_if_not_ascii_i7 text change_costs (add index $1^i5) $79^i5)))
                unit
              }
            else unit
          )
          (if (ge moo_length $3^i5)
            then
              {
                (var_set current_cost (add current_cost (cost_if_not_ascii_i7 text change_costs (add index $2^i5) $79^i5)))
                unit
