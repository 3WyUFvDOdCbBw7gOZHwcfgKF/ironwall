  (function state_advance_one ([state IwParseState]) to unit in
    {
      (if (lt (cm_get state index) (cm_get state length))
        then
          {
            (var [code i5] (state_current_code state))
            (cm_set state index (add (cm_get state index) $1^i5))
            (if (eq code $10^i5)
              then
