                then (parse_class_after_head state acc fallback_seed (cm_get head_atom text) form_start form_line form_column false)
                else
                  (if (atom_is_export head_atom)
                    then (parse_export_after_head state acc fallback_seed)
                    else
                      (if (atom_is_declare head_atom)
                        then (parse_declare_after_head state acc fallback_seed form_start form_line form_column false true)
                        else
                          (skip_group_contents state acc fallback_seed $41^i5)
                      )
                  )
              )
          )
      )
      unit
    }
  )

  (function skip_nested_paren_form ([state IwParseState] [acc IwParseAccumulator] [fallback_seed s3] [nested_start i5] [nested_line i5] [nested_column i5]) to unit in
    {
      (skip_ws state)
      (if (code_is_delimiter (state_current_code state))
        then
          {
            (skip_group_contents state acc fallback_seed $41^i5)
          }
        else
          {
            (var [nested_head IwParseAtom] (parse_atom state fallback_seed))
            (skip_group_contents state acc fallback_seed $41^i5)
            (record_form_from_head acc nested_head nested_start (cm_get state index) nested_line nested_column)
          }
      )
      unit
    }
  )

  (export (function iw_parse_source ([lex_result IwLexResult] [source_path s3] [source s3]) to IwParseResult in
    {
      (var [empty_text s3] (s3_slice_span source_path $0^i5 $0^i5 source_path))
      (var [empty_sample IwParseNodeSample] (class_new IwParseNodeSample empty_text empty_text $0^i5 $0^i5 $0^i5 $0^i5 false))
      (var [state IwParseState] (class_new IwParseState source (s3_length source) $0^i5 $1^i5 $1^i5 false (s3_slice_span source_path $0^i5 $0^i5 source_path)))
      (var [acc IwParseAccumulator]
        (class_new IwParseAccumulator
          empty_text
          empty_text
          empty_text
          empty_text
          $0^i5
          $0^i5
          (array_new <array IwParseNodeSample> $64^i5 empty_sample)
          $0^i5
          $0^i5
          $0^i5
          $0^i5
          $0^i5
          $0^i5
          $0^i5
          (cm_get lex_result return_type_count)
          (cm_get lex_result assignment_count)
          $0^i5
          $0^i5
          $0^i5
          $0^i5
          $0^i5
          $0^i5
          $0^i5
          $0^i5
          $0^i5
          $0^i5
          $0^i5
          $0^i5
          $0^i5
          (array_new <array IwParseNodeSample> $32^i5 empty_sample)
          $0^i5
          (array_new <array IwParseNodeSample> $32^i5 empty_sample)
          $0^i5
          (array_new <array IwParseNodeSample> $64^i5 empty_sample)
        )
      )
      (skip_ws state)
      (if (eq (state_current_code state) $123^i5)
        then (state_advance_one state)
        else (mark_parse_error state)
      )
      (skip_ws state)
      (var [program_atom IwParseAtom] (parse_atom state source_path))
      (var [has_program_header bool] (atom_is_program program_atom))
      (if has_program_header
        then unit
        else (mark_parse_error state)
      )
      (skip_ws state)
      (var [program_unit_atom IwParseAtom] (class_new IwParseAtom empty_text $0^i5 $0^i5 $0^i5 $0^i5))
      (if has_program_header
        then (var_set program_unit_atom (parse_atom state source_path))
        else unit
      )
      (cm_set acc program_unit (cm_get program_unit_atom text))
      (var [done bool] false)
      (while (and (not done) (lt (cm_get state index) (cm_get state length))) in
        {
          (skip_ws state)
          (if (eq (state_current_code state) $125^i5)
            then
              {
                (state_advance_one state)
                (var_set done true)
              }
            else
              (if (eq (state_current_code state) $40^i5)
                then (parse_top_level_form state acc source_path)
                else
                  {
                    (mark_parse_error state)
                    (state_advance_one state)
                  }
              )
          )
        }
      )
      (if (not done)
        then (mark_parse_error state)
        else unit
      )
      {
        (var [top_level_count i5] (add (cm_get acc function_count) (cm_get acc class_count)))
        (var [member_count i5]
          (add
            (cm_get acc property_count)
            (add (cm_get acc constructor_count) (cm_get acc method_count))
          )
        )
        (class_new IwParseResult
          (cm_get acc program_unit)
          (cm_get acc first_import_unit)
          (cm_get acc first_function_name)
          (cm_get acc first_class_name)
          (cm_get acc import_count)
          (cm_get acc import_sample_count)
          (cm_get acc import_samples)
          (cm_get acc function_count)
          (cm_get acc class_count)
          top_level_count
          (cm_get acc export_count)
          (cm_get acc public_count)
          member_count
          (cm_get acc property_count)
          (cm_get acc constructor_count)
          (cm_get acc method_count)
          (cm_get acc return_type_count)
          (cm_get acc assignment_count)
          (cm_get acc first_import_start)
          (cm_get acc first_import_end)
          (cm_get acc first_import_line)
          (cm_get acc first_import_column)
          (cm_get acc first_function_start)
          (cm_get acc first_function_end)
          (cm_get acc first_function_line)
          (cm_get acc first_function_column)
          (cm_get acc first_class_start)
          (cm_get acc first_class_end)
          (cm_get acc first_class_line)
          (cm_get acc first_class_column)
          (cm_get acc declaration_sample_count)
          (cm_get acc declaration_samples)
          (cm_get acc member_sample_count)
          (cm_get acc member_samples)
          (cm_get acc form_sample_count)
          (cm_get acc form_samples)
          (or
            (cm_get state has_errors)
            (or
              (cm_get lex_result has_unbalanced_brackets)
              (eq (s3_length (cm_get acc program_unit)) $0^i5)
            )
          )
          (cm_get state diagnostic_message)
        )
      }
    }
  ))
}
