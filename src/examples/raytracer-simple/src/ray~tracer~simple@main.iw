      (var [light_distance f5] (vec_length direction_to_light))
      (var [shadow_ray Ray] (class_new Ray origin (vec_scale direction_to_light (div $1p0^f5 light_distance))))
      (var [maximum_t f5] (sub light_distance $0p02^f5))
      (var [blocked bool] false)
