  (function sphere_hit_t ([ray Ray] [sphere Sphere] [minimum_t f5] [maximum_t f5]) to f5 in
    {
      (var [offset Vec3] (vec_sub ray.origin sphere.center))
      (var [a f5] (vec_dot ray.direction ray.direction))
      (var [half_b f5] (vec_dot offset ray.direction))
      (var [c f5] (sub (vec_dot offset offset) (mul sphere.radius sphere.radius)))
      (var [discriminant f5] (sub (mul half_b half_b) (mul a c)))
      (if (lt discriminant $0p0^f5)
        then (sub $0p0^f5 $1p0^f5)
        else
          {
            (var [root_delta f5] (sqrt discriminant))
            (var [near_root f5] (div (sub (sub $0p0^f5 half_b) root_delta) a))
            (if (and (gt near_root minimum_t) (lt near_root maximum_t))
              then near_root
              else
                {
                  (var [far_root f5] (div (add (sub $0p0^f5 half_b) root_delta) a))
                  (if (and (gt far_root minimum_t) (lt far_root maximum_t))
                    then far_root
