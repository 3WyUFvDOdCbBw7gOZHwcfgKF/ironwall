      (array_set raw $0^i5 (class_new Sphere (class_new Vec3 (sub $0p0^f5 $0p95^f5) (sub $0p0^f5 $0p2^f5) (sub $0p0^f5 $3p6^f5)) $0p8^f5 (class_new Vec3 $0p92^f5 $0p9^f5 $0p84^f5) $0p25^f5))
      (array_set raw $1^i5 (class_new Sphere (class_new Vec3 $0p85^f5 (sub $0p0^f5 $0p55^f5) (sub $0p0^f5 $2p55^f5)) $0p45^f5 (class_new Vec3 $0p95^f5 $0p72^f5 $0p3^f5) $0p55^f5))
      (array_set raw $2^i5 (class_new Sphere (class_new Vec3 $1p3^f5 $0p28^f5 (sub $0p0^f5 $4p2^f5)) $0p7^f5 (class_new Vec3 $0p35^f5 $0p82^f5 $0p8^f5) $0p15^f5))
      (array_set raw $3^i5 (class_new Sphere (class_new Vec3 (sub $0p0^f5 $0p1^f5) (sub $0p0^f5 $0p78^f5) (sub $0p0^f5 $4p7^f5)) $0p22^f5 (class_new Vec3 $0p98^f5 $0p98^f5 $0p98^f5) $0p8^f5))
