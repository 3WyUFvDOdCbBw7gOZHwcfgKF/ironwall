      (array_set raw $1^i5 (class_new Plane (class_new Vec3 $0p0^f5 $2p45^f5 $0p0^f5) (class_new Vec3 $0p0^f5 (sub $0p0^f5 $1p0^f5) $0p0^f5) (class_new Vec3 $0p74^f5 $0p78^f5 $0p84^f5) $0p02^f5))
