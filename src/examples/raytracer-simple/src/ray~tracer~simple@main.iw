          }
      )
    }
  )

  (function trace_hit ([ray Ray] [spheres <Array Sphere>] [planes <Array Plane>]) to HitState in
    {
      (var [hit HitState] (class_new HitState))
      (var [sphere_index i5] $0^i5)
