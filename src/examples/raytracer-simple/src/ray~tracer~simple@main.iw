      (array_set raw $4^i5 (class_new Plane (class_new Vec3 $0p0^f5 $0p0^f5 (sub $0p0^f5 $6p0^f5)) (class_new Vec3 $0p0^f5 $0p0^f5 $1p0^f5) (class_new Vec3 $0p72^f5 $0p78^f5 $0p74^f5) $0p05^f5))
