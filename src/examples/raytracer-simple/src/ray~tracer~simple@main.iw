            {
              (var [u f5] (div (add (val_to_f5 x_index) $0p5^f5) (val_to_f5 config.width)))
              (var [v f5] (div (sub (sub (val_to_f5 config.height) (val_to_f5 y_index)) $0p5^f5) (val_to_f5 config.height)))
              (var [target Vec3] (vec_add camera.lower_left (vec_add (vec_scale camera.horizontal u) (vec_scale camera.vertical v))))
              (var [ray Ray] (class_new Ray camera.origin (vec_normalize (vec_sub target camera.origin))))
              (sys_fd_write_s3 fd (ppm_line_s3 (trace_ray ray spheres planes)))
              (var_set x_index (add x_index $1^i5))
            }
          )
          (var_set y_index (add y_index $1^i5))
        }
      )
      (sys_fd_close fd)
      unit
    }
  )

  (function main ([args <array s3>]) to i5 in
    {
      (quiet_gc_print)
      (var [config RenderConfig] (parse_config args))
      (render_scene config)
      (gc_collect)
      $0^i5
    }
  )
}
