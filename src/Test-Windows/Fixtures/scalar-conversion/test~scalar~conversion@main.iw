{program test~scalar~conversion@main
  (function score ([value bool]) to i5 in (if value then $1^i5 else $0^i5))
  (function f6_one_bits () to u6 in (ls $1023^u6 $52^u6))

  (function check_val_float_to_int () to i5 in
    (add
      (score (eq (val_to_i5 $3p75^f5) $3^i5))
      (add
        (score (eq (val_to_i5 (sub $0p0^f5 $3p75^f5)) (sub $0^i5 $3^i5)))
        (add
          (score (eq (val_to_i5 (val_to_f6 $4294967297^i6)) $1^i5))
          (add
            (score (eq (val_to_i5 (val_to_f6 (sub $0^i6 $4294967297^i6))) (sub $0^i5 $1^i5)))
            (add
              (score (eq (val_to_u5 (sub $0p0^f5 $1p25^f5)) $4294967295^u5))
              (score (eq (val_to_u5 (val_to_f6 $4294967298^u6)) $2^u5))
            )
          )
        )
      )
    )
  )

  (function check_val_int_to_float () to i5 in
    (add
      (score (eq (val_to_i5 (val_to_f5 $16777217^i5)) $16777216^i5))
      (add
        (score (eq (val_to_i5 (val_to_f5 (sub $0^i5 $16777217^i5))) (sub $0^i5 $16777216^i5)))
        (add
          (score (eq (val_to_u5 (val_to_f5 $16777217^u5)) $16777216^u5))
          (score (eq (val_to_i6 (val_to_f6 (add $9007199254740992^i6 $1^i6))) $9007199254740992^i6))
        )
      )
    )
  )

  (function check_bin_semantics () to i5 in
    (add
      (score (eq (bin_to_u5 $1p0^f5) $1065353216^u5))
      (add
        (score (eq (bin_to_f5 $1065353216^u5) $1p0^f5))
        (add
          (score (eq (bin_to_u6 $1p0^f6) (f6_one_bits)))
          (add
            (score (eq (bin_to_f6 (f6_one_bits)) $1p0^f6))
            (add
              (score (eq (bin_to_u5 (sub $0^i5 $1^i5)) $4294967295^u5))
              (score (eq (bin_to_i5 $4294967295^u5) (sub $0^i5 $1^i5)))
            )
          )
        )
      )
    )
  )

  (function check_bin_narrowing () to i5 in
    (add
      (score (eq (bin_to_i5 $4294967298^i6) $2^i5))
      (add
        (score (eq (bin_to_u5 $4294967298^u6) $2^u5))
        (add
          (score (eq (bin_to_u5 (f6_one_bits)) $0^u5))
          (score (eq (bin_to_i5 $4294967295^i6) (sub $0^i5 $1^i5)))
        )
      )
    )
  )

  (function main ([args <array s3>]) to i5 in
    (add
      (check_val_float_to_int)
      (add
        (check_val_int_to_float)
        (add (check_bin_semantics) (check_bin_narrowing))
      )
    )
  )
}