{program test~astvis~cond~gallery@main
  (function cond_score ([flag bool] [value i5]) to i5 in
    (cond
      ((eq value $0^i5) $10^i5)
      ((eq value $1^i5)
        (cond
          (flag $21^i5)
          (else $22^i5)
        )
      )
      ((eq value $2^i5)
        (let (
          ([next i5] (add value $30^i5))
        ) in
          (cond
            ((eq next $32^i5) next)
            (else (sub next $1^i5))
          )
        )
      )
      (else
        {
          (var [sum i5] $0^i5)
          (if flag then (var_set sum (add sum value)) else (var_set sum (sub sum value)))
          sum
        }
      )
    )
  )
  (function main ([args <array s3>]) to i5 in (cond_score true $2^i5))
}
