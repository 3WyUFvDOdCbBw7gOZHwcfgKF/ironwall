{program test~std~io~stdin~forward@main
  (import std~io)

  (function main ([args <array s3>]) to i5 in
    {
      (var [header_line s3] (stdin_read_nonempty_line_s3))
      (var [left i5] (pair_line_left_i5 header_line))
      (var [right i5] (pair_line_right_i5 header_line))
      (var [separator c3] (pair_line_separator header_line))
      (var [tail i5] (stdin_read_i5))
      (print_i5_with_sep left separator)
      (print_i5_with_sep right separator)
      (print_i5_with_sep tail separator)
      $0^i5
    }
  )
}