{program test~std~string@main
  (import std~string)
  (function score_s3 ([value bool]) to i5 in (if value then $1^i5 else $0^i5))
  (function same_s3 ([left s3] [right s3]) to bool in
    {
      (var [left_len i5] (s3_length left))
      (var [right_len i5] (s3_length right))
      (if
        (neq left_len right_len)
        then
        false
        else
        {
          (var [same bool] true)
          (var [index i5] $0^i5)
          (while
            (and same (lt index left_len))
            in
            {
              (var_set same (eq (s3_get left index) (s3_get right index)))
              (var_set index (add index $1^i5))
            }
          )
          same
        }
      )
    }
  )
  (function main ([args <array s3>]) to i5 in
    {
      (var [hello StringS3] (class_new StringS3 $hello_s3^s3))
      (var [ell StringS3] (class_new StringS3 $ell_s3^s3))
      (var [lo StringS3] (class_new StringS3 $lo_s3^s3))
      (var [he StringS3] (class_new StringS3 $he_s3^s3))
      (var [world StringS3] (class_new StringS3 $world_s3^s3))
      (var [empty StringS3] (class_new StringS3 $empty_s3^s3))
      (var [ll StringS3] (class_new StringS3 $ll_s3^s3))
      (var [hello_world StringS3] (string_concat hello world))
      (var [repeated_lo StringS3] (string_repeat lo $3^i5))
      (var [reversed_world StringS3] (string_reversed world))
      (var [double_reversed_world StringS3] (string_reversed reversed_world))
      (var [repeat_zero StringS3] (string_repeat hello $0^i5))
      (var [empty_world StringS3] (string_concat empty world))
      (var [world_empty StringS3] (string_concat world empty))
      (add
        (score_s3 (eq (string_len hello) $5^i5))
        (add
          (score_s3 (eq (hello.find ell) $1^i5))
          (add
            (score_s3 (eq (hello.find lo) $3^i5))
            (add
              (score_s3 (eq (hello.find world) (sub $0^i5 $1^i5)))
              (add
                (score_s3 (eq (hello.count ll) $1^i5))
                (add
                  (score_s3 (eq (hello.count empty) $6^i5))
                  (add
                    (score_s3 (hello.startswith he))
                    (add
                      (score_s3 (hello.endswith lo))
                      (add
                        (score_s3 (hello.endswith empty))
                        (add
                          (score_s3 (string_contains hello ell))
                          (add
                            (score_s3 (xor (string_contains hello world) true))
                            (add
                              (score_s3 (eq (string_len hello_world) $10^i5))
                              (add
                                (score_s3 (same_s3 hello_world.raw $helloworld_s3^s3))
                                (add
                                  (score_s3 (eq (string_len repeated_lo) $6^i5))
                                  (add
                                    (score_s3 (same_s3 repeated_lo.raw $lololo_s3^s3))
                                    (add
                                      (score_s3
                                        (same_s3 reversed_world.raw $dlrow_s3^s3)
                                      )
                                      (add
                                        (score_s3
                                          (same_s3
                                            double_reversed_world.raw
                                            $world_s3^s3
                                          )
                                        )
                                        (add
                                          (score_s3
                                            (same_s3 repeat_zero.raw $empty_s3^s3)
                                          )
                                          (add
                                            (score_s3
                                              (same_s3 empty_world.raw $world_s3^s3)
                                            )
                                            (score_s3
                                              (same_s3 world_empty.raw $world_s3^s3)
                                            )
                                          )
                                        )
                                      )
                                    )
                                  )
                                )
                              )
                            )
                          )
                        )
                      )
                    )
                  )
                )
              )
            )
          )
        )
      )
    }
  )
}
