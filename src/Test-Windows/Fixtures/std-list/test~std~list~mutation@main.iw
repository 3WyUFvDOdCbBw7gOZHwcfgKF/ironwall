{program test~std~list~mutation@main
  (import std~list)
  (import std~eq)
  (function same_i5 ([left i5] [right i5]) to bool in (eq left right))
  (function main ([args <array s3>]) to i5 in
    {
      (var [rule <Eq i5>] (class_new <Eq i5> same_i5))
      (var [source <List i5>] (<list_new i5> $0^i5))
      (source.append $1^i5)
      (source.append $2^i5)
      (source.insert $0^i5 $9^i5)
      (source.insert (<list_len i5> source) $8^i5)
      (var [head i5] (source.get $0^i5))
      (var [tail i5] (source.get $3^i5))
      (source.set $1^i5 $5^i5)
      (var [popped_head i5] (source.pop $0^i5))
      (var [popped_tail i5] (<list_pop i5> source))
      (source.reverse)
      (var [copy <List i5>] (source.copy))
      (source.append $7^i5)
      (var [copy_mid i5] (copy.get $1^i5))
      (var [len_source i5] (<list_len i5> source))
      (var [len_copy i5] (<list_len i5> copy))
      (var [source_has_seven i5] (if (<list_contains i5> source rule $7^i5) then $100^i5 else $0^i5))
      (var [copy_has_seven i5] (if (<list_contains i5> copy rule $7^i5) then $100^i5 else $0^i5))
      (source.clear)
      (source.append $4^i5)
      (source.reverse)
      (copy.clear)
      (copy.append $6^i5)
      (var [joined <List i5>] (<list_concat i5> source copy))
      (add
        head
        (add
          tail
          (add
            popped_head
            (add
              popped_tail
              (add
                copy_mid
                (add
                  len_source
                  (add
                    len_copy
                    (add
                      source_has_seven
                      (add
                        copy_has_seven
                        (add
                          (source.get $0^i5)
                          (add
                            (copy.get $0^i5)
                            (add (<list_len i5> joined) (joined.get $1^i5))
                          )
                        )
                      )
                    )
                  )
                )
              )
            )
          )
        )
      )
    }
  )
}
