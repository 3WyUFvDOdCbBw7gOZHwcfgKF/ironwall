{program test~module~global~closure~capture~lib@state
  (var [shared_counter i5] $5^i5)
  (function make_reader () to <to i5 from i5> in
    (fn ([delta i5]) to i5 in (add shared_counter delta))
  )
  (function make_writer ([step i5]) to <to i5 from i5> in
    (fn ([delta i5]) to i5 in
      {
        (var_set shared_counter (add shared_counter (add step delta)))
        shared_counter
      }
    )
  )
}