{program test~language~rules~duplicate_constructor@main
  (class DuplicateCtor
    (property [value i5])
    (constructor ([value0 i5]) in (cm_set self value value0))
    (constructor ([value1 i5]) in (cm_set self value (add value1 $1^i5)))
  )
  (function main ([args <array s3>]) to i5 in $0^i5)
}
