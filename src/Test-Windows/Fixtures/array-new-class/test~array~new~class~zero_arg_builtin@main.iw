{program test~array~new~class~zero_arg_builtin@main
  (function score_bool ([ok bool] [points i5]) to i5 in
    (if ok then points else $0^i5)
  )

  (function s3_equals_local ([left s3] [right s3]) to bool in
    {
      (var [left_len i5] (s3_length left))
      (var [same bool] (eq left_len (s3_length right)))
      (var [index i5] $0^i5)
      (while (lt index left_len) in
        {
          (if same
            then
              (if (eq (s3_get left index) (s3_get right index))
                then unit
                else { (var_set same false) unit }
              )
            else unit
          )
          (var_set index (add index $1^i5))
        }
      )
      same
    }
  )

  (function s4_equals_local ([left s4] [right s4]) to bool in
    {
      (var [left_len i5] (s4_length left))
      (var [same bool] (eq left_len (s4_length right)))
      (var [index i5] $0^i5)
      (while (lt index left_len) in
        {
          (if same
            then
              (if (eq (s4_get left index) (s4_get right index))
                then unit
                else { (var_set same false) unit }
              )
            else unit
          )
          (var_set index (add index $1^i5))
        }
      )
      same
    }
  )

  (function s5_equals_local ([left s5] [right s5]) to bool in
    {
      (var [left_len i5] (s5_length left))
      (var [same bool] (eq left_len (s5_length right)))
      (var [index i5] $0^i5)
      (while (lt index left_len) in
        {
          (if same
            then
              (if (eq (s5_get left index) (s5_get right index))
                then unit
                else { (var_set same false) unit }
              )
            else unit
          )
          (var_set index (add index $1^i5))
        }
      )
      same
    }
  )

  (function z5_is_default ([value z5]) to bool in
    (and (eq (z5_real value) $19p0^f5) (eq (z5_img value) $19p0^f5))
  )

  (function z6_is_default ([value z6]) to bool in
    (and (eq (z6_real value) $19p0^f6) (eq (z6_img value) $19p0^f6))
  )

  (function z7_is_default ([value z7]) to bool in
    (and (eq (z7_real value) $19p0^f7) (eq (z7_img value) $19p0^f7))
  )

  (function main ([args <array s3>]) to i5 in
    {
      (var [default_s3 s3] (s3_new))
      (var [default_s4 s4] (s4_new))
      (var [default_s5 s5] (s5_new))
      (var [default_z5 z5] (z5_new))
      (var [default_z6 z6] (z6_new))
      (var [default_z7 z7] (z7_new))
      (var [default_s3_array <array s3>] (array_new <array s3>))
      (var [nested_s3_array <array <array s3>>] (array_new <array <array s3>>))
      (var [default_z5_array <array z5>] (array_new <array z5>))
      (var [default_z6_array <array z6>] (array_new <array z6>))
      (var [default_z7_array <array z7>] (array_new <array z7>))
      (array_set (array_get nested_s3_array $0^i5) $0^i5 $changed_s3^s3)
      (add
        (score_bool (s3_equals_local default_s3 $expected_default_s3^s3) $1^i5)
        (add
          (score_bool (s4_equals_local default_s4 $expected_default_s4^s4) $2^i5)
          (add
            (score_bool (s5_equals_local default_s5 $expected_default_s5^s5) $4^i5)
            (add
              (score_bool (z5_is_default default_z5) $8^i5)
              (add
                (score_bool (z6_is_default default_z6) $16^i5)
                (add
                  (score_bool (z7_is_default default_z7) $32^i5)
                  (add
                    (score_bool (eq (array_length default_s3_array) $5^i5) $64^i5)
                    (add
                      (score_bool (s3_equals_local (array_get default_s3_array $0^i5) $expected_default_s3^s3) $128^i5)
                      (add
                        (score_bool (s3_equals_local (array_get default_s3_array $4^i5) $expected_default_s3^s3) $256^i5)
                        (add
                          (score_bool (eq (array_length nested_s3_array) $5^i5) $512^i5)
                          (add
                            (score_bool (eq (array_length (array_get nested_s3_array $0^i5)) $5^i5) $1024^i5)
                            (add
                              (score_bool (s3_equals_local (array_get (array_get nested_s3_array $0^i5) $0^i5) $changed_s3^s3) $2048^i5)
                              (add
                                (score_bool (s3_equals_local (array_get (array_get nested_s3_array $1^i5) $0^i5) $expected_default_s3^s3) $4096^i5)
                                (add
                                  (score_bool (s3_equals_local (array_get (array_get nested_s3_array $0^i5) $1^i5) $expected_default_s3^s3) $8192^i5)
                                  (add
                                    (score_bool (eq (array_length default_z5_array) $5^i5) $16384^i5)
                                    (add
                                      (score_bool (z5_is_default (array_get default_z5_array $0^i5)) $32768^i5)
                                      (add
                                        (score_bool (z6_is_default (array_get default_z6_array $1^i5)) $65536^i5)
                                        (score_bool (z7_is_default (array_get default_z7_array $4^i5)) $131072^i5)
                                      )
                                    )
                                  )
                                )
                              )
                            )
                          )
                        )
                      )
                    )
                  )
                )
              )
            )
          )
        )
      )
    }
  )
}