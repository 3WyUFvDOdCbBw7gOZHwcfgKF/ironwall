{program test~std~dict~abort_popitem@main
  (import std~dict)
  (import std~eq)
  (import std~hash)
  (function same_i5 ([left i5] [right i5]) to bool in (eq left right))
  (function bad_hash ([value i5]) to i5 in $1^i5)
  (function main ([args <array s3>]) to i5 in
    {
      (var [key_eq <Eq i5>] (class_new <Eq i5> same_i5))
      (var [hash_rule <Hash i5>] (class_new <Hash i5> bad_hash))
      (var [source <Dict i5 i5>] (<dict_new i5 i5> hash_rule key_eq $0^i5 $0^i5))
      (source.popitem)
      $0^i5
    }
  )
}
