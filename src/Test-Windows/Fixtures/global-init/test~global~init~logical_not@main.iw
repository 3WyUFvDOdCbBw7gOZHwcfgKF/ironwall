{program test~global~init~logical_not@main
  (var [global_true bool] (not false))
  (var [global_false bool] (not (not false)))
  (var [global_roundtrip bool] (not (not true)))
  (function score ([value bool]) to i5 in (if value then $1^i5 else $0^i5))
  (function main ([args <array s3>]) to i5 in
    (add
      (score global_true)
      (add
        (score (not global_false))
        (add
          (score global_roundtrip)
          (score (not (and global_true global_false)))
        )
      )
    )
  )
}