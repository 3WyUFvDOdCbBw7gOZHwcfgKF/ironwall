{program test~seq~var~scope~let~mutual_abort@main
  (function main ([args <array s3>]) to i5 in
    (let (
      ([evenish <to i5 from i5>] (fn ([value i5]) to i5 in
        (if
          (eq value $0^i5)
          then
          $100^i5
          else
          (oddish (sub value $1^i5))
        )
      ))
      ([oddish <to i5 from i5>] (fn ([value i5]) to i5 in
        (if
          (eq value $0^i5)
          then
          $7^i5
          else
          (evenish (sub value $1^i5))
        )
      ))
    ) in
      (add (evenish $4^i5) (oddish $5^i5))
    )
  )
}