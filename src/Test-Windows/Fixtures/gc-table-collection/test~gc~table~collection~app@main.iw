{program test~gc~table~collection~app@main
  (import test~gc~table~collection~lib)
  (import std~gc)
  (var [main_text s3] (s3_new $4^i5 (s3_get $hello_s3^s3 $0^i5)))
  (var [main_rank i5] $7^i5)
  (class MainBox
    (property [left LibBox])
    (property [name s3])
    (constructor ([left0 LibBox] [name0 s3]) in
      {
        (cm_set self left left0)
        (cm_set self name name0)
      }
    )
  )
  (function main ([args <array s3>]) to i5 in
    {
      (var [lib_box LibBox] (make_lib_box))
      (var [main_box MainBox] (class_new MainBox lib_box main_text))
      (var [reclaimed_count i5] (gc_collect))
      (add
        reclaimed_count
        (add
          (lib_score)
          (add main_rank (add (s3_length main_box.left.name) (s3_length main_box.name)))
        )
      )
    }
  )
}
