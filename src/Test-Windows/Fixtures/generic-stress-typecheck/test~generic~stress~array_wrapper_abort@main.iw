{program test~generic~stress~array_wrapper_abort@main
  (class ParamBox
    (property [value i5])
    (constructor ([value0 i5]) in (cm_set self value value0))
  )
  (function <generic make_wrapped_array T> ([seed T]) to <array T> in
    (array_new <array T> $3^i5 seed)
  )
  (function main ([args <array s3>]) to i5 in
    {
      (var [seed ParamBox] (class_new ParamBox $12^i5))
      (var [raw <array ParamBox>] (<make_wrapped_array ParamBox> seed))
      (array_length raw)
    }
  )
}
