{program test~std~array~class@main
  (import std~array)
  (class Marker (property [value i5]) (constructor () in (cm_set self value $5^i5)))
  (class Payload
    (property [flag i5])
    (property [marker Marker])
    (constructor () in
      {
        (cm_set self flag $7^i5)
        (cm_set self marker (class_new Marker))
      }
    )
  )
  (function main ([args <array s3>]) to i5 in
    {
      (var [seed Payload] (class_new Payload))
      (cm_set seed flag $31^i5)
      (cm_set seed.marker value $11^i5)
      (var [source <Array Payload>] (<array_new_fill Payload> $4^i5 seed))
      (var [first Payload] (source.get $0^i5))
      (var [last Payload] (source.get $3^i5))
      (cm_set first flag $67^i5)
      (cm_set first.marker value $41^i5)
      (var [copy <Array Payload>] (source.copy))
      (var [copy_first Payload] (copy.get $0^i5))
      (cm_set copy_first.marker value $53^i5)
      (var [joined <Array Payload>] (<Array_concat Payload> source copy))
      (var [source_third Payload] (source.get $2^i5))
      (var [joined_last Payload] (joined.get $7^i5))
      (add
        last.flag
        (add
          (mul seed.flag $100^i5)
          (add
            (mul source_third.marker.value $10000^i5)
            (mul joined_last.marker.value $1000000^i5)
          )
        )
      )
    }
  )
}
