{program test~std~sys~seek@main
  (import std~windows~sys)
  (import test~std~sys~lib)
  (function main ([args <array s3>]) to i5 in
    {
      (var [fd i5] (sys_fd_open_read_s3 $seek_path_s3^s3))
      (var [pos1 i5] (sys_fd_seek_set fd $5^i5))
      (var [chunk1 s3] (sys_fd_read_s3 fd $2^i5))
      (var [pos2 i5] (sys_fd_seek_cur fd (sub $0^i5 $1^i5)))
      (var [chunk2 s3] (sys_fd_read_s3 fd $2^i5))
      (var [pos3 i5] (sys_fd_seek_end fd (sub $0^i5 $2^i5)))
      (var [chunk3 s3] (sys_fd_read_s3 fd $2^i5))
      (sys_fd_close fd)
      (add
        $300^i5
        (add
          (score (eq pos1 $5^i5))
          (add
            (score (s3_equals chunk1 $seek_chunk1_s3^s3))
            (add
              (score (eq pos2 $6^i5))
              (add
                (score (s3_equals chunk2 $seek_chunk2_s3^s3))
                (add
                  (score (eq pos3 $8^i5))
                  (score (s3_equals chunk3 $seek_chunk3_s3^s3))
                )
              )
            )
          )
        )
      )
    }
  )
}
