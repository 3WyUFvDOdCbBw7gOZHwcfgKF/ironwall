{program test~std~sys~fork@main
  (import std~windows~sys)
  (import test~std~sys~lib)
  (function main ([args <array s3>]) to i5 in
    {
      (var [pid i5] (sys_process_fork))
      (if
        (eq pid $0^i5)
        then
        {
          (sys_process_exit $7^i5)
          $0^i5
        }
        else
        {
          (var [status i5] (sys_process_wait4 pid))
          (add
            $170^i5
            (add (score (gt pid $0^i5)) (score (eq status (exit_status_word $7^i5))))
          )
        }
      )
    }
  )
}
