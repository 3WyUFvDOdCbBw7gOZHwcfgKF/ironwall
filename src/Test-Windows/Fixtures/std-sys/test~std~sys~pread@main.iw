{program test~std~sys~pread@main
  (import std~windows~sys)
  (import test~std~sys~lib)
  (function main ([args <array s3>]) to i5 in
    {
      (var [fd i5] (sys_fd_open_read_s3 $sys_pread_path_s3^s3))
      (var [chunk s3] (sys_fd_pread_s3 fd $3^i5 $4^i5))
      (var [pos i5] (sys_fd_seek_cur fd $0^i5))
      (var [prefix s3] (sys_fd_read_s3 fd $2^i5))
      (sys_fd_close fd)
      (add
        $360^i5
        (add
          (score (s3_equals chunk $sys_pread_slice_s3^s3))
          (add
            (score (eq pos $0^i5))
            (score (s3_equals prefix $sys_pread_leading_s3^s3))
          )
        )
      )
    }
  )
}
