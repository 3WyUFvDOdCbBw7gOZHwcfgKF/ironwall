{program test~std~sys~fsync@main
  (import std~windows~sys)
  (import test~std~sys~lib)
  (function main ([args <array s3>]) to i5 in
    {
      (var [fd i5] (sys_fd_open_write_s3 $fsync_path_s3^s3))
      (var [written i5] (sys_fd_write_s3 fd $fsync_payload_s3^s3))
      (sys_fd_fsync fd)
      (sys_fd_close fd)
      (add
        $260^i5
        (add
          (score (gt fd $2^i5))
          (score (eq written (s3_length $fsync_payload_s3^s3)))
        )
      )
    }
  )
}
