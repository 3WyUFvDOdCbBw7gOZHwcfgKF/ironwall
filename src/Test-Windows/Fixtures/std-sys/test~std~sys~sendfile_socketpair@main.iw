{program test~std~sys~sendfile_socketpair@main
  (import std~windows~sys)
  (import test~std~sys~lib)
  (function main ([args <array s3>]) to i5 in
    {
      (var [source_fd i5] (sys_fd_open_read_s3 $sendfile_path_s3^s3))
      (var [pair_fds <array i5>] (sys_net_socketpair_stream))
      (var [read_fd i5] (pipe_read_fd pair_fds))
      (var [write_fd i5] (pipe_write_fd pair_fds))
      (var [sent i5] (sys_fd_sendfile write_fd source_fd $64^i5))
      (var [received s3] (sys_net_recv_s3 read_fd $64^i5))
      (var [offset_after_sendfile i5] (sys_fd_seek_cur source_fd $0^i5))
      (sys_fd_close write_fd)
      (sys_fd_close read_fd)
      (sys_fd_close source_fd)
      (add
        $560^i5
        (add
          (score (eq sent (s3_length $sendfile_text_s3^s3)))
          (add
            (score (s3_equals received $sendfile_text_s3^s3))
            (score (eq offset_after_sendfile (s3_length $sendfile_text_s3^s3)))
          )
        )
      )
    }
  )
}
