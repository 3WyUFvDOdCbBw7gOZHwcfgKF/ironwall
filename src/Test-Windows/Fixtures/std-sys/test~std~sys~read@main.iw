{program test~std~sys~read@main
  (import std~windows~sys)
  (import test~std~sys~lib)
  (function main ([args <array s3>]) to i5 in
    {
      (var [fd i5] (sys_fd_open_read_s3 $sys_input_path_s3^s3))
      (var [received s3] (sys_fd_read_s3 fd $32^i5))
      (sys_fd_close fd)
      (add $130^i5 (score (s3_equals received $alpha_beta_s3^s3)))
    }
  )
}
