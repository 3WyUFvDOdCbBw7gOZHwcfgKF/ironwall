{program test~std~sys~execve@main
  (import std~windows~sys)
  (import test~std~sys~lib)
  (function main ([args <array s3>]) to i5 in
    {
      (var [pipe_fds <array i5>] (sys_fd_pipe2))
      (var [read_fd i5] (pipe_read_fd pipe_fds))
      (var [write_fd i5] (pipe_write_fd pipe_fds))
      (var [pid i5] (sys_process_fork))
      (if
        (eq pid $0^i5)
        then
        {
          (var [stdout_fd i5] (sys_fd_dup2 write_fd $1^i5))
          (sys_fd_close read_fd)
          (sys_fd_close write_fd)
          (var [argv <array s3>] (s3_array2 $echo_argv0_s3^s3 $echo_arg_s3^s3))
          (var [envp <array s3>] (array_new <array s3> $0^i5 $echo_arg_s3^s3))
          (if (eq stdout_fd $1^i5) then unit else (iw_match_unreachable))
          (sys_process_execve_s3 $bin_echo_path_s3^s3 argv envp)
          $0^i5
        }
        else
        {
          (sys_fd_close write_fd)
          (var [received s3] (sys_fd_read_s3 read_fd $8^i5))
          (sys_fd_close read_fd)
          (var [status i5] (sys_process_wait4 pid))
          (add
            $190^i5
            (add
              (score (s3_equals received $echo_output_s3^s3))
              (score (eq status (exit_status_word $0^i5)))
            )
          )
        }
      )
    }
  )
}
