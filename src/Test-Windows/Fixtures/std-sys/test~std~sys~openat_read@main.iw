{program test~std~sys~openat_read@main
  (import std~windows~sys)
  (import test~std~sys~lib)
  (function main ([args <array s3>]) to i5 in
    {
      (var [dir_fd i5] (sys_fd_open_read_s3 $sys_dir_path_s3^s3))
      (var [fd i5] (sys_fd_openat_read_s3 dir_fd $openat_input_child_s3^s3))
      (var [received s3] (sys_fd_read_s3 fd $32^i5))
      (sys_fd_close fd)
      (sys_fd_close dir_fd)
      (add
        $200^i5
        (add
          (score (gt fd $2^i5))
          (score (s3_equals received $openat_input_text_s3^s3))
        )
      )
    }
  )
}
