{program test~std~sys~pipe2@main
  (import std~windows~sys)
  (import test~std~sys~lib)
  (function main ([args <array s3>]) to i5 in
    {
      (var [pipe_fds <array i5>] (sys_fd_pipe2))
      (var [read_fd i5] (pipe_read_fd pipe_fds))
      (var [write_fd i5] (pipe_write_fd pipe_fds))
      (var [written i5] (sys_fd_write_s3 write_fd $pipe_payload_s3^s3))
      (sys_fd_close write_fd)
      (var [received s3] (sys_fd_read_s3 read_fd $16^i5))
      (sys_fd_close read_fd)
      (add
        $150^i5
        (add
          (score (eq written (s3_length $pipe_payload_s3^s3)))
          (score (s3_equals received $pipe_payload_s3^s3))
        )
      )
    }
  )
}
