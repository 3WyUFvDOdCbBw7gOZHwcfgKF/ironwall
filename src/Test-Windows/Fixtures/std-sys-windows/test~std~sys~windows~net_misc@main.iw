{program test~std~sys~windows~net_misc@main
  (import std~windows~sys)

  (function score ([value bool]) to i5 in (if value then $1^i5 else $0^i5))
  (function s3_equals ([left s3] [right s3]) to bool in
    {
      (var [left_length i5] (s3_length left))
      (if
        (neq left_length (s3_length right))
        then
        false
        else
        {
          (var [index i5] $0^i5)
          (var [same bool] true)
          (while
            (lt index left_length)
            in
            {
              (if
                same
                then
                (if
                  (neq (s3_get left index) (s3_get right index))
                  then
                  {
                    (var_set same false)
                    unit
                  }
                  else
                  unit
                )
                else
                unit
              )
              (var_set index (add index $1^i5))
            }
          )
          same
        }
      )
    }
  )

  (function main ([args <array s3>]) to i5 in
    {
      (sys_net_startup)
      (var [server_fd i5] (sys_net_tcp4_socket))
      (var [client_fd i5] (sys_net_tcp4_socket))
      (sys_net_set_reuseaddr server_fd)
      (sys_net_bind_ipv4_any server_fd $0^i5)
      (var [port i5] (sys_net_getsockname_ipv4_port server_fd))
      (sys_net_listen server_fd $16^i5)
      (sys_net_set_tcp_nodelay client_fd)
      (sys_net_connect_ipv4_loopback client_fd port)
      (var [accepted_fd i5] (sys_net_accept server_fd))
      (var [sent i5] (sys_net_send_s3 client_fd $std_sys_windows_net_misc_payload_s3^s3))
      (var [received s3] (sys_net_recv_s3 accepted_fd $64^i5))
      (sys_net_shutdown_read accepted_fd)
      (sys_net_shutdown_read_write client_fd)
      (sys_net_close accepted_fd)
      (sys_net_close client_fd)
      (sys_net_close server_fd)
      (sys_net_cleanup)
      (add
        (score (gt port $0^i5))
        (add
          (score (gt accepted_fd $0^i5))
          (add
            (score (eq sent (s3_length $std_sys_windows_net_misc_payload_s3^s3)))
            (add
              (score (s3_equals received $std_sys_windows_net_misc_payload_s3^s3))
              (add $1^i5 $1^i5)
            )
          )
        )
      )
    }
  )
}