{program test~std~sys~windows~dir_iterate@main
  (import std~windows~sys)

  (function score ([value bool]) to i5 in (if value then $1^i5 else $0^i5))
  (function s3_equals ([left s3] [right s3]) to bool in
    {
      (var [left_length i5] (s3_length left))
      (if
        (neq left_length (s3_length right))
        then
        false
        else
        {
          (var [index i5] $0^i5)
          (var [same bool] true)
          (while
            (lt index left_length)
            in
            {
              (if
                same
                then
                (if
                  (neq (s3_get left index) (s3_get right index))
                  then
                  {
                    (var_set same false)
                    unit
                  }
                  else
                  unit
                )
                else
                unit
              )
              (var_set index (add index $1^i5))
            }
          )
          same
        }
      )
    }
  )

  (function main ([args <array s3>]) to i5 in
    {
      (if (sys_path_exists_s3 $std_sys_windows_dir_iterate_root_s3^s3) then (sys_path_rmdir_s3 $std_sys_windows_dir_iterate_root_s3^s3) else unit)
      (sys_path_mkdir_s3 $std_sys_windows_dir_iterate_root_s3^s3)
      (sys_path_mkdir_s3 $std_sys_windows_dir_iterate_subdir_s3^s3)
      (var [fd_a i5] (sys_file_create_s3 $std_sys_windows_dir_iterate_file_a_s3^s3))
      (sys_file_write_s3 fd_a $std_sys_windows_dir_iterate_value_a_s3^s3)
      (sys_file_close fd_a)
      (var [fd_b i5] (sys_file_create_s3 $std_sys_windows_dir_iterate_file_b_s3^s3))
      (sys_file_write_s3 fd_b $std_sys_windows_dir_iterate_value_b_s3^s3)
      (sys_file_close fd_b)
      (var [dir_handle i5] (sys_dir_open_s3 $std_sys_windows_dir_iterate_root_s3^s3))
      (var [saw_empty bool] false)
      (var [entry_count i5] $0^i5)
      (var [total_name_length i5] $0^i5)
      (while
        (not saw_empty)
        in
        {
          (var [entry s3] (sys_dir_read_s3 dir_handle))
          (if
            (eq (s3_length entry) $0^i5)
            then
            {
              (var_set saw_empty true)
              unit
            }
            else
            {
              (var_set entry_count (add entry_count $1^i5))
              (var_set total_name_length (add total_name_length (s3_length entry)))
            }
          )
        }
      )
      (sys_dir_close dir_handle)
      (sys_path_unlink_s3 $std_sys_windows_dir_iterate_file_a_s3^s3)
      (sys_path_unlink_s3 $std_sys_windows_dir_iterate_file_b_s3^s3)
      (sys_path_rmdir_s3 $std_sys_windows_dir_iterate_subdir_s3^s3)
      (sys_path_rmdir_s3 $std_sys_windows_dir_iterate_root_s3^s3)
      (add
        (score saw_empty)
        (add
          (score (eq entry_count $3^i5))
          (score (eq total_name_length $23^i5))
        )
      )
    }
  )
}