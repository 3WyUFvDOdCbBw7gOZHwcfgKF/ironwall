{program test~std~sys~windows~invalid_handle_kind@main
  (import std~windows~sys)

  (function main ([args <array s3>]) to i5 in
    {
      (if (sys_path_exists_s3 $std_sys_windows_invalid_handle_kind_root_s3^s3) then (sys_path_rmdir_s3 $std_sys_windows_invalid_handle_kind_root_s3^s3) else unit)
      (sys_path_mkdir_s3 $std_sys_windows_invalid_handle_kind_root_s3^s3)
      (var [dir_handle i5] (sys_dir_open_s3 $std_sys_windows_invalid_handle_kind_root_s3^s3))
      (sys_wait_one dir_handle $0^i5)
      (sys_dir_close dir_handle)
      (sys_path_rmdir_s3 $std_sys_windows_invalid_handle_kind_root_s3^s3)
      $0^i5
    }
  )
}