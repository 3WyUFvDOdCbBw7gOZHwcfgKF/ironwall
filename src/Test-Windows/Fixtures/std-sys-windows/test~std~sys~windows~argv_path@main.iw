{program test~std~sys~windows~argv_path@main
  (import std~windows~sys)

  (function score ([value bool]) to i5 in (if value then $1^i5 else $0^i5))
  (function s3_equals ([left s3] [right s3]) to bool in
    {
      (var [left_length i5] (s3_length left))
      (if
        (neq left_length (s3_length right))
        then
        false
        else
        {
          (var [index i5] $0^i5)
          (var [same bool] true)
          (while
            (lt index left_length)
            in
            {
              (if
                same
                then
                (if
                  (neq (s3_get left index) (s3_get right index))
                  then
                  {
                    (var_set same false)
                    unit
                  }
                  else
                  unit
                )
                else
                unit
              )
              (var_set index (add index $1^i5))
            }
          )
          same
        }
      )
    }
  )

  (function main ([args <array s3>]) to i5 in
    {
      (if (sys_path_exists_s3 $std_sys_windows_argv_path_file_s3^s3) then (sys_path_unlink_s3 $std_sys_windows_argv_path_file_s3^s3) else unit)
      (if (sys_path_exists_s3 $std_sys_windows_argv_path_dir_s3^s3) then (sys_path_rmdir_s3 $std_sys_windows_argv_path_dir_s3^s3) else unit)
      (sys_path_mkdir_s3 $std_sys_windows_argv_path_dir_s3^s3)
      (var [file_fd i5] (sys_fd_creat_s3 $std_sys_windows_argv_path_file_s3^s3))
      (sys_fd_write_s3 file_fd $std_sys_windows_argv_path_payload_s3^s3)
      (sys_fd_close file_fd)
      (var [total i5]
        (add
          (score (eq (sys_process_argc) $4^i5))
          (add
            (score (s3_equals (sys_process_argv_s3 $1^i5) $std_sys_windows_argv_arg1_s3^s3))
            (add
              (score (s3_equals (sys_process_argv_s3 $2^i5) $std_sys_windows_argv_arg2_s3^s3))
              (add
                (score (s3_equals (sys_process_argv_s3 $3^i5) $std_sys_windows_argv_arg3_s3^s3))
                (add
                  (score (sys_path_exists_s3 $std_sys_windows_argv_path_file_s3^s3))
                  (add
                    (score (sys_path_exists_s3 $std_sys_windows_argv_path_dir_s3^s3))
                    (add
                      (score (sys_path_is_file_s3 $std_sys_windows_argv_path_file_s3^s3))
                      (add
                        (score (not (sys_path_is_dir_s3 $std_sys_windows_argv_path_file_s3^s3)))
                        (add
                          (score (sys_path_is_dir_s3 $std_sys_windows_argv_path_dir_s3^s3))
                          (add
                            (score (not (sys_path_is_file_s3 $std_sys_windows_argv_path_dir_s3^s3)))
                            (score (not (sys_path_exists_s3 $std_sys_windows_argv_path_missing_s3^s3)))
                          )
                        )
                      )
                    )
                  )
                )
              )
            )
          )
        )
      )
      (sys_path_unlink_s3 $std_sys_windows_argv_path_file_s3^s3)
      (sys_path_rmdir_s3 $std_sys_windows_argv_path_dir_s3^s3)
      total
    }
  )
}