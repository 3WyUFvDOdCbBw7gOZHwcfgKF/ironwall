{program test~std~dict@main
  (import std~dict)
  (import std~eq)
  (import std~hash)
  (import std~list)
  (import std~pair)
  (function same_i5 ([left i5] [right i5]) to bool in (eq left right))
  (function bad_hash ([value i5]) to i5 in $1^i5)
  (function main ([args <array s3>]) to i5 in
    {
      (var [key_eq <Eq i5>] (class_new <Eq i5> same_i5))
      (var [value_eq <Eq i5>] (class_new <Eq i5> same_i5))
      (var [hash_rule <Hash i5>] (class_new <Hash i5> bad_hash))
      (var [left <Dict i5 i5>] (<dict_new i5 i5> hash_rule key_eq $0^i5 $0^i5))
      (var [missing_before i5] (left.get $9^i5 $44^i5))
      (var [first_one i5] (left.setdefault $1^i5 $10^i5))
      (var [second_one i5] (left.setdefault $1^i5 $99^i5))
      (left.setdefault $2^i5 $20^i5)
      (left.setdefault $3^i5 $30^i5)
      (var [other <Dict i5 i5>] (<dict_new i5 i5> hash_rule key_eq $0^i5 $0^i5))
      (other.setdefault $2^i5 $200^i5)
      (other.setdefault $4^i5 $40^i5)
      (var [copy <Dict i5 i5>] (left.copy))
      (copy.update other)
      (var [popped_two i5] (copy.pop $2^i5))
      (var [setdefault_five i5] (copy.setdefault $5^i5 $50^i5))
      (var [popitem_pair <Pair i5 i5>] (copy.popitem))
      (var [keys <List i5>] (copy.keys))
      (var [values <List i5>] (copy.values))
      (var [items <List <Pair i5 i5>>] (copy.items))
      (var [merged <Dict i5 i5>] (<dict_merge i5 i5> left other))
      (var [merged_copy <Dict i5 i5>] (merged.copy))
      (var [equals_before bool] (<dict_equals i5 i5> merged merged_copy value_eq))
      (merged_copy.pop $4^i5)
      (var [equals_after bool] (<dict_equals i5 i5> merged merged_copy value_eq))
      (other.clear)
      (add
        missing_before
        (add
          first_one
          (add
            second_one
            (add
              popped_two
              (add
                setdefault_five
                (add
                  (<dict_len i5 i5> left)
                  (add
                    (<dict_len i5 i5> copy)
                    (add
                      (<dict_len i5 i5> merged)
                      (add
                        (<dict_len i5 i5> other)
                        (add
                          (keys.get $0^i5)
                          (add
                            (keys.get $2^i5)
                            (add
                              (values.get $1^i5)
                              (add
                                (cm_get (items.get $2^i5) second)
                                (add
                                  popitem_pair.first
                                  (add
                                    popitem_pair.second
                                    (add
                                      (if
                                        (<dict_contains i5 i5> copy $1^i5)
                                        then
                                        $100^i5
                                        else
                                        $0^i5
                                      )
                                      (add
                                        (if
                                          (<dict_contains i5 i5> copy $5^i5)
                                          then
                                          $0^i5
                                          else
                                          $10^i5
                                        )
                                        (add
                                          (if equals_before then $20^i5 else $0^i5)
                                          (add
                                            (if equals_after then $0^i5 else $30^i5)
                                            (add
                                              (merged.get $2^i5 $0^i5)
                                              (<list_len <Pair i5 i5>> items)
                                            )
                                          )
                                        )
                                      )
                                    )
                                  )
                                )
                              )
                            )
                          )
                        )
                      )
                    )
                  )
                )
              )
            )
          )
        )
      )
    }
  )
}
