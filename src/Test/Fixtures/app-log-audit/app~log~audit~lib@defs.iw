{program app~log~audit~lib@defs
  (import std~windows~sys)

  (export (function same_s3 ([left s3] [right s3]) to bool in
    {
      (var [left_length i5] (s3_length left))
      (if (neq left_length (s3_length right))
        then false
        else
          {
            (var [index i5] $0^i5)
            (var [same bool] true)
            (while (lt index left_length) in
              {
                (if same
                  then
                    (if (neq (s3_get left index) (s3_get right index))
                      then
                        {
                          (var_set same false)
                          unit
                        }
                      else unit
                    )
                  else unit
                )
                (var_set index (add index $1^i5))
              }
            )
            same
          }
      )
    }
  ))

  (function hash_s3 ([value s3]) to i5 in
    {
      (var [index i5] $0^i5)
      (var [length i5] (s3_length value))
      (var [acc i5] $146959810^i5)
      (while (lt index length) in
        {
          (var_set acc (add (mul acc $131^i5) (val_to_i5 (s3_get value index))))
          (var_set index (add index $1^i5))
        }
      )
      acc
    }
  )

  (function pipe_read_fd ([pipe_fds <array i5>]) to i5 in
    (array_get pipe_fds $0^i5)
  )

  (function pipe_write_fd ([pipe_fds <array i5>]) to i5 in
    (array_get pipe_fds $1^i5)
  )

  (function s3_array2 ([first s3] [second s3]) to <array s3> in
    {
      (var [result <array s3>] (array_new <array s3> $2^i5 first))
      (array_set result $1^i5 second)
      result
    }
  )

  (function next_line_end ([source s3] [start i5]) to i5 in
    {
      (var [index i5] start)
      (var [length i5] (s3_length source))
      (while (and (lt index length) (neq (s3_get source index) (s3_get $newline_s3^s3 $0^i5))) in
        {
          (var_set index (add index $1^i5))
        }
      )
      index
    }
  )

  (function s3_slice ([source s3] [start i5] [end_exclusive i5]) to s3 in
    {
      (var [length i5] (sub end_exclusive start))
      (var [result s3] (s3_new length (s3_get $space_s3^s3 $0^i5)))
      (var [index i5] $0^i5)
      (while (lt index length) in
        {
          (s3_set result index (s3_get source (add start index)))
          (var_set index (add index $1^i5))
        }
      )
      result
    }
  )

  (function digit_char ([value i5]) to c3 in
    (if (eq value $0^i5)
      then (s3_get $digit0_s3^s3 $0^i5)
      else
        (if (eq value $1^i5)
          then (s3_get $digit1_s3^s3 $0^i5)
          else
            (if (eq value $2^i5)
              then (s3_get $digit2_s3^s3 $0^i5)
              else
                (if (eq value $3^i5)
                  then (s3_get $digit3_s3^s3 $0^i5)
                  else
                    (if (eq value $4^i5)
                      then (s3_get $digit4_s3^s3 $0^i5)
                      else
                        (if (eq value $5^i5)
                          then (s3_get $digit5_s3^s3 $0^i5)
                          else
                            (if (eq value $6^i5)
                              then (s3_get $digit6_s3^s3 $0^i5)
                              else
                                (if (eq value $7^i5)
                                  then (s3_get $digit7_s3^s3 $0^i5)
                                  else
                                    (if (eq value $8^i5)
                                      then (s3_get $digit8_s3^s3 $0^i5)
                                      else (s3_get $digit9_s3^s3 $0^i5)
                                    )
                                )
                            )
                        )
                    )
                )
            )
        )
    )
  )

  (function count_decimal_digits_nonnegative ([value i5]) to i5 in
    (if (lt value $10^i5)
      then $1^i5
      else (add $1^i5 (count_decimal_digits_nonnegative (div value $10^i5)))
    )
  )

  (function fill_decimal_digits ([result s3] [slot i5] [value i5]) to s3 in
    {
      (if (lt value $10^i5)
        then
          {
            (s3_set result slot (digit_char value))
          }
        else
          {
            (var [prefix_value i5] (div value $10^i5))
            (fill_decimal_digits result (sub slot $1^i5) prefix_value)
            (s3_set result slot (digit_char (mod value $10^i5)))
          }
      )
      result
    }
  )

  (export (function i5_to_s3 ([value i5]) to s3 in
    (if (lt value $0^i5)
      then
        {
          (var [abs_value i5] (sub $0^i5 value))
          (var [digits i5] (count_decimal_digits_nonnegative abs_value))
          (var [result s3] (s3_new (add digits $1^i5) (s3_get $digit0_s3^s3 $0^i5)))
          (s3_set result $0^i5 (s3_get $minus_s3^s3 $0^i5))
          (fill_decimal_digits result digits abs_value)
        }
      else
        {
          (var [digits i5] (count_decimal_digits_nonnegative value))
          (var [result s3] (s3_new digits (s3_get $digit0_s3^s3 $0^i5)))
          (fill_decimal_digits result (sub digits $1^i5) value)
        }
    )
  ))

  (export (function write_line ([fd i5] [value s3]) to unit in
    {
      (sys_fd_write_s3 fd value)
      (sys_fd_write_s3 fd $newline_s3^s3)
      unit
    }
  ))

  (export (function write_blank_line ([fd i5]) to unit in
    {
      (sys_fd_write_s3 fd $newline_s3^s3)
      unit
    }
  ))

  (export (function write_label_i5_line ([fd i5] [label s3] [value i5]) to unit in
    {
      (sys_fd_write_s3 fd label)
      (sys_fd_write_s3 fd (i5_to_s3 value))
      (sys_fd_write_s3 fd $newline_s3^s3)
      unit
    }
  ))

  (export (function write_label_bool_line ([fd i5] [label s3] [value bool]) to unit in
    {
      (sys_fd_write_s3 fd label)
      (if value
        then (sys_fd_write_s3 fd $yes_s3^s3)
        else (sys_fd_write_s3 fd $no_s3^s3)
      )
      (sys_fd_write_s3 fd $newline_s3^s3)
      unit
    }
  ))
}
