{program test‾seq‾var‾scope‾let‾self_abort@main
  (function main ([args <array s3>]) to i5 in
    (let (
      ([countdown <to i5 from i5>] (fn ([value i5]) to i5 in
        (if
          (eq value $0^i5)
          then
          $11^i5
          else
          (add $1^i5 (countdown (sub value $1^i5)))
