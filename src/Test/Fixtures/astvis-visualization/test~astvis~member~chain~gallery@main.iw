{program test~astvis~member~chain~gallery@main
  (function deep_cm_get_chain ([args <array s3>]) to i5 in
    (cm_get (cm_get (cm_get (cm_get source left) right) leaf) value)
  )
  (function cm_set_nested_member_lvalue ([args <array s3>]) to i5 in
    (cm_set (cm_get (cm_get record user) profile) name (array_get names index))
  )
  (function cm_set_nested_member_value ([args <array s3>]) to i5 in
    (cm_set table row (cm_get (cm_get payload left) right))
  )
  (function mixed_member_updates ([args <array s3>]) to i5 in
    {
      (cm_set (cm_get state users) active (cm_get (cm_get input user) active))
      (cm_set (cm_get (cm_get state users) selected) score (add (cm_get stats base) (cm_get stats bonus)))
      (cm_get (cm_get (cm_get state users) selected) score)
    }
  )
  (function main ([args <array s3>]) to i5 in (mixed_member_updates args))
}
