{program test~std~hof~stress@main
  (import std~array)
  (import std~list)
  (import std~set)
  (import std~dict)
  (import std~eq)
  (import std~hash)

  (function same_i5 ([left i5] [right i5]) to bool in (eq left right))
  (function id_hash ([value i5]) to i5 in value)
  (function double_i5 ([value i5]) to i5 in (mul value $2^i5))
  (function keep_multiple_of_three_i5 ([value i5]) to bool in
    (eq (mod value $3^i5) $0^i5)
  )
  (function add_i5 ([acc i5] [value i5]) to i5 in (add acc value))
  (function add_one_i5 ([value i5]) to i5 in (add value $1^i5))
  (function keep_gt_sixty_i5 ([value i5]) to bool in (gt value $60^i5))
  (function add_five_i5 ([value i5]) to i5 in (add value $5^i5))
  (function keep_multiple_of_twelve_i5 ([value i5]) to bool in
    (eq (mod value $12^i5) $0^i5)
  )
  (function dict_add_key_to_value ([key i5] [value i5]) to i5 in (add key value))
  (function dict_value_multiple_of_three ([key i5] [value i5]) to bool in
    (eq (mod value $3^i5) $0^i5)
  )
  (function dict_add_value ([acc i5] [value i5]) to i5 in (add acc value))
  (function main ([args <array s3>]) to i5 in
    {
      (var [base <Array i5>] (<array_new_fill i5> $64^i5 $0^i5))
      (var [fill_index i5] $0^i5)
      (while (lt fill_index (<Array_len i5> base)) in
        {
          (base.set fill_index (add fill_index $1^i5))
          (var_set fill_index (add fill_index $1^i5))
        }
      )

      (var [array_doubled <Array i5>] (<Array_map i5 i5> base $0^i5 double_i5))
      (var [array_kept <Array i5>] (<Array_filter i5> array_doubled keep_multiple_of_three_i5))
      (var [array_sum i5] (<Array_fold i5 i5> array_kept $0^i5 add_i5))

      (var [list_source <List i5>] (<list_new i5> $0^i5))
      (var [list_index i5] $0^i5)
      (while (lt list_index (<Array_len i5> array_kept)) in
        {
          (list_source.append (array_kept.get list_index))
          (var_set list_index (add list_index $1^i5))
        }
      )
      (var [list_shifted <List i5>] (<list_map i5 i5> list_source $0^i5 add_one_i5))
      (var [list_kept <List i5>] (<list_filter i5> list_shifted keep_gt_sixty_i5))
      (var [list_sum i5] (<list_fold i5 i5> list_kept $0^i5 add_i5))

      (var [eq_i5_rule <Eq i5>] (class_new <Eq i5> same_i5))
      (var [hash_i5_rule <Hash i5>] (class_new <Hash i5> id_hash))

      (var [set_source <Set i5>] (<set_new i5> hash_i5_rule eq_i5_rule))
      (var [set_index i5] $0^i5)
      (while (lt set_index (<list_len i5> list_kept)) in
        {
          (set_source.add (list_kept.get set_index))
          (var_set set_index (add set_index $1^i5))
        }
      )
      (var [set_mapped <Set i5>] (<set_map i5 i5> set_source hash_i5_rule eq_i5_rule add_five_i5))
      (var [set_kept <Set i5>] (<set_filter i5> set_mapped keep_multiple_of_twelve_i5))
      (var [set_sum i5] (<set_fold i5 i5> set_kept $0^i5 add_i5))

      (var [dict_source <Dict i5 i5>] (<dict_new i5 i5> hash_i5_rule eq_i5_rule $0^i5 $0^i5))
      (var [dict_index i5] $0^i5)
      (while (lt dict_index (<list_len i5> list_kept)) in
        {
          (dict_source.setdefault dict_index (list_kept.get dict_index))
          (var_set dict_index (add dict_index $1^i5))
        }
      )
      (var [dict_mapped <Dict i5 i5>] (<dict_map_values i5 i5 i5> dict_source $0^i5 dict_add_key_to_value))
      (var [dict_kept <Dict i5 i5>] (<dict_filter i5 i5> dict_mapped dict_value_multiple_of_three))
      (var [dict_sum i5] (<dict_fold i5 i5 i5> dict_kept $0^i5 dict_add_value))

      (add
        array_sum
        (add
          list_sum
          (add
            set_sum
            (add
              dict_sum
              (add
                (<Array_len i5> array_kept)
                (add
                  (<list_len i5> list_kept)
                  (add
                    (<set_len i5> set_kept)
                    (add
                      (<dict_len i5 i5> dict_kept)
                      (add
                        (if (eq (array_kept.get $0^i5) $6^i5) then $100^i5 else $0^i5)
                        (add
                          (if (eq (array_kept.get $20^i5) $126^i5) then $110^i5 else $0^i5)
                          (add
                            (if (eq (list_kept.get $0^i5) $61^i5) then $120^i5 else $0^i5)
                            (add
                              (if (<set_contains i5> set_kept $108^i5) then $130^i5 else $0^i5)
                              (add
                                (if (<dict_contains i5 i5> dict_kept $8^i5) then $140^i5 else $0^i5)
                                (if (<dict_contains i5 i5> dict_kept $7^i5) then $0^i5 else $150^i5)
                              )
                            )
                          )
                        )
                      )
                    )
                  )
                )
              )
            )
          )
        )
      )
    }
  )
}