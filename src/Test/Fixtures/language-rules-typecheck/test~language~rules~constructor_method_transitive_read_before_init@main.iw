{program test~language~rules~constructor_method_transitive_read_before_init@main
  (class MethodTransitiveReadBeforeInit
    (property [left i5])
    (property [right i5])
    (method read_right () to i5 in (cm_get self right))
    (method read_via () to i5 in ((cm_get self read_right)))
    (constructor () in
      {
        (cm_set self left $1^i5)
        ((cm_get self read_via))
        (cm_set self right $2^i5)
      }
    )
  )
  (function main ([args <array s3>]) to i5 in $0^i5)
}
