{program test~std~memory~string~concat~baseline@main
  (import std~string)

  (function main ([args <array s3>]) to i5 in
    {
      (var [chunk_seed StringS3] (class_new StringS3 $ab_s3^s3))
      (var [chunk StringS3] (string_repeat chunk_seed $2048^i5))
      (var [result StringS3] (class_new StringS3 $empty_s3^s3))
      (var [index i5] $0^i5)
      (while (lt index $512^i5) in
        {
          (var_set result (string_concat result chunk))
          (var_set index (add index $1^i5))
        }
      )
      (mod
        (add
          (string_len result)
          (result.count chunk)
        )
        $251^i5
      )
    }
  )
}