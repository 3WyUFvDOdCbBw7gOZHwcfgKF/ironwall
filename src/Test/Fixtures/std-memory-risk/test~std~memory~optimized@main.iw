{program test~std~memory~optimized@main
  (import std~dict)
  (import std~set)
  (import std~list)
  (import std~pair)
  (import std~eq)
  (import std~hash)

  (function same_i5 ([left i5] [right i5]) to bool in (eq left right))
  (function id_hash ([value i5]) to i5 in value)
  (function add_i5 ([acc i5] [value i5]) to i5 in (add acc value))
  (function dict_add_one_to_value ([key i5] [value i5]) to i5 in (add value $1^i5))
  (function add_one_i5 ([value i5]) to i5 in (add value $1^i5))
  (function keep_even_key ([key i5] [value i5]) to bool in (eq (mod key $2^i5) $0^i5))
  (function keep_multiple_of_three_i5 ([value i5]) to bool in (eq (mod value $3^i5) $0^i5))

  (function main ([args <array s3>]) to i5 in
    {
      (var [eq_rule <Eq i5>] (class_new <Eq i5> same_i5))
      (var [hash_rule <Hash i5>] (class_new <Hash i5> id_hash))
      (var [dict_source <Dict i5 i5>] (<dict_new i5 i5> hash_rule eq_rule $0^i5 $0^i5))
      (var [set_source <Set i5>] (<set_new i5> hash_rule eq_rule))
      (var [list_source <List i5>] (<list_new i5> $0^i5))
      (var [index i5] $0^i5)
      (while (lt index $12000^i5) in
        {
          (dict_source.setdefault index index)
          (set_source.add index)
          (if (lt index $192^i5)
            then
              {
                (list_source.append index)
                unit
              }
            else unit
          )
          (var_set index (add index $1^i5))
        }
      )

      (var [dict_mapped <Dict i5 i5>] (<dict_map_values i5 i5 i5> dict_source $0^i5 dict_add_one_to_value))
      (var [dict_kept <Dict i5 i5>] (<dict_filter i5 i5> dict_mapped keep_even_key))
      (var [dict_sum i5] (<dict_fold i5 i5 i5> dict_kept $0^i5 add_i5))
      (var [dict_keys <List i5>] (dict_kept.keys))
      (var [dict_values <List i5>] (dict_kept.values))
      (var [dict_items <List <Pair i5 i5>>] (dict_kept.items))

      (var [set_mapped <Set i5>] (<set_map i5 i5> set_source hash_rule eq_rule add_one_i5))
      (var [set_kept <Set i5>] (<set_filter i5> set_mapped keep_multiple_of_three_i5))
      (var [set_sum i5] (<set_fold i5 i5> set_kept $0^i5 add_i5))

      (var [repeated <List i5>] (<list_repeat i5> list_source $64^i5))

      (mod
        (add
          dict_sum
          (add
            set_sum
            (add
              (<list_len i5> repeated)
              (add
                (<dict_len i5 i5> dict_kept)
                (add
                  (<set_len i5> set_kept)
                  (add
                    (dict_keys.get $0^i5)
                    (add
                      (dict_values.get $10^i5)
                      (add
                        (cm_get (dict_items.get $5^i5) second)
                        (repeated.get $100^i5)
                      )
                    )
                  )
                )
              )
            )
          )
        )
        $251^i5
      )
    }
  )
}