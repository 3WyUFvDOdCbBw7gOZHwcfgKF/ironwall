{program test~gc~validate@main
  (import std~gc)
  (class Marker
    (public (property [label s3]))
    (constructor ([label0 s3]) in (cm_set self label label0))
  )
  (class Payload
    (property [marker Marker])
    (public (property [name s3]))
    (constructor ([marker0 Marker] [name0 s3]) in
      {
        (cm_set self marker marker0)
        (cm_set self name name0)
      }
    )
  )
  (function main ([args <array s3>]) to i5 in
    {
      (var [dynamic_text s3] (s3_new $5^i5 (s3_get $hello_s3^s3 $0^i5)))
      (var [marker Marker] (class_new Marker dynamic_text))
      (var [payload Payload] (class_new Payload marker dynamic_text))
      (var [items <array s3>] (array_new <array s3> $2^i5 dynamic_text))
      (var [reclaimed_count i5] (gc_collect))
      (add
        reclaimed_count
        (add
          (s3_length dynamic_text)
          (add
            (s3_length marker.label)
            (add (s3_length payload.name) (array_length items))
          )
        )
      )
    }
  )
}
