{program test~generic~stress~flow@main
  (class <generic MaybeBox T>
    (public (property [payload <union unit T>]))
    (constructor ([payload0 <union unit T>]) in (cm_set self payload payload0))
  )
  (function <generic choose_or_abort T> ([flag bool] [value T] [fallback T]) to T in
    {
      (var [picked T] (if flag then value else fallback))
      picked
    }
  )
  (function <generic unwrap_or T> ([box <MaybeBox T>] [fallback T]) to T in
    (match box.payload ([empty unit] fallback) ([value T] value))
  )
  (function <generic unwrap_present T> ([box <MaybeBox T>]) to T in
    (match box.payload ([empty unit] (iw_match_unreachable)) ([value T] value))
  )
  (function main ([args <array s3>]) to i5 in
    {
      (var [present <MaybeBox i5>] (class_new <MaybeBox i5> $17^i5))
      (var [missing <MaybeBox i5>] (class_new <MaybeBox i5> unit))
      (add
        (<choose_or_abort i5> false $99^i5 $20^i5)
        (add (<unwrap_or i5> missing $5^i5) (<unwrap_present i5> present))
      )
    }
  )
}
