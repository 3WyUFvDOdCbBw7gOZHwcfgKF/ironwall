{program test~precompiled~app@main
  (import test~precompiled~lib)
  (function main ([args <array s3>]) to i5 in
    {
      (var [single <Box i5>] (<make_box i5> $5^i5))
      (var [double <Box <Box i5>>] (<make_box <Box i5>> single))
      (var [triple <Box <Box <Box i5>>>] (prime_triple_i5 $5^i5))
      (add
        seed_value
        (add single.value (add double.value.value (add triple.value.value.value $0^i5)))
      )
    }
  )
}
