{program test~array~new~class@main
  (class Marker (public (property [value i5])) (constructor () in (cm_set self value $17^i5)))
  (class DefaultBox
    (public (property [value i5]))
    (public (property [marker Marker]))
    (constructor () in
      {
        (cm_set self value $17^i5)
        (cm_set self marker (class_new Marker))
      }
    )
  )
  (function main ([args <array s3>]) to i5 in
    {
      (var [seed DefaultBox] (class_new DefaultBox))
      (cm_set seed value $99^i5)
      (cm_set seed.marker value $88^i5)
      (var [raw <array DefaultBox>] (array_new <array DefaultBox> $6^i5 seed))
      (var [left_value i5] (cm_get (array_get raw $0^i5) value))
      (var [right_value i5] (cm_get (array_get raw $5^i5) value))
      (var [seed_value i5] seed.value)
      (cm_set (cm_get (array_get raw $0^i5) marker) value $41^i5)
      (var [other_marker i5] (cm_get (cm_get (array_get raw $5^i5) marker) value))
      (add
        left_value
        (add
          (mul right_value $100^i5)
          (add (mul seed_value $10000^i5) (mul other_marker $1000000^i5))
        )
      )
    }
  )
}
