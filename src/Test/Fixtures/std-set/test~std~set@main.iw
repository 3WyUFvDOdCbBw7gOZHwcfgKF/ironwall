{program test~std~set@main
  (import std~set)
  (import std~eq)
  (import std~hash)
  (function same_i5 ([left i5] [right i5]) to bool in (eq left right))
  (function bad_hash ([value i5]) to i5 in $1^i5)
  (function main ([args <array s3>]) to i5 in
    {
      (var [eq_rule <Eq i5>] (class_new <Eq i5> same_i5))
      (var [hash_rule <Hash i5>] (class_new <Hash i5> bad_hash))
      (var [full <Set i5>] (<set_new i5> hash_rule eq_rule))
      (full.add $5^i5)
      (full.add $7^i5)
      (full.add $9^i5)
      (full.add $7^i5)
      (var [subset <Set i5>] (<set_new i5> hash_rule eq_rule))
      (subset.add $5^i5)
      (subset.add $9^i5)
      (var [other <Set i5>] (<set_new i5> hash_rule eq_rule))
      (other.add $11^i5)
      (other.add $13^i5)
      (var [copy <Set i5>] (full.copy))
      (copy.discard $99^i5)
      (copy.remove $7^i5)
      (copy.add $15^i5)
      (var [disjoint_ok bool] (full.isdisjoint other))
      (var [mixed <Set i5>] (<set_new i5> hash_rule eq_rule))
      (mixed.add $7^i5)
      (mixed.add $9^i5)
      (mixed.add $11^i5)
      (var [union_set <Set i5>] (full.union mixed))
      (var [intersection_set <Set i5>] (full.intersection mixed))
      (var [difference_set <Set i5>] (full.difference mixed))
      (var [symdiff_set <Set i5>] (full.symmetric_difference mixed))
      (var [union_fn_set <Set i5>] (<set_union i5> full other))
      (var [intersection_fn_set <Set i5>] (<set_intersection i5> full mixed))
      (var [difference_fn_set <Set i5>] (<set_difference i5> mixed subset))
      (var [symdiff_fn_set <Set i5>] (<set_symmetric_difference i5> subset other))
      (var [update_target <Set i5>] (subset.copy))
      (update_target.update mixed)
      (var [intersection_target <Set i5>] (full.copy))
      (intersection_target.intersection_update mixed)
      (var [difference_target <Set i5>] (full.copy))
      (difference_target.difference_update mixed)
      (var [symdiff_target <Set i5>] (full.copy))
      (symdiff_target.symmetric_difference_update mixed)
      (var [popped i5] (copy.pop))
      (var [popped_valid i5] (if (eq popped $5^i5) then $5^i5 else (if (eq popped $9^i5) then $5^i5 else (if (eq popped $15^i5) then $5^i5 else $0^i5))))
      (other.clear)
      (add
        (add
          (<set_len i5> full)
          (add
            (<set_len i5> union_set)
            (add
              (<set_len i5> intersection_set)
              (add
                (<set_len i5> difference_set)
                (add
                  (<set_len i5> symdiff_set)
                  (add
                    (<set_len i5> union_fn_set)
                    (add
                      (<set_len i5> intersection_fn_set)
                      (add
                        (<set_len i5> difference_fn_set)
                        (add
                          (<set_len i5> symdiff_fn_set)
                          (add
                            (<set_len i5> update_target)
                            (add
                              (<set_len i5> intersection_target)
                              (add
                                (<set_len i5> difference_target)
                                (<set_len i5> symdiff_target)
                              )
                            )
                          )
                        )
                      )
                    )
                  )
                )
              )
            )
          )
        )
        (add
          popped_valid
          (add
            (<set_len i5> copy)
            (add
              (<set_len i5> subset)
              (add
                (<set_len i5> other)
                (add
                  (if (<set_contains i5> full $7^i5) then $100^i5 else $0^i5)
                  (add
                    (if (<set_contains i5> full $4^i5) then $0^i5 else $10^i5)
                    (add
                      (if (subset.issubset full) then $20^i5 else $0^i5)
                      (add
                        (if (full.issuperset subset) then $30^i5 else $0^i5)
                        (add
                          (if disjoint_ok then $40^i5 else $0^i5)
                          (add
                            (if (<set_contains i5> copy $7^i5) then $0^i5 else $60^i5)
                            (add
                              (if
                                (<set_contains i5> copy popped)
                                then
                                $0^i5
                                else
                                $10^i5
                              )
                              (add
                                (if
                                  (<set_contains i5> copy $9^i5)
                                  then
                                  $5^i5
                                  else
                                  $0^i5
                                )
                                (add
                                  (if
                                    (<set_contains i5> union_set $11^i5)
                                    then
                                    $100^i5
                                    else
                                    $0^i5
                                  )
                                  (add
                                    (if
                                      (<set_contains i5> intersection_set $7^i5)
                                      then
                                      $10^i5
                                      else
                                      $0^i5
                                    )
                                    (add
                                      (if
                                        (<set_contains i5> difference_set $5^i5)
                                        then
                                        $20^i5
                                        else
                                        $0^i5
                                      )
                                      (add
                                        (if
                                          (<set_contains i5> symdiff_set $11^i5)
                                          then
                                          $30^i5
                                          else
                                          $0^i5
                                        )
                                        (add
                                          (if
                                            (<set_contains i5> update_target $11^i5)
                                            then
                                            $40^i5
                                            else
                                            $0^i5
                                          )
                                          (add
                                            (if
                                              (<set_contains i5>
                                                intersection_target
                                                $5^i5
                                              )
                                              then
                                              $0^i5
                                              else
                                              $50^i5
                                            )
                                            (add
                                              (if
                                                (<set_contains i5>
                                                  difference_target
                                                  $7^i5
                                                )
                                                then
                                                $0^i5
                                                else
                                                $60^i5
                                              )
                                              (if
                                                (<set_contains i5> symdiff_target $9^i5)
                                                then
                                                $0^i5
                                                else
                                                $70^i5
                                              )
                                            )
                                          )
                                        )
                                      )
                                    )
                                  )
                                )
                              )
                            )
                          )
                        )
                      )
                    )
                  )
                )
              )
            )
          )
        )
      )
    }
  )
}
