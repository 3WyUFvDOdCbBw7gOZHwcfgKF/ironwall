      (if (run_formula_case $32^i5 $fft_0032_ok^s3 $fft_0032_fail^s3) then unit else (var_set all_ok false))
      (if (run_formula_case $64^i5 $fft_0064_ok^s3 $fft_0064_fail^s3) then unit else (var_set all_ok false))
      (if (run_formula_case_f6 $64^i5 $fft_f6_0064_ok^s3 $fft_f6_0064_fail^s3) then unit else (var_set all_ok false))
      (if (run_formula_case_f7 $65^i5 $fft_f7_0065_ok^s3 $fft_f7_0065_fail^s3) then unit else (var_set all_ok false))
      (if all_ok then $0^i5 else $1^i5)
    }
  )
}
