      (var [total i5] $0^i5)
      (var_set total (add total (score (eq (add $7p5^f5 $2p0^f5) $9p5^f5))))
      (var_set total (add total (score (eq (sub $7p5^f5 $2p0^f5) $5p5^f5))))
      (var_set total (add total (score (eq (mul $3p0^f5 $2p0^f5) $6p0^f5))))
