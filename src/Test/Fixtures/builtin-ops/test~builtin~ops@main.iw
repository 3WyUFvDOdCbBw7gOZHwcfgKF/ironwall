      (var_set total (add total (score (le $2^u6 $2^u6))))
      (var_set total (add total (score (lt $2^u6 $3^u6))))
      (var_set total (add total (score (ge $3^u6 $3^u6))))
      (var_set total (add total (score (gt $3^u6 $2^u6))))
