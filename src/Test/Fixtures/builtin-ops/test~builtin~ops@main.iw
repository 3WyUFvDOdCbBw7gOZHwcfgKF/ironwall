{program test~builtin~ops@main
  (function score ([value bool]) to i5 in (if value then $1^i5 else $0^i5))
  (function numeric_i5 () to i5 in
    {
      (var [total i5] $0^i5)
      (var_set total (add total (score (eq (add $7^i5 $2^i5) $9^i5))))
      (var_set total (add total (score (eq (sub $7^i5 $2^i5) $5^i5))))
      (var_set total (add total (score (eq (mul $3^i5 $2^i5) $6^i5))))
      (var_set total (add total (score (eq (div $8^i5 $2^i5) $4^i5))))
      (var_set total (add total (score (eq (mod $7^i5 $2^i5) $1^i5))))
      (var_set total (add total (score (le $2^i5 $2^i5))))
      (var_set total (add total (score (lt $2^i5 $3^i5))))
      (var_set total (add total (score (ge $3^i5 $3^i5))))
      (var_set total (add total (score (gt $3^i5 $2^i5))))
      (var_set total (add total (score (eq $3^i5 $3^i5))))
      (var_set total (add total (score (neq $3^i5 $2^i5))))
      total
    }
  )
  (function numeric_i6 () to i5 in
