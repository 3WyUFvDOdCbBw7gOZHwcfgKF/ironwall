  (function numeric_f7 () to i5 in
    {
      (var [total i5] $0^i5)
      (var_set total (add total (score (eq (add $7p5^f7 $2p0^f7) $9p5^f7))))
      (var_set total (add total (score (eq (sub $7p5^f7 $2p0^f7) $5p5^f7))))
      (var_set total (add total (score (eq (mul $3p0^f7 $2p0^f7) $6p0^f7))))
      (var_set total (add total (score (eq (div $7p5^f7 $2p5^f7) $3p0^f7))))
      (var_set total (add total (score (eq (mod $7p5^f7 $2p0^f7) $1p5^f7))))
      (var_set total (add total (score (le $2p0^f7 $2p0^f7))))
      (var_set total (add total (score (lt $2p0^f7 $3p0^f7))))
      (var_set total (add total (score (ge $3p0^f7 $3p0^f7))))
      (var_set total (add total (score (gt $3p0^f7 $2p0^f7))))
      (var_set total (add total (score (eq $3p0^f7 $3p0^f7))))
      (var_set total (add total (score (neq $3p0^f7 $2p0^f7))))
      total
    }
  )
  (function bitwise_i5 () to i5 in
    (add
      (score (eq (bwand $6^i5 $3^i5) $2^i5))
      (add
        (score (eq (bwor $6^i5 $3^i5) $7^i5))
        (add
          (score (eq (bwxor $6^i5 $3^i5) $5^i5))
          (add
            (score (eq (ls $3^i5 $2^i5) $12^i5))
            (score (eq (rs $12^i5 $2^i5) $3^i5))
          )
        )
      )
    )
  )
  (function bitwise_i6 () to i5 in
    (add
      (score (eq (bwand $6^i6 $3^i6) $2^i6))
      (add
        (score (eq (bwor $6^i6 $3^i6) $7^i6))
        (add
