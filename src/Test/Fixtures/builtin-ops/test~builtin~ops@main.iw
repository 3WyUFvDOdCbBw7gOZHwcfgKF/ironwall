            (score (eq (rs $12^u7 $2^u7) $3^u7))
          )
        )
      )
    )
  )
  (function logic_bool () to i5 in
    (add
      (score (and true true))
      (add
        (score (or false true))
        (add
          (score (xor true false))
          (add
            (score (not false))
            (add
              (score (not (not true)))
              (score (not (and true false)))
            )
          )
        )
      )
    )
  )
  (function logic_closure_bool () to i5 in
    {
      (var [flipper <to bool from bool>] (fn ([value bool]) to bool in (not value)))
      (add (score (flipper false)) (score (not (flipper true))))
    }
  )
  (function main ([args <array s3>]) to i5 in
    {
      (var [total i5] $0^i5)
      (var_set total (add total (numeric_i5)))
      (var_set total (add total (numeric_i6)))
      (var_set total (add total (numeric_i7)))
      (var_set total (add total (numeric_u5)))
      (var_set total (add total (numeric_u6)))
      (var_set total (add total (numeric_u7)))
      (var_set total (add total (numeric_f5)))
      (var_set total (add total (numeric_f6)))
      (var_set total (add total (numeric_f7)))
      (var_set total (add total (bitwise_i5)))
      (var_set total (add total (bitwise_i6)))
      (var_set total (add total (bitwise_i7)))
      (var_set total (add total (bitwise_u5)))
      (var_set total (add total (bitwise_u6)))
      (var_set total (add total (bitwise_u7)))
      (var_set total (add total (logic_bool)))
      (var_set total (add total (logic_closure_bool)))
      total
    }
  )
}
