      (var_set total (add total (score (lt $2p0^f5 $3p0^f5))))
      (var_set total (add total (score (ge $3p0^f5 $3p0^f5))))
      (var_set total (add total (score (gt $3p0^f5 $2p0^f5))))
      (var_set total (add total (score (eq $3p0^f5 $3p0^f5))))
      (var_set total (add total (score (neq $3p0^f5 $2p0^f5))))
      total
    }
  )
  (function numeric_f6 () to i5 in
    {
      (var [total i5] $0^i5)
      (var_set total (add total (score (eq (add $7p5^f6 $2p0^f6) $9p5^f6))))
      (var_set total (add total (score (eq (sub $7p5^f6 $2p0^f6) $5p5^f6))))
      (var_set total (add total (score (eq (mul $3p0^f6 $2p0^f6) $6p0^f6))))
      (var_set total (add total (score (eq (div $7p5^f6 $2p5^f6) $3p0^f6))))
      (var_set total (add total (score (eq (mod $7p5^f6 $2p0^f6) $1p5^f6))))
      (var_set total (add total (score (le $2p0^f6 $2p0^f6))))
      (var_set total (add total (score (lt $2p0^f6 $3p0^f6))))
      (var_set total (add total (score (ge $3p0^f6 $3p0^f6))))
      (var_set total (add total (score (gt $3p0^f6 $2p0^f6))))
      (var_set total (add total (score (eq $3p0^f6 $3p0^f6))))
