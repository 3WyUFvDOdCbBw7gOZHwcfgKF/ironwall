          (add
            (score (eq (ls $3^u5 $2^u5) $12^u5))
            (score (eq (rs $12^u5 $2^u5) $3^u5))
          )
        )
      )
    )
  )
  (function bitwise_u6 () to i5 in
    (add
      (score (eq (bwand $6^u6 $3^u6) $2^u6))
      (add
        (score (eq (bwor $6^u6 $3^u6) $7^u6))
        (add
          (score (eq (bwxor $6^u6 $3^u6) $5^u6))
          (add
