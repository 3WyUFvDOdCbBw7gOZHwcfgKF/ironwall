{program ray~tracer@main
  (import std~array)
  (import std~gc)
  (import std~math)
  (import std~string)
  (import std~linux~sys)

  (class Vec3
    (property [x f5])
    (property [y f5])
    (property [z f5])
    (constructor () in
      {
        (cm_set self x $0p0^f5)
        (cm_set self y $0p0^f5)
        (cm_set self z $0p0^f5)
      }
    )
    (constructor ([x0 f5] [y0 f5] [z0 f5]) in
      {
        (cm_set self x x0)
        (cm_set self y y0)
        (cm_set self z z0)
      }
    )
  )

  (class Ray
    (property [origin Vec3])
    (property [direction Vec3])
    (constructor ([origin0 Vec3] [direction0 Vec3]) in
      {
        (cm_set self origin origin0)
        (cm_set self direction direction0)
      }
    )
  )

  (class Aabb
    (property [min Vec3])
    (property [max Vec3])
    (constructor ([min0 Vec3] [max0 Vec3]) in
      {
        (cm_set self min min0)
        (cm_set self max max0)
      }
    )
  )

  (class Camera
    (property [origin Vec3])
    (property [lower_left Vec3])
    (property [horizontal Vec3])
    (property [vertical Vec3])
    (constructor ([origin0 Vec3] [lower_left0 Vec3] [horizontal0 Vec3] [vertical0 Vec3]) in
      {
        (cm_set self origin origin0)
        (cm_set self lower_left lower_left0)
        (cm_set self horizontal horizontal0)
        (cm_set self vertical vertical0)
      }
    )
  )

  (class DiffuseMaterial
    (property [albedo Vec3])
    (constructor ([albedo0 Vec3]) in
      {
        (cm_set self albedo albedo0)
      }
    )
  )

  (class MirrorMaterial
    (property [albedo Vec3])
    (property [reflectivity f5])
    (constructor ([albedo0 Vec3] [reflectivity0 f5]) in
      {
        (cm_set self albedo albedo0)
        (cm_set self reflectivity reflectivity0)
      }
    )
  )

  (class CheckerMaterial
    (property [albedo_a Vec3])
    (property [albedo_b Vec3])
    (property [scale f5])
    (constructor ([albedo_a0 Vec3] [albedo_b0 Vec3] [scale0 f5]) in
      {
        (cm_set self albedo_a albedo_a0)
        (cm_set self albedo_b albedo_b0)
        (cm_set self scale scale0)
      }
    )
  )

  (class SurfaceMaterial
    (property [kind <union DiffuseMaterial MirrorMaterial CheckerMaterial>])
    (constructor ([kind0 <union DiffuseMaterial MirrorMaterial CheckerMaterial>]) in
      {
        (cm_set self kind kind0)
      }
    )
  )

  (class Sphere
    (property [center Vec3])
    (property [radius f5])
    (property [material SurfaceMaterial])
    (constructor ([center0 Vec3] [radius0 f5] [material0 SurfaceMaterial]) in
      {
        (cm_set self center center0)
        (cm_set self radius radius0)
        (cm_set self material material0)
      }
    )
  )

  (class BoxShape
    (property [center Vec3])
    (property [half_extent Vec3])
    (property [material SurfaceMaterial])
    (constructor ([center0 Vec3] [half_extent0 Vec3] [material0 SurfaceMaterial]) in
      {
        (cm_set self center center0)
        (cm_set self half_extent half_extent0)
        (cm_set self material material0)
      }
    )
  )

  (class Plane
    (property [point Vec3])
    (property [normal Vec3])
    (property [material SurfaceMaterial])
    (constructor ([point0 Vec3] [normal0 Vec3] [material0 SurfaceMaterial]) in
      {
        (cm_set self point point0)
        (cm_set self normal normal0)
        (cm_set self material material0)
      }
    )
  )

  (class FaceIndex
    (property [a i5])
    (property [b i5])
    (property [c i5])
    (constructor () in
      {
        (cm_set self a $0^i5)
        (cm_set self b $0^i5)
        (cm_set self c $0^i5)
      }
    )
    (constructor ([a0 i5] [b0 i5] [c0 i5]) in
      {
        (cm_set self a a0)
        (cm_set self b b0)
        (cm_set self c c0)
      }
    )
  )

  (class Triangle
    (property [a Vec3])
    (property [b Vec3])
    (property [c Vec3])
    (property [ab Vec3])
    (property [ac Vec3])
    (property [normal Vec3])
    (property [bounds Aabb])
    (property [center Vec3])
    (constructor () in
      {
        (var [zero_vec Vec3] (class_new Vec3 $0p0^f5 $0p0^f5 $0p0^f5))
        (var [zero_bounds Aabb] (class_new Aabb zero_vec zero_vec))
        (cm_set self a zero_vec)
        (cm_set self b zero_vec)
        (cm_set self c zero_vec)
        (cm_set self ab zero_vec)
        (cm_set self ac zero_vec)
        (cm_set self normal zero_vec)
        (cm_set self bounds zero_bounds)
        (cm_set self center zero_vec)
      }
    )
    (constructor ([a0 Vec3] [b0 Vec3] [c0 Vec3] [ab0 Vec3] [ac0 Vec3] [normal0 Vec3] [bounds0 Aabb] [center0 Vec3]) in
      {
        (cm_set self a a0)
        (cm_set self b b0)
        (cm_set self c c0)
        (cm_set self ab ab0)
        (cm_set self ac ac0)
        (cm_set self normal normal0)
        (cm_set self bounds bounds0)
        (cm_set self center center0)
      }
    )
  )

  (class TransformSpec
    (property [center_shift Vec3])
    (property [scale_value f5])
    (property [yaw f5])
    (property [offset Vec3])
    (constructor ([center_shift0 Vec3] [scale_value0 f5] [yaw0 f5] [offset0 Vec3]) in
      {
        (cm_set self center_shift center_shift0)
        (cm_set self scale_value scale_value0)
        (cm_set self yaw yaw0)
        (cm_set self offset offset0)
      }
    )
  )

  (class HitRange
    (property [t_min f5])
    (property [t_max f5])
    (constructor ([t_min0 f5] [t_max0 f5]) in
      {
        (cm_set self t_min t_min0)
        (cm_set self t_max t_max0)
      }
    )
  )

  (class BvhLeaf
    (property [bounds Aabb])
    (property [indices <Array i5>])
    (constructor ([bounds0 Aabb] [indices0 <Array i5>]) in
      {
        (cm_set self bounds bounds0)
        (cm_set self indices indices0)
      }
    )
  )

  (class BvhBranch
    (property [bounds Aabb])
    (property [left <union BvhLeaf BvhBranch>])
    (property [right <union BvhLeaf BvhBranch>])
    (constructor ([bounds0 Aabb] [left0 <union BvhLeaf BvhBranch>] [right0 <union BvhLeaf BvhBranch>]) in
      {
        (cm_set self bounds bounds0)
        (cm_set self left left0)
        (cm_set self right right0)
      }
    )
  )

  (class MeshShape
    (property [bounds Aabb])
    (property [root <union BvhLeaf BvhBranch>])
    (property [triangles <Array Triangle>])
    (property [material SurfaceMaterial])
    (constructor ([bounds0 Aabb] [root0 <union BvhLeaf BvhBranch>] [triangles0 <Array Triangle>] [material0 SurfaceMaterial]) in
      {
        (cm_set self bounds bounds0)
        (cm_set self root root0)
        (cm_set self triangles triangles0)
        (cm_set self material material0)
      }
    )
  )

  (class SceneObject
    (property [kind <union Sphere BoxShape Plane MeshShape>])
    (constructor () in
      {
        (cm_set self kind
          (class_new Plane
            (class_new Vec3 $0p0^f5 $0p0^f5 $0p0^f5)
            (class_new Vec3 $0p0^f5 $1p0^f5 $0p0^f5)
            (class_new SurfaceMaterial
              (class_new DiffuseMaterial (class_new Vec3 $0p0^f5 $0p0^f5 $0p0^f5))
            )
          )
        )
      }
    )
    (constructor ([kind0 <union Sphere BoxShape Plane MeshShape>]) in
      {
        (cm_set self kind kind0)
      }
    )
  )

  (class DirectionalLight
    (property [direction Vec3])
    (property [color Vec3])
    (property [intensity f5])
    (constructor ([direction0 Vec3] [color0 Vec3] [intensity0 f5]) in
      {
        (cm_set self direction direction0)
        (cm_set self color color0)
        (cm_set self intensity intensity0)
      }
    )
  )

  (class PointLight
    (property [position Vec3])
    (property [color Vec3])
    (property [intensity f5])
    (constructor ([position0 Vec3] [color0 Vec3] [intensity0 f5]) in
      {
        (cm_set self position position0)
        (cm_set self color color0)
        (cm_set self intensity intensity0)
      }
    )
  )

  (class SceneLight
    (property [kind <union DirectionalLight PointLight>])
    (constructor () in
      {
        (cm_set self kind
          (class_new DirectionalLight
            (class_new Vec3 $0p0^f5 (sub $0p0^f5 $1p0^f5) $0p0^f5)
            (class_new Vec3 $0p0^f5 $0p0^f5 $0p0^f5)
            $0p0^f5
          )
        )
      }
    )
    (constructor ([kind0 <union DirectionalLight PointLight>]) in
      {
        (cm_set self kind kind0)
      }
    )
  )

  (class LightSample
    (property [direction Vec3])
    (property [color Vec3])
    (property [max_distance f5])
    (constructor ([direction0 Vec3] [color0 Vec3] [max_distance0 f5]) in
      {
        (cm_set self direction direction0)
        (cm_set self color color0)
        (cm_set self max_distance max_distance0)
      }
    )
  )

  (class HitRecord
    (property [distance f5])
    (property [position Vec3])
    (property [normal Vec3])
    (property [material SurfaceMaterial])
    (constructor ([distance0 f5] [position0 Vec3] [normal0 Vec3] [material0 SurfaceMaterial]) in
      {
        (cm_set self distance distance0)
        (cm_set self position position0)
        (cm_set self normal normal0)
        (cm_set self material material0)
      }
    )
  )

  (class ObjCounts
    (property [vertex_count i5])
    (property [face_count i5])
    (constructor ([vertex_count0 i5] [face_count0 i5]) in
      {
        (cm_set self vertex_count vertex_count0)
        (cm_set self face_count face_count0)
      }
    )
  )

  (class ObjModel
    (property [vertices <Array Vec3>])
    (property [faces <Array FaceIndex>])
    (constructor ([vertices0 <Array Vec3>] [faces0 <Array FaceIndex>]) in
      {
        (cm_set self vertices vertices0)
        (cm_set self faces faces0)
      }
    )
  )

  (class IndexSplit
    (property [left <Array i5>])
    (property [right <Array i5>])
    (constructor ([left0 <Array i5>] [right0 <Array i5>]) in
      {
        (cm_set self left left0)
        (cm_set self right right0)
      }
    )
  )

  (class RenderConfig
    (property [obj_path s3])
    (property [output_path s3])
    (property [width i5])
    (property [height i5])
    (constructor ([obj_path0 s3] [output_path0 s3] [width0 i5] [height0 i5]) in
      {
        (cm_set self obj_path obj_path0)
        (cm_set self output_path output_path0)
        (cm_set self width width0)
        (cm_set self height height0)
      }
    )
  )

  (class SceneBundle
    (property [camera Camera])
    (property [objects <Array SceneObject>])
    (property [lights <Array SceneLight>])
    (constructor ([camera0 Camera] [objects0 <Array SceneObject>] [lights0 <Array SceneLight>]) in
      {
        (cm_set self camera camera0)
        (cm_set self objects objects0)
        (cm_set self lights lights0)
      }
    )
  )

  (function char_of ([value s3]) to c3 in
    (s3_get value $0^i5)
  )

  (function i5_abs ([value i5]) to i5 in
    (if (lt value $0^i5) then (sub $0^i5 value) else value)
  )

  (function f5_min ([left f5] [right f5]) to f5 in
    (if (lt left right) then left else right)
  )

  (function f5_max ([left f5] [right f5]) to f5 in
    (if (gt left right) then left else right)
  )

  (function f5_clamp ([value f5] [lower f5] [upper f5]) to f5 in
    (if (lt value lower)
      then lower
      else
        (if (gt value upper)
          then upper
          else value
        )
    )
  )

  (function vec3_zero () to Vec3 in
    (class_new Vec3 $0p0^f5 $0p0^f5 $0p0^f5)
  )

  (function vec_add ([left Vec3] [right Vec3]) to Vec3 in
    (class_new Vec3
      (add left.x right.x)
      (add left.y right.y)
      (add left.z right.z)
    )
  )

  (function vec_sub ([left Vec3] [right Vec3]) to Vec3 in
    (class_new Vec3
      (sub left.x right.x)
      (sub left.y right.y)
      (sub left.z right.z)
    )
  )

  (function vec_scale ([value Vec3] [factor f5]) to Vec3 in
    (class_new Vec3
      (mul value.x factor)
      (mul value.y factor)
      (mul value.z factor)
    )
  )

  (function vec_hadamard ([left Vec3] [right Vec3]) to Vec3 in
    (class_new Vec3
      (mul left.x right.x)
      (mul left.y right.y)
      (mul left.z right.z)
    )
  )

  (function vec_neg ([value Vec3]) to Vec3 in
    (class_new Vec3
      (sub $0p0^f5 value.x)
      (sub $0p0^f5 value.y)
      (sub $0p0^f5 value.z)
    )
  )

  (function vec_dot ([left Vec3] [right Vec3]) to f5 in
    (add
      (mul left.x right.x)
      (add
        (mul left.y right.y)
        (mul left.z right.z)
      )
    )
  )

  (function vec_cross ([left Vec3] [right Vec3]) to Vec3 in
    (class_new Vec3
      (sub (mul left.y right.z) (mul left.z right.y))
      (sub (mul left.z right.x) (mul left.x right.z))
      (sub (mul left.x right.y) (mul left.y right.x))
    )
  )

  (function vec_length ([value Vec3]) to f5 in
    (sqrt (vec_dot value value))
  )

  (function vec_normalize ([value Vec3]) to Vec3 in
    {
      (var [length_value f5] (vec_length value))
      (if (lt length_value $0p000001^f5)
        then value
        else (vec_scale value (div $1p0^f5 length_value))
      )
    }
  )

  (function vec_min ([left Vec3] [right Vec3]) to Vec3 in
    (class_new Vec3
      (f5_min left.x right.x)
      (f5_min left.y right.y)
      (f5_min left.z right.z)
    )
  )

  (function vec_max ([left Vec3] [right Vec3]) to Vec3 in
    (class_new Vec3
      (f5_max left.x right.x)
      (f5_max left.y right.y)
      (f5_max left.z right.z)
    )
  )

  (function vec_component ([value Vec3] [axis i5]) to f5 in
    (if (eq axis $0^i5)
      then value.x
      else
        (if (eq axis $1^i5)
          then value.y
          else value.z
        )
    )
  )

  (function vec_lerp ([left Vec3] [right Vec3] [amount f5]) to Vec3 in
    (vec_add
      (vec_scale left (sub $1p0^f5 amount))
      (vec_scale right amount)
    )
  )

  (function reflect ([direction Vec3] [normal Vec3]) to Vec3 in
    (vec_sub direction (vec_scale normal (mul $2p0^f5 (vec_dot direction normal))))
  )

  (function ray_at ([ray Ray] [distance f5]) to Vec3 in
    (vec_add ray.origin (vec_scale ray.direction distance))
  )

  (function aabb_from_point ([point Vec3]) to Aabb in
    (class_new Aabb point point)
  )

  (function aabb_include_point ([bounds Aabb] [point Vec3]) to Aabb in
    (class_new Aabb (vec_min bounds.min point) (vec_max bounds.max point))
  )

  (function aabb_union ([left Aabb] [right Aabb]) to Aabb in
    (class_new Aabb
      (vec_min left.min right.min)
      (vec_max left.max right.max)
    )
  )

  (function aabb_max_extent_axis ([bounds Aabb]) to i5 in
    {
      (var [extent_x f5] (sub bounds.max.x bounds.min.x))
      (var [extent_y f5] (sub bounds.max.y bounds.min.y))
      (var [extent_z f5] (sub bounds.max.z bounds.min.z))
      (if (ge extent_x extent_y)
        then
          (if (ge extent_x extent_z) then $0^i5 else $2^i5)
        else
          (if (ge extent_y extent_z) then $1^i5 else $2^i5)
      )
    }
  )

  (function aabb_hit ([bounds Aabb] [ray Ray] [start_t f5] [end_t f5]) to bool in
    {
      (var [dir_x f5] ray.direction.x)
      (var [box_min_x f5] bounds.min.x)
      (var [box_max_x f5] bounds.max.x)
      (var [t_min_x f5] start_t)
      (var [t_max_x f5] end_t)
      (var [x_ok bool] true)
      (if (lt (abs dir_x) $0p000001^f5)
        then
          {
            (var_set x_ok (and (ge ray.origin.x box_min_x) (le ray.origin.x box_max_x)))
            unit
          }
        else
          {
            (var [inv_dir_x f5] (div $1p0^f5 dir_x))
            (var [raw_tx0 f5] (mul (sub box_min_x ray.origin.x) inv_dir_x))
            (var [raw_tx1 f5] (mul (sub box_max_x ray.origin.x) inv_dir_x))
            (var [near_tx f5] (f5_min raw_tx0 raw_tx1))
            (var [far_tx f5] (f5_max raw_tx0 raw_tx1))
            (var_set t_min_x (f5_max t_min_x near_tx))
            (var_set t_max_x (f5_min t_max_x far_tx))
            unit
          }
      )
      (if (or (not x_ok) (gt t_min_x t_max_x))
        then false
        else
          {
            (var [dir_y f5] ray.direction.y)
            (var [box_min_y f5] bounds.min.y)
            (var [box_max_y f5] bounds.max.y)
            (var [t_min_y f5] t_min_x)
            (var [t_max_y f5] t_max_x)
            (var [y_ok bool] true)
            (if (lt (abs dir_y) $0p000001^f5)
              then
                {
                  (var_set y_ok (and (ge ray.origin.y box_min_y) (le ray.origin.y box_max_y)))
                  unit
                }
              else
                {
                  (var [inv_dir_y f5] (div $1p0^f5 dir_y))
                  (var [raw_ty0 f5] (mul (sub box_min_y ray.origin.y) inv_dir_y))
                  (var [raw_ty1 f5] (mul (sub box_max_y ray.origin.y) inv_dir_y))
                  (var [near_ty f5] (f5_min raw_ty0 raw_ty1))
                  (var [far_ty f5] (f5_max raw_ty0 raw_ty1))
                  (var_set t_min_y (f5_max t_min_y near_ty))
                  (var_set t_max_y (f5_min t_max_y far_ty))
                  unit
                }
            )
            (if (or (not y_ok) (gt t_min_y t_max_y))
              then false
              else
                {
                  (var [dir_z f5] ray.direction.z)
                  (var [box_min_z f5] bounds.min.z)
                  (var [box_max_z f5] bounds.max.z)
                  (var [t_min_z f5] t_min_y)
                  (var [t_max_z f5] t_max_y)
                  (var [z_ok bool] true)
                  (if (lt (abs dir_z) $0p000001^f5)
                    then
                      {
                        (var_set z_ok (and (ge ray.origin.z box_min_z) (le ray.origin.z box_max_z)))
                        unit
                      }
                    else
                      {
                        (var [inv_dir_z f5] (div $1p0^f5 dir_z))
                        (var [raw_tz0 f5] (mul (sub box_min_z ray.origin.z) inv_dir_z))
                        (var [raw_tz1 f5] (mul (sub box_max_z ray.origin.z) inv_dir_z))
                        (var [near_tz f5] (f5_min raw_tz0 raw_tz1))
                        (var [far_tz f5] (f5_max raw_tz0 raw_tz1))
                        (var_set t_min_z (f5_max t_min_z near_tz))
                        (var_set t_max_z (f5_min t_max_z far_tz))
                        unit
                      }
                  )
                  (and z_ok (le t_min_z t_max_z))
                }
            )
          }
      )
    }
  )

  (function degrees_to_radians ([value f5]) to f5 in
    (div (mul value (pi_f5)) $180p0^f5)
  )

  (function make_camera ([look_from Vec3] [look_at Vec3] [up_hint Vec3] [fov_y_degrees f5] [aspect_ratio f5]) to Camera in
    {
      (var [theta f5] (degrees_to_radians fov_y_degrees))
      (var [half_angle f5] (mul theta $0p5^f5))
      (var [half_height f5] (div (sin half_angle) (cos half_angle)))
      (var [half_width f5] (mul aspect_ratio half_height))
      (var [w_basis Vec3] (vec_normalize (vec_sub look_from look_at)))
      (var [u_basis Vec3] (vec_normalize (vec_cross up_hint w_basis)))
      (var [v_basis Vec3] (vec_cross w_basis u_basis))
      (var [horizontal Vec3] (vec_scale u_basis (mul $2p0^f5 half_width)))
      (var [vertical Vec3] (vec_scale v_basis (mul $2p0^f5 half_height)))
      (var [lower_left Vec3]
        (vec_sub
          (vec_sub
            (vec_sub look_from (vec_scale u_basis half_width))
            (vec_scale v_basis half_height)
          )
          w_basis
        )
      )
      (class_new Camera look_from lower_left horizontal vertical)
    }
  )

  (function camera_ray ([camera Camera] [u f5] [v f5]) to Ray in
    {
      (var [point_on_plane Vec3]
        (vec_add
          camera.lower_left
          (vec_add
            (vec_scale camera.horizontal u)
            (vec_scale camera.vertical v)
          )
        )
      )
      (class_new Ray camera.origin (vec_normalize (vec_sub point_on_plane camera.origin)))
    }
  )

  (function digit_char ([value i5]) to c3 in
    (if (eq value $0^i5)
      then (char_of $digit0_s3^s3)
      else
        (if (eq value $1^i5)
          then (char_of $digit1_s3^s3)
          else
            (if (eq value $2^i5)
              then (char_of $digit2_s3^s3)
              else
                (if (eq value $3^i5)
                  then (char_of $digit3_s3^s3)
                  else
                    (if (eq value $4^i5)
                      then (char_of $digit4_s3^s3)
                      else
                        (if (eq value $5^i5)
                          then (char_of $digit5_s3^s3)
                          else
                            (if (eq value $6^i5)
                              then (char_of $digit6_s3^s3)
                              else
                                (if (eq value $7^i5)
                                  then (char_of $digit7_s3^s3)
                                  else
                                    (if (eq value $8^i5)
                                      then (char_of $digit8_s3^s3)
                                      else (char_of $digit9_s3^s3)
                                    )
                                )
