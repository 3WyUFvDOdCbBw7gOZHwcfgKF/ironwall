          (class_new Vec3 (sub $0p0^f5 $0p2167575^f5) $2p0^f5 (sub $0p0^f5 $1p575^f5))
          $0p72^f5
          (sub $0p0^f5 $0p55^f5)
          (class_new Vec3 $0p35^f5 $0p0^f5 $0p75^f5)
          teapot_material
        )
      )
      (gc_collect)
      (var [teapot_object SceneObject] (class_new SceneObject teapot_mesh))
      (var [primitive_objects <Array SceneObject>] (<array_new_fill SceneObject> $3^i5 ground_object))
      (primitive_objects.set $1^i5 sphere_object)
      (primitive_objects.set $2^i5 box_object)
      (var [mesh_objects <Array SceneObject>] (<array_new_fill SceneObject> $1^i5 teapot_object))
      (var [all_objects <Array SceneObject>] (<Array_concat SceneObject> primitive_objects mesh_objects))
      (gc_collect)
      (var [sun_light SceneLight]
        (class_new SceneLight
          (class_new DirectionalLight
            (vec_normalize (class_new Vec3 (sub $0p0^f5 $0p65^f5) (sub $0p0^f5 $1p0^f5) (sub $0p0^f5 $0p35^f5)))
            (class_new Vec3 $1p0^f5 $0p95^f5 $0p88^f5)
            $1p65^f5
          )
        )
      )
      (var [fill_light SceneLight]
        (class_new SceneLight
          (class_new PointLight
            (class_new Vec3 $2p7^f5 $3p8^f5 $3p6^f5)
            (class_new Vec3 $1p0^f5 $0p82^f5 $0p72^f5)
            $4p8^f5
          )
        )
      )
      (var [rim_light SceneLight]
        (class_new SceneLight
          (class_new PointLight
            (class_new Vec3 (sub $0p0^f5 $3p2^f5) $2p7^f5 $1p8^f5)
            (class_new Vec3 $0p72^f5 $0p82^f5 $1p0^f5)
            $3p2^f5
          )
        )
      )
      (var [lights <Array SceneLight>] (<array_new_fill SceneLight> $3^i5 sun_light))
      (lights.set $1^i5 fill_light)
      (lights.set $2^i5 rim_light)
      (var [aspect_ratio f5] (div (val_to_f5 config.width) (val_to_f5 config.height)))
      (var [camera Camera]
        (make_camera
          (class_new Vec3 $0p1^f5 $2p35^f5 $6p5^f5)
          (class_new Vec3 $0p35^f5 $1p05^f5 $0p45^f5)
          (class_new Vec3 $0p0^f5 $1p0^f5 $0p0^f5)
          $34p0^f5
          aspect_ratio
        )
      )
      (class_new SceneBundle camera all_objects lights)
    }
  )

  (function parse_config ([args <array s3>]) to RenderConfig in
    {
      (var [arg_count i5] (array_length args))
      (var [obj_path s3] (if (ge arg_count $1^i5) then (array_get args $0^i5) else $obj_default_s3^s3))
      (var [output_path s3] (if (ge arg_count $2^i5) then (array_get args $1^i5) else $output_default_s3^s3))
      (var [width i5] (if (ge arg_count $3^i5) then (parse_i5_range (array_get args $2^i5) $0^i5 (s3_length (array_get args $2^i5))) else $200^i5))
      (var [height i5] (if (ge arg_count $4^i5) then (parse_i5_range (array_get args $3^i5) $0^i5 (s3_length (array_get args $3^i5))) else $140^i5))
      (class_new RenderConfig obj_path output_path width height)
    }
  )

  (function render_scene ([bundle SceneBundle] [config RenderConfig]) to unit in
    {
      (var [fd i5] (sys_fd_creat_s3 config.output_path))
      (sys_fd_write_s3 fd (ppm_header_s3 config.width config.height))
      (var [y_index i5] $0^i5)
      (while (lt y_index config.height) in
        {
          (var [x_index i5] $0^i5)
          (while (lt x_index config.width) in
            {
              (var [u f5] (div (add (val_to_f5 x_index) $0p5^f5) (val_to_f5 config.width)))
              (var [v f5] (div (sub (sub (val_to_f5 config.height) (val_to_f5 y_index)) $0p5^f5) (val_to_f5 config.height)))
              (var [ray Ray] (camera_ray bundle.camera u v))
              (var [color Vec3] (trace_ray bundle.objects bundle.lights ray $1^i5))
              (sys_fd_write_s3 fd (ppm_line_s3 color))
              (var_set x_index (add x_index $1^i5))
              (if (eq (mod x_index $8^i5) $0^i5)
                then
                  {
                    (gc_collect)
                    unit
                  }
                else unit
              )
            }
          )
          (var_set y_index (add y_index $1^i5))
          (gc_collect)
        }
      )
      (sys_fd_close fd)
      unit
    }
  )

  (function main ([args <array s3>]) to i5 in
    {
      (quiet_gc_print)
      (var [config RenderConfig] (parse_config args))
      (var [bundle SceneBundle] (make_scene config))
      (render_scene bundle config)
      $0^i5
    }
  )
}